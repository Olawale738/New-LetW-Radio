    "frontend:build": "cd frontend && npm run build",
    "build": "npm run frontend:build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "ejs": "^6.0.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "socket.io": "^4.7.2",
    "sql.js": "^1.11.0",
    "uuid": "^9.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
