{
  "name": "online-radio",
  "version": "1.0.0",
  "description": "Full-featured online radio manager and streaming platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "frontend:install": "cd frontend && npm install",
