// ── Schedule ──────────────────────────────────────────────────
async function loadSchedule() {
  try {
    const res  = await fetch('/api/planning');
    const rows = await res.json();
    const now  = new Date();
    const dow  = now.getDay();
    const today = rows.filter(r => Number(r.day_of_week) === dow);
    const list  = document.getElementById('schedule-list');

    if (!today.length) {
      list.innerHTML = '<div style="font-size:12px;color:var(--text-dim);text-align:center;padding:20px;">No programs scheduled today.</div>';
      return;
    }

    const nowStr = now.toTimeString().slice(0, 5);
    list.innerHTML = '';
    today.forEach(row => {
      const current = row.start_time <= nowStr && row.end_time > nowStr;
      const div = document.createElement('div');
      div.className = 'schedule-item' + (current ? ' current' : '');
      div.innerHTML =
        '<div class="schedule-dot"></div>' +
        '<div class="schedule-time">' + row.start_time + ' – ' + row.end_time + '</div>' +
        '<div class="schedule-name">' + esc(row.content_name) + '</div>';
      list.appendChild(div);
    });
    startNextProgramCountdown(today);
  } catch(e) {
    document.getElementById('schedule-list').innerHTML =
      '<div style="font-size:12px;color:var(--text-dim);text-align:center;padding:20px;">Could not load schedule.</div>';
  }
}

function startNextProgramCountdown(rows) {
  if (window._countdownInterval) clearInterval(window._countdownInterval);
  const now    = new Date();
  const nowStr = now.toTimeString().slice(0, 5);
  const next   = rows.find(r => r.start_time > nowStr);
  if (!next) { document.getElementById('next-program-wrap').style.display = 'none'; return; }
  document.getElementById('next-program-wrap').style.display = 'block';
  document.getElementById('next-program-name').textContent = next.content_name || next.start_time;
  function tick() {
    const n = new Date();
    const [h, m] = next.start_time.split(':').map(Number);
    const target = new Date(n); target.setHours(h, m, 0, 0);
    if (target <= n) { clearInterval(window._countdownInterval); return; }
    const diff = target - n;
    const hh = Math.floor(diff / 3600000), mm = Math.floor((diff % 3600000) / 60000), ss = Math.floor((diff % 60000) / 1000);
    document.getElementById('next-program-countdown').textContent =
      (hh ? hh + 'h ' : '') + mm + 'm ' + ss + 's';
  }
  tick();
  window._countdownInterval = setInterval(tick, 1000);
}

async function loadRecentlyPlayed() {
  try {
    const res  = await fetch('/api/history');
    const rows = await res.json();
    const el   = document.getElementById('recently-played-list');
    if (!el) return;
    const last5 = rows.slice(0, 5);
    if (!last5.length) { el.innerHTML = '<div style="font-size:11px;color:var(--text-dim);text-align:center;padding:12px;">Nothing played yet.</div>'; return; }
    el.innerHTML = last5.map(r => {
      const t = r.played_at ? new Date(r.played_at).toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' }) : '';
      return '<div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid rgba(212,168,67,0.06);">' +
        '<div style="width:6px;height:6px;border-radius:50%;background:rgba(212,168,67,0.3);flex-shrink:0;"></div>' +
        '<div style="flex:1;min-width:0;"><div style="font-size:11px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(r.title||'') + '</div>' +
        '<div style="font-size:10px;color:var(--gold);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(r.artist||'') + '</div></div>' +
        '<div style="font-size:9px;color:var(--text-dim);flex-shrink:0;">' + t + '</div></div>';
    }).join('');
  } catch(e) {
    const el = document.getElementById('recently-played-list');
    if (el) el.innerHTML = '<div style="font-size:11px;color:var(--text-dim);text-align:center;padding:12px;">Could not load history.</div>';
  }
}

// ── Tabs ──────────────────────────────────────────────────────
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.toggle('active', p.id === 'tab-' + tab));
  if (tab === 'onair')    { loadSchedule(); loadRecentlyPlayed(); }
  if (tab === 'sermons')  { loadSermons(); }
}

// ── Request ───────────────────────────────────────────────────
function setReqType(type) {
  currentReqType = type;
  document.querySelectorAll('.req-type-btn').forEach(b => b.classList.toggle('active', b.dataset.type === type));
  const label  = document.getElementById('req-text-label');
  const area   = document.getElementById('req-text');
  const dedGrp = document.getElementById('req-dedication-group');
  if (type === 'song') {
    label.textContent = 'Song / Artist Name';
    area.placeholder  = 'What song would you like to hear?';
    dedGrp.style.display = 'none';
  } else if (type === 'prayer') {
    label.textContent = 'Prayer Request';
    area.placeholder  = 'Share your prayer request...';
    dedGrp.style.display = 'none';
  } else {
    label.textContent = 'Dedication Message';
    area.placeholder  = 'Write your dedication...';
    dedGrp.style.display = 'block';
  }
}

async function submitRequest() {
  const username  = document.getElementById('req-name').value.trim() || getUsername();
  const text      = document.getElementById('req-text').value.trim();
  const dedicated = document.getElementById('req-dedicated').value.trim();
  if (!text) return;
  try {
    const res = await fetch('/api/requests', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        username,
        request_type: currentReqType,
        request_text: text,
        dedicated_to: dedicated,
      }),
    });
    if (res.status === 403) {
      const data = await res.json().catch(() => ({}));
      showFlashAlert(data.message || 'You have been banned from the community.', '#e03060');
      return;
    }
    if (res.ok) {
      document.getElementById('req-text').value      = '';
      document.getElementById('req-dedicated').value = '';
      const toast = document.getElementById('req-toast');
      toast.classList.add('visible');
      setTimeout(() => toast.classList.remove('visible'), 3500);
    }
  } catch(e) {}
}

// ── Mobile Panel ──────────────────────────────────────────────
function toggleMobilePanel() {
  mobilePanelOpen = !mobilePanelOpen;
  document.getElementById('community-panel').classList.toggle('open', mobilePanelOpen);
  // Floating toggle always shows 💬 — the panel has its own ✕ close button now.
  // This prevents the ✕ from overlapping the chat send button at the bottom.
  document.getElementById('panel-backdrop').classList.toggle('visible', mobilePanelOpen);
}

// ── Embed code generator ──────────────────────────────────────
function _updateEmbedCode() {
  const box  = document.getElementById('embed-code-box');
  const link = document.getElementById('embed-preview-link');
  if (!box) return;
  const base = window.location.origin;
  const chId = _channels.find(c => c.url === _activeStreamUrl)?.id || '';
  const src  = base + '/embed' + (chId ? '?ch=' + chId : '');
  const code = `<iframe src="${src}" width="340" height="200" frameborder="0" allow="autoplay" style="border-radius:18px;"></iframe>`;
  box.value = code;
  if (link) link.href = src;
}

function copyEmbedCode() {
  const box = document.getElementById('embed-code-box');
  if (!box) return;
  navigator.clipboard.writeText(box.value).then(() => {
    const orig = box.style.borderColor;
    box.style.borderColor = 'rgba(212,168,67,0.6)';
    setTimeout(() => { box.style.borderColor = orig; }, 1200);
  }).catch(() => {
    box.select(); document.execCommand('copy');
  });
}

// Refresh embed code whenever active channel changes (monkey-patch switchChannel)
const _origSwitchChannel = switchChannel;
function switchChannel(url, name, channelId) {
  _origSwitchChannel(url, name, channelId);
  setTimeout(_updateEmbedCode, 100);
}

// ── Wake Lock ─────────────────────────────────────────────────
async function requestWakeLock() {
  if (!('wakeLock' in navigator)) return;
  try { wakeLock = await navigator.wakeLock.request('screen'); } catch(e) {}
}
async function releaseWakeLock() {
  if (wakeLock) { try { await wakeLock.release(); } catch(e) {} wakeLock = null; }
}
document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'visible') {
    if (isPlaying) requestWakeLock();
    // Resume the visualizer that was paused to save battery
    if ((isPlaying || isLive) && !vizRaf && analyser) drawAnalyserBars();
    // The browser may have silently killed the stream while backgrounded and
    // throttled our keepalive — verify the audio is still flowing, reconnect if not.
    _verifyPlaybackHealth();
  } else {
    // Tab hidden — pause canvas animation to reduce CPU/battery drain
    if (vizRaf) { cancelAnimationFrame(vizRaf); vizRaf = null; }
  }
});

// ── Media Session ─────────────────────────────────────────────
function setupMediaSession() {
  if (!('mediaSession' in navigator)) return;
  navigator.mediaSession.setActionHandler('play',  () => startPlayback());
  navigator.mediaSession.setActionHandler('pause', () => stopPlayback());
  navigator.mediaSession.setActionHandler('stop',  () => stopPlayback());
}

// (Keyboard shortcuts defined further below — Space/M/↑/↓/Escape)

document.addEventListener('click', e => {
  if (!e.target.closest('.sleep-wrap')) {
    document.getElementById('sleep-menu').classList.remove('open');
  }
});

// ── PWA ───────────────────────────────────────────────────────
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredInstall = e;
  if (!localStorage.getItem('letw_install_dismissed')) {
    document.getElementById('install-banner').classList.add('visible');
  }
});

function installPWA() {
  if (!deferredInstall) return;
  deferredInstall.prompt();
  deferredInstall.userChoice.then(() => { deferredInstall = null; dismissInstall(); });
}

function dismissInstall() {
  document.getElementById('install-banner').classList.remove('visible');
  localStorage.setItem('letw_install_dismissed', '1');
}

// ── Keyboard Shortcuts ────────────────────────────────────────
// Space  = play / pause
// M      = mute toggle
// ↑ / ↓  = volume up / down (5% steps)
// Escape = close share drawer / flash alert
document.addEventListener('keydown', e => {
  // Don't steal keys while typing in inputs
  const tag = (e.target.tagName || '').toLowerCase();
  if (tag === 'input' || tag === 'textarea' || tag === 'select') return;

  if (e.code === 'Space') {
    e.preventDefault();
    togglePlay();
  } else if (e.code === 'KeyM') {
    toggleMute();
  } else if (e.code === 'ArrowUp') {
    e.preventDefault();
    const vol = Math.min(1, Math.round((currentVolume + 0.05) * 100) / 100);
    const sld = document.getElementById('vol-slider');
    if (sld) sld.value = vol;
    currentVolume = vol;
    audio.volume  = isMuted ? 0 : vol;
    localStorage.setItem('letw_volume', vol);
    updateVolIcon();
  } else if (e.code === 'ArrowDown') {
    e.preventDefault();
    const vol = Math.max(0, Math.round((currentVolume - 0.05) * 100) / 100);
    const sld = document.getElementById('vol-slider');
    if (sld) sld.value = vol;
    currentVolume = vol;
    audio.volume  = isMuted ? 0 : vol;
    localStorage.setItem('letw_volume', vol);
    updateVolIcon();
  } else if (e.code === 'Escape') {
    closeShareDrawer();
    dismissFlashAlert();
  }
});

// ── Service Worker ────────────────────────────────────────────
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/sw.js').catch(() => {});
}

// ── Util ──────────────────────────────────────────────────────
function esc(s) {
  return String(s)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&#39;');
}

// ── Init ──────────────────────────────────────────────────────
(async function init() {
  // Set up canvas dimensions
  const dpr = window.devicePixelRatio || 1;
  canvas.width  = (canvas.parentElement ? canvas.parentElement.offsetWidth - 56 : 360) * dpr;
  canvas.height = 48 * dpr;
  canvas.style.width  = '';
  canvas.style.height = '48px';
  ctx2d.scale(dpr, dpr);
  drawIdleVisualizer();

  // Username
  document.getElementById('chat-username-display').textContent = getUsername();
  document.getElementById('req-name').value = getUsername();

  // Volume
  updateVolIcon();

  // Async loads
  await loadTicker();
  await loadChatHistory();

  // Fetch status
  try {
    const res  = await fetch('/api/status');
    const data = await res.json();
    applyStatus(data);
    if (data.radioName) {
      document.title = data.radioName + ' — Listen Live';
      const heroName = document.getElementById('hero-radio-name');
      if (heroName) heroName.textContent = data.radioName.toUpperCase();
    }
  } catch(e) {}

  // Push
  await initPush();

  // Media session
  setupMediaSession();

  // Channel deep-link: ?ch=channelId — load channels then auto-select
  try {
    const urlParams = new URLSearchParams(window.location.search);
    const chParam = urlParams.get('ch');
    if (chParam) {
      const r = await fetch('/api/streams');
      if (r.ok) {
        const chans = await r.json();
        const found = chans.find(c => c.id === chParam || c.name.toLowerCase() === chParam.toLowerCase());
        if (found) {
          _channels = chans;
          _activeStreamUrl  = found.url;
          _activeStreamName = found.name;
          renderChannelGrid();
          // Update track title to channel name
          const tt = document.getElementById('track-title');
          if (tt) tt.textContent = found.name;
        }
      }
    }
  } catch {}

  // NowPlaying metadata poller — DCLM-style 30-second refresh
  // Fills in elapsed time, duration, and album art as a backup to Socket.IO
  startNowPlayingPoller();

  // Embed code — set after channels loaded
  setTimeout(_updateEmbedCode, 500);

  // Auto-connect: pre-load the audio stream so pressing play starts instantly.
  // The audio element buffers silently in the background — no sound plays
  // until the user presses the play button.
  if (!isLive && !isPlaying) {
    audio.preload = 'auto';
    audio.src     = _activeStreamUrl;
    audio.load();
  }
})();

// ── NowPlaying poller (DCLM-style) ───────────────────────────────────────────
let _npPollTimer = null;
let _npElapsedTimer = null;
let _npElapsed = 0;
let _npDuration = 0;

function startNowPlayingPoller() {
  if (_npPollTimer) return;
  _pollNowPlaying(); // immediate first fetch
  _npPollTimer = setInterval(_pollNowPlaying, 30000); // every 30 s
}

async function _pollNowPlaying() {
  if (isLive) return; // live mode has its own state
  try {
    const res  = await fetch('/api/nowplaying');
    const data = await res.json();
    const np   = data.now_playing;
    if (!np) return;
    // Update track info if different from current
    const title  = np.song.title  || '';
    const artist = np.song.artist || '';
    const art    = np.song.art    || '';
    const trackTitle  = document.getElementById('track-title');
    const trackArtist = document.getElementById('track-artist');
    if (trackTitle && title && trackTitle.textContent !== title)  updateTrackInfo(title, artist);
    if (typeof updateAlbumArt === 'function' && art) updateAlbumArt(art);
    // Elapsed/duration progress
    _npDuration = np.duration || 0;
    _npElapsed  = np.elapsed  || 0;
    _syncProgressBar();
    // Listener count
    if (data.listeners && typeof data.listeners.current === 'number') {
      updateListeners(data.listeners.current);
    }
  } catch {}
}

function _syncProgressBar() {
  if (!_npDuration) return;
  const prog = document.getElementById('now-playing-progress');
  if (!prog) return;
  prog.classList.add('active');
  const pct = Math.min(_npElapsed / _npDuration, 1) * 100;
  prog.style.setProperty('--np-progress', pct + '%');
}

// Tick elapsed every second while playing
setInterval(() => {
  if (isPlaying && !isLive && _npDuration > 0) {
    _npElapsed = Math.min(_npElapsed + 1, _npDuration);
    _syncProgressBar();
  }
}, 1000);

// ══════════════════════════════════════════════════════════════
// Sermon / On-Demand playback
// ══════════════════════════════════════════════════════════════

/** Format seconds → M:SS or H:MM:SS */
function _fmtDur(secs) {
  if (!secs || secs <= 0) return '';
  secs = Math.floor(secs);
  const h = Math.floor(secs / 3600);
  const m = Math.floor((secs % 3600) / 60);
  const s = secs % 60;
  if (h > 0) return `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  return `${m}:${String(s).padStart(2,'0')}`;
}

/** Fetch sermon tracks from API and cache them. */
async function loadSermons() {
  if (_sermonLoaded) { renderSermons(_sermonTracks); return; }
  const listEl = document.getElementById('sermon-list');
  listEl.innerHTML = '<div style="font-size:12px;color:var(--text-dim);text-align:center;padding:28px 14px;">Loading sermons…</div>';
  try {
    // Try tray=sermon first, then tray=sermons, then all tracks
    let tracks = [];
    for (const tray of ['sermon', 'sermons', '']) {
      const url = tray ? `/api/tracks?tray=${tray}` : '/api/tracks';
      const r   = await fetch(url);
      if (r.ok) {
        const data = await r.json();
        if (Array.isArray(data) && data.length) { tracks = data; break; }
      }
    }
    _sermonTracks = tracks;
    _sermonLoaded = true;
    renderSermons(tracks);
  } catch (e) {
    listEl.innerHTML = '<div style="font-size:12px;color:var(--text-dim);text-align:center;padding:28px 14px;">Could not load sermons.</div>';
  }
}

/** Render the sermon list (optionally filtered). */
function renderSermons(tracks) {
  const listEl = document.getElementById('sermon-list');
  if (!tracks || !tracks.length) {
    listEl.innerHTML = `
      <div style="text-align:center;padding:28px 14px;">
        <div style="font-size:28px;margin-bottom:8px;">🎙️</div>
        <div style="font-size:12px;color:var(--text-dim);">No sermons available yet.</div>
        <div style="font-size:11px;color:var(--text-dim);margin-top:4px;">The admin can upload messages in the dashboard.</div>
      </div>`;
    return;
  }
  listEl.innerHTML = tracks.map(t => {
    const active = t.id === _currentSermonId;
    return `<div class="sermon-item${active ? ' active' : ''}" onclick="playSermon('${t.id}')" data-id="${t.id}">
      <div class="sermon-thumb">${active ? '▶' : '🎙️'}</div>
      <div class="sermon-info">
        <div class="sermon-title">${esc(t.title)}</div>
        <div class="sermon-speaker">${esc(t.artist || 'LETW Ministry')}</div>
      </div>
      <span class="sermon-duration">${_fmtDur(t.duration)}</span>
    </div>`;
  }).join('');
}

/** Client-side filter of the already-loaded list. */
function filterSermons(term) {
  const q = term.toLowerCase().trim();
  if (!q) { renderSermons(_sermonTracks); return; }
  renderSermons(_sermonTracks.filter(t =>
    (t.title || '').toLowerCase().includes(q) ||
    (t.artist || '').toLowerCase().includes(q) ||
    (t.album || '').toLowerCase().includes(q)
  ));
}

/** Start playing a sermon in the main audio element. */
async function playSermon(id) {
  const track = _sermonTracks.find(t => t.id === id);
  if (!track) return;

  // Stop live / regular stream cleanly
  if (isLive) exitLiveMode();
  clearTimeout(reconnectTO); reconnectTO = null;
  clearStallTimer();
  audio.pause();
  isPlaying = false;

  _sermonActive    = true;
  _currentSermonId = id;

  // Show seek bar
  document.getElementById('sermon-seek-wrap').classList.add('visible');
  document.getElementById('sermon-seek-bar').value = 0;
  document.getElementById('sermon-current-time').textContent = '0:00';
  document.getElementById('sermon-total-time').textContent   = _fmtDur(track.duration) || '0:00';

  // Show "Back to Radio" button in sermons tab
  const backBtn = document.getElementById('sermon-back-btn');
  if (backBtn) backBtn.classList.add('visible');

  // Update track info in player card
  updateTrackInfo(track.title, track.artist || 'LETW Ministry');
  const badge = document.getElementById('status-badge');
  const text  = document.getElementById('status-text');
  if (badge) badge.className = 'status-badge sermon';
  if (text)  text.textContent = 'SERMON';
  const heroStatus = document.getElementById('hero-status');
  if (heroStatus) heroStatus.textContent = 'SERMON';
  const heroDot = document.getElementById('hero-dot');
  if (heroDot) heroDot.style.background = '#4caf50';

  // Re-render list to highlight active item
  const searchVal = (document.getElementById('sermon-search') || {}).value || '';
  filterSermons(searchVal);

  // Load and play
  audio.src = `/api/tracks/${id}/preview`;
  audio.load();
  try {
    await audio.play();
    isPlaying = true;
    document.getElementById('play-icon').textContent = '⏸';
    document.getElementById('play-btn').classList.add('playing');
    document.getElementById('now-playing-progress').classList.add('active');
    setVinylPlaying(true);
    startVisualizerFromAudio();
    requestWakeLock();
  } catch(e) {
    // Autoplay blocked — user will press play
    document.getElementById('play-icon').textContent = '▶';
  }
}

/** Handle main audio's timeupdate for seek bar during sermon playback. */
audio.addEventListener('timeupdate', () => {
  if (!_sermonActive || _sermonSeekDragging || !audio.duration) return;
  const pct = audio.currentTime / audio.duration;
  document.getElementById('sermon-seek-bar').value = Math.round(pct * 1000);
  document.getElementById('sermon-current-time').textContent = _fmtDur(audio.currentTime);
  document.getElementById('sermon-total-time').textContent   = _fmtDur(audio.duration);
});

/** User drags the seek bar. */
function seekSermon(val) {
  if (!_sermonActive || !audio.duration) return;
  _sermonSeekDragging = true;
  const t = (val / 1000) * audio.duration;
  document.getElementById('sermon-current-time').textContent = _fmtDur(t);
}

audio.addEventListener('mouseup',   () => { if (_sermonSeekDragging) { _sermonSeekDragging = false; audio.currentTime = (document.getElementById('sermon-seek-bar').value / 1000) * audio.duration; } });
audio.addEventListener('touchend',  () => { if (_sermonSeekDragging) { _sermonSeekDragging = false; audio.currentTime = (document.getElementById('sermon-seek-bar').value / 1000) * audio.duration; } });

document.getElementById('sermon-seek-bar').addEventListener('pointerup', (e) => {
  if (!_sermonActive || !audio.duration) return;
  _sermonSeekDragging = false;
  audio.currentTime = (e.target.value / 1000) * audio.duration;
});
document.getElementById('sermon-seek-bar').addEventListener('pointerdown', () => {
  _sermonSeekDragging = true;
});

/** Auto-advance to next sermon when current one ends. */
audio.addEventListener('ended', () => {
  if (!_sermonActive) return;
  const idx = _sermonTracks.findIndex(t => t.id === _currentSermonId);
  if (idx >= 0 && idx < _sermonTracks.length - 1) {
    // Play the next sermon
    playSermon(_sermonTracks[idx + 1].id);
  } else {
    // End of list — return to stream
    stopSermon();
  }
});

/** Stop sermon and return to the live/regular radio stream. */
function stopSermon() {
  if (!_sermonActive) return;
  _sermonActive    = false;
  _currentSermonId = null;

  audio.pause();
  audio.src = '';
  isPlaying = false;
  clearStallTimer();

  // Hide seek bar
  document.getElementById('sermon-seek-wrap').classList.remove('visible');
  const backBtn = document.getElementById('sermon-back-btn');
  if (backBtn) backBtn.classList.remove('visible');

  // Re-render list to un-highlight
  const searchVal = (document.getElementById('sermon-search') || {}).value || '';
  filterSermons(searchVal);

  // Reset player UI
  document.getElementById('play-icon').textContent = '▶';
  document.getElementById('play-btn').classList.remove('playing');
  updateTrackInfo('LETW Radio', 'Light Encounter Tabernacle Worldwide');
  setStatusBadge(false);
  cancelSleepTimer();
  releaseWakeLock();

  // Reconnect to whichever channel the user last selected
  reconnectAudio(_activeStreamUrl);
}

// ══════════════════════════════════════════════════════════════
// Channel switcher (DCLM-style multi-stream selector)
// ══════════════════════════════════════════════════════════════

async function loadChannels() {
  try {
    const r = await fetch('/api/streams');
    if (!r.ok) throw new Error();
    _channels = await r.json();
  } catch { _channels = [{ id: 'default', name: 'Main Stream', url: '/stream', description: 'Primary broadcast', is_default: 1 }]; }
  renderChannelGrid();
}

function renderChannelGrid() {
  const grid = document.getElementById('channel-grid');
  if (!_channels.length) {
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:20px;font-size:12px;color:var(--text-dim);">No channels configured.</div>';
    return;
  }
  const icons = ['📻','🎙️','🙏','🎵','✨','🎚️','📡','🔊'];
  grid.innerHTML = _channels.map((ch, i) => {
    const active = ch.url === _activeStreamUrl || (ch.url === '/stream' && _activeStreamUrl === '/stream');
    const lang = ch.language || '';
    const badge = (lang && lang !== 'English') ? `<span style="font-size:8px;padding:1px 5px;border-radius:8px;background:rgba(212,168,67,0.15);color:var(--gold);margin-top:2px;display:inline-block;">${esc(lang)}</span>` : '';
    return `<div class="channel-btn${active ? ' active' : ''}" onclick="switchChannel('${ch.url.replace(/'/g,"\\'")}','${ch.name.replace(/'/g,"\\'")}','${(ch.id||'').replace(/'/g,'')}')">
      <div class="channel-btn-icon">${ch.image_url ? `<img src="${esc(ch.image_url)}" style="width:32px;height:32px;border-radius:8px;object-fit:cover;" onerror="this.style.display='none'">` : icons[i % icons.length]}</div>
      <div class="channel-btn-name">${esc(ch.name)}</div>
      ${badge}
      ${ch.description ? `<div class="channel-btn-desc">${esc(ch.description)}</div>` : ''}
    </div>`;
  }).join('');
}

function openChannelDrawer() {
  if (!_channels.length) loadChannels();
  document.getElementById('channel-drawer').classList.add('open');
  document.getElementById('channel-drawer-backdrop').classList.add('open');
}

function closeChannelDrawer() {
  document.getElementById('channel-drawer').classList.remove('open');
  document.getElementById('channel-drawer-backdrop').classList.remove('open');
}

function switchChannel(url, name, channelId) {
  closeChannelDrawer();
  if (url === _activeStreamUrl && isPlaying && !isLive) return;
  _activeStreamUrl = url;
  _activeStreamName = name;
  // Update URL bar with deep-link for sharing
  try {
    const u = new URL(window.location.href);
    if (channelId) u.searchParams.set('ch', channelId); else u.searchParams.delete('ch');
    window.history.replaceState({}, '', u.toString());
  } catch {}
  // Update ticker / title to show which channel is active
  const trackTitle  = document.getElementById('track-title');
  const trackArtist = document.getElementById('track-artist');
  if (trackTitle)  trackTitle.textContent  = name;
  if (trackArtist) trackArtist.textContent = 'LETW Radio';
  // Re-render the grid so the active highlight updates
  renderChannelGrid();
  // Stop live if active
  if (isLive) exitLiveMode();
  // Reconnect to the new URL
  clearTimeout(reconnectTO); reconnectTO = null;
  audio.pause();
  audio.src = url;
  audio.load();
  isPlaying = true;
  document.getElementById('play-icon').textContent = '⏸';
  document.getElementById('play-btn').classList.add('playing');
  setStatusBadge(true);
  audio.play().catch(() => scheduleReconnect());
}

// ── Patch getStreamUrl() to use the selected channel ─────────
// All <script> blocks in the same HTML page share the global lexical
// environment, so let/const from any prior block (isLive, LIVE_URL,
// _activeStreamUrl) are visible here.  Function declarations are
// mutable bindings, so we can safely reassign getStreamUrl.
getStreamUrl = function() { return isLive ? LIVE_URL : _activeStreamUrl; };

// ── Album art update ──────────────────────────────────────────
function updateAlbumArt(src) {
  const wrap    = document.getElementById('album-art-wrap');
  const bgWrap  = document.getElementById('art-bg-blur');
  const bgImg   = document.getElementById('art-bg-img');
  if (!src) {
    wrap.classList.remove('visible');
    if (bgWrap) bgWrap.classList.remove('visible');
    return;
  }
  const img = document.getElementById('album-art-img');
  img.onload = () => {
    wrap.classList.add('visible');
    // Echo the art as a blurred colour wash behind the player body
    if (bgImg && bgWrap) { bgImg.src = src; bgWrap.classList.add('visible'); }
  };
  img.onerror = () => {
    wrap.classList.remove('visible');
    if (bgWrap) bgWrap.classList.remove('visible');
  };
  if (img.src !== src) img.src = src;
}

// ── Equalizer bars toggle ──────────────────────────────────────────────────
function _syncEqBars() {
  const el = document.getElementById('eq-bars');
  if (!el) return;
  el.classList.toggle('playing', isPlaying && !_sermonActive);
}
// Hook into existing audio events
audio.addEventListener('playing', _syncEqBars);
audio.addEventListener('pause',   _syncEqBars);
audio.addEventListener('ended',   _syncEqBars);

// ── Volume slider gradient fill ────────────────────────────────────────────
(function initVolGradient() {
  const slider = document.getElementById('vol-slider');
  if (!slider) return;
  function update() {
    const pct = Math.round((slider.value - slider.min) / (slider.max - slider.min) * 100);
    slider.style.setProperty('--vol', pct + '%');
  }
  slider.addEventListener('input', update);
  update();
})();

// Load channels on startup
loadChannels();

// ── App Store Badges (DCLM-style) ─────────────────────────────────────────
// Fetches the app_store_android / app_store_ios settings
// and shows the download strip if at least one link is configured.
(async function initDCLMFeatures() {
  const settings = window.__S || {};

  // ── App Store Download Badges ────────────────────────────────────────────────
  const androidUrl = settings.app_store_android || '';
  const iosUrl     = settings.app_store_ios     || '';
  const strip      = document.getElementById('app-download-strip');
  const btnAndroid = document.getElementById('app-btn-android');
  const btnIos     = document.getElementById('app-btn-ios');
  let anyAppShown = false;
  if (androidUrl && btnAndroid) { btnAndroid.href = androidUrl; btnAndroid.style.display = 'inline-flex'; anyAppShown = true; }
  if (iosUrl     && btnIos)     { btnIos.href     = iosUrl;     btnIos.style.display     = 'inline-flex'; anyAppShown = true; }
  if (strip && anyAppShown) strip.style.display = 'block';
  if (settings.website_url) {
    const siteLink = document.querySelector('a.link-btn[href="https://letw.org"]');
    if (siteLink) siteLink.href = settings.website_url;
  }

  // ── YouTube Link ─────────────────────────────────────────────────────────────
  const ytWrap = document.getElementById('social-links-row');
  const ytUrl  = settings.social_youtube || 'https://www.youtube.com/watch?v=8wTuN77RZJ4';
  if (ytWrap && ytUrl) {
    ytWrap.innerHTML = `<a href="${ytUrl}" target="_blank" rel="noopener noreferrer" aria-label="Watch on YouTube"
      style="display:inline-flex;align-items:center;gap:8px;padding:8px 20px;border-radius:22px;
             background:rgba(224,48,48,0.12);border:1px solid rgba(224,48,48,0.4);
             color:#ff4444;font-size:13px;font-weight:700;text-decoration:none;transition:all 0.2s;
             letter-spacing:0.3px;"
      onmouseover="this.style.background='rgba(224,48,48,0.22)';this.style.borderColor='rgba(224,48,48,0.7)'"
      onmouseout="this.style.background='rgba(224,48,48,0.12)';this.style.borderColor='rgba(224,48,48,0.4)'">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="14" viewBox="0 0 576 512" fill="currentColor">
        <path d="M549.655 124.083c-6.281-23.65-24.787-42.276-48.284-48.597C458.781 64 288 64 288 64S117.22 64 74.629 75.486c-23.497 6.322-42.003 24.947-48.284 48.597-11.412 42.867-11.412 132.305-11.412 132.305s0 89.438 11.412 132.305c6.281 23.65 24.787 41.5 48.284 47.821C117.22 448 288 448 288 448s170.78 0 213.371-11.486c23.497-6.321 42.003-24.171 48.284-47.821 11.412-42.867 11.412-132.305 11.412-132.305s0-89.438-11.412-132.305zm-317.51 213.508V175.185l142.739 81.205-142.739 81.201z"/>
      </svg>
      Watch on YouTube
    </a>`;
    ytWrap.style.display = 'flex';
  }

  // ── Tawk.to Live Chat Widget ─────────────────────────────────────────────────
  // DCLM uses Tawk.to for live listener support; we do the same when configured.
  if (settings.tawkto_enabled === '1' && settings.tawkto_id) {
    const twkId = settings.tawkto_id.trim();
    if (twkId && !document.getElementById('tawkto-script')) {
      window.Tawk_API = window.Tawk_API || {};
      window.Tawk_LoadStart = new Date();
      const s1 = document.createElement('script');
      s1.id = 'tawkto-script';
      s1.async = true;
      s1.src = `https://embed.tawk.to/${twkId}`;
      s1.charset = 'UTF-8';
      s1.setAttribute('crossorigin', '*');
      document.head.appendChild(s1);
    }
  }

  // ── App Announcement Modal (DCLM modal.php style) ────────────────────────────
  // Shows once per session (sessionStorage flag) if admin has enabled it.
  if (settings.announce_modal_enabled === '1') {
    const modalKey = 'letw_announce_seen_' + (settings.announce_modal_title || '');
    if (!sessionStorage.getItem(modalKey)) {
      sessionStorage.setItem(modalKey, '1');
      const modal = document.getElementById('announce-modal');
      const titleEl = document.getElementById('announce-modal-title');
      const bodyEl  = document.getElementById('announce-modal-body');
      if (titleEl) titleEl.textContent = settings.announce_modal_title || 'Hello Beloved';
      if (bodyEl)  bodyEl.textContent  = settings.announce_modal_body  || '';
      // Populate app buttons inside modal too
      const modalAndroid = document.getElementById('announce-modal-android');
      const modalIos     = document.getElementById('announce-modal-ios');
      if (modalAndroid && androidUrl) { modalAndroid.href = androidUrl; modalAndroid.style.display = 'inline-flex'; }
      if (modalIos     && iosUrl)     { modalIos.href     = iosUrl;     modalIos.style.display     = 'inline-flex'; }
      if (modal) {
        modal.style.display = 'flex';
        // Auto-dismiss after 8s
        setTimeout(() => { if (modal) modal.style.display = 'none'; }, 8000);
      }
    }
  }

  // ── Google Analytics (DCLM footer.php style) ────────────────────────────────
  // Paste your GA4 measurement ID (G-XXXXXXXX) or UA-XXXXXXXX into admin settings.
  if (settings.ga_enabled === '1' && settings.ga_id) {
    const gaId = settings.ga_id.trim();
    if (gaId && !document.getElementById('ga-script')) {
      const gTag = document.createElement('script');
      gTag.id    = 'ga-script';
      gTag.async = true;
      gTag.src   = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
      document.head.appendChild(gTag);
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', gaId);
    }
  }
})();

function closeAnnounceModal() {
  const m = document.getElementById('announce-modal');
  if (m) m.style.display = 'none';
}
</script>

