function showRequestToast(status, text) {
  const wrap = document.getElementById('req-status-toast');
  if (!wrap) return;
  wrap.querySelector('.rst-status').textContent = status === 'played' ? '🎵 Now Playing Your Request!' : '✅ Request Approved!';
  wrap.querySelector('.rst-text').textContent = text || '';
  wrap.classList.add('visible');
