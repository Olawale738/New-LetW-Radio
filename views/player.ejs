<!-- Hidden audio element -->
<audio id="audio-element" preload="none"></audio>

<script src="/socket.io/socket.io.js"></script>
<script>
// ══════════════════════════════════════════════════════════════
// LETW Radio Player — Full-featured listener app
// ══════════════════════════════════════════════════════════════

// ── Constants ─────────────────────────────────────────────────
const CHAT_COLORS = ['#d4a843','#4a9fd4','#4caf82','#e05070','#9b6fd4','#d46a4a'];
const STREAM_URL  = '/stream';
const LIVE_URL    = '/live-stream';

// ── State ─────────────────────────────────────────────────────
let reconnectDelay = 500;          // start fast; doubles on each failure
const MAX_RECONNECT_DELAY = 20000; // cap at 20 s
let isPlaying     = false;
let isLive        = false;
let currentVolume = parseFloat(localStorage.getItem('letw_volume') || '0.85');
let isMuted       = false;
let sleepTick     = null;
let sleepEndTime  = null;
let audioCtx         = null;
let analyser         = null;
let analyserSource   = null;  // MediaStreamSource from captureStream (visualizer tap only)
let vizRaf           = null;
let wakeLock      = null;
let pushEnabled   = false;
let pushSub       = null;
let vapidPublicKey = '';
let stallTimer        = null;
let reconnectTO       = null;
let _liveEdgeTimer    = null;  // live-edge latency manager interval
let currentReqType = 'song';
let mobilePanelOpen = false;
let deferredInstall = null;
let currentTrackId  = null;   // set on trackStart for the like button
let likeDebounce    = false;  // prevent double-tap likes
let crossfadeRAF    = null;   // animation frame for volume crossfade
let crossfadeSecs   = 3;      // default; updated from trackWillEnd event
let flashAlertTimer = null;   // auto-dismiss timer for flash alerts
let _liveJoinTO     = null;   // timeout: if live audio doesn't start in 10 s, retry
let _liveTimerInterval = null; // interval for live broadcast duration display
let _liveStartedAt  = null;   // Date when the live broadcast began (for timer)
let _wasEverPlaying = false;  // true after first successful audio.play() — used to
                               // distinguish "Connecting" from "Buffering" in waiting state
let _streamErrorCount = 0;    // counts consecutive stream errors for error banner

// ── Live MediaSource streaming ────────────────────────────────
// PRIMARY:  Binary WebSocket /live-ws (raw ws frames, no Socket.IO overhead,
//           TCP_NODELAY, per-connection backpressure, 120-chunk ring buffer,
//           AudioWorklet jitter buffer for gapless playback)
// FALLBACK: Socket.IO live:audio events (legacy path, still supported)
// LAST:     HTTP /live-stream if MediaSource is unavailable (old mobile)
let liveMimeType  = 'audio/webm;codecs=opus'; // actual mimeType from admin's MediaRecorder
let _liveMS       = null;     // MediaSource instance
let _liveSB       = null;     // SourceBuffer
let _livePending  = [];       // chunks queued before SourceBuffer is ready
let _liveUseMS    = false;    // true = using MediaSource; false = HTTP /live-stream fallback
let _liveMSObjUrl = null;     // ObjectURL to revoke on cleanup
let _liveFailTO   = null;     // timeout for startLiveViaMS sourceopen watchdog

// ── Binary WebSocket live transport ──────────────────────────
// Frame protocol: [type:1][seq:4 LE][ts:8 LE][payload...]
// Types: 0x01=HELLO, 0x02=INIT, 0x03=AUDIO, 0x04=ENDED, 0x05=PING, 0x06=PONG
const LWS_HELLO = 0x01, LWS_INIT = 0x02, LWS_AUDIO = 0x03,
      LWS_ENDED = 0x04, LWS_PING  = 0x05, LWS_PONG  = 0x06;
const LWS_HDR   = 13; // header size in bytes
let   _lws      = null;  // WebSocket to /live-ws
let   _lwsTimer = null;  // reconnect timer
let   _lwsSeq   = 0;     // last received sequence number
let   _lwsRtt   = null;  // latest RTT measurement (ms)
let   _lwsPingTs = 0;    // client timestamp when last ping was sent

// ── Unified Audio Processing Graph ───────────────────────────
// One AudioContext processes ALL audio — regular stream AND live broadcast.
// Chain:
//   <audio> → MediaElementSourceNode
//     → HPF(80Hz) → LowShelf(120Hz,+3.5dB) → Peak(220Hz,+2.5dB)
//     → Peak(380Hz,-2dB) → Peak(1.2kHz,-1dB) → Peak(2.8kHz,+3dB)
//     → Peak(6kHz,+1.5dB) → HighShelf(12kHz,+2.5dB)
//     → Compressor1(-20dB, 3:1, 8ms/200ms)
//     → Compressor2(-4dB, 10:1, 1ms/50ms)  [brick-wall limiter]
//     → AudioWorkletNode(audio-processor)   [stereo width, saturation, true-peak limit]
//     → GainNode(makeup)
//     → [AudioWorkletNode(live-stream-processor) — only in live mode]
//     → AudioContext.destination
let _audioCtx     = null;  // shared AudioContext (created once on first gesture)
let _srcNode      = null;  // MediaElementSourceNode (created once, never recreated)
let _chainTail    = null;  // last node before destination (audio-processor output)
let _outGain      = null;  // master output gain node
let _liveWorklet  = null;  // live-stream-processor (inserted only in live mode)
let _graphReady   = false; // true once chain is set up and audio-processor loaded
let _graphLoading = false; // prevents concurrent _setupAudioGraph calls

// ── Sermon / On-Demand state ──────────────────────────────────
let _sermonTracks      = [];      // full list fetched from API
let _sermonActive      = false;   // true while a sermon is playing in main audio
let _currentSermonId   = null;    // id of the currently-active sermon track
let _sermonSeekDragging = false;  // true while user is dragging the seek bar
let _sermonLoaded      = false;   // tracks list loaded at least once

// ── Channel / Stream state ────────────────────────────────────
let _channels       = [];          // list fetched from /api/streams
let _activeStreamUrl = '/stream';  // currently active stream URL
let _activeStreamName = 'Main Stream';

// ── Username ──────────────────────────────────────────────────
function getUsername() {
  let u = localStorage.getItem('letw_username');
  if (!u) {
    u = 'BlessedListener' + (100 + Math.floor(Math.random() * 900));
    localStorage.setItem('letw_username', u);
  }
  return u;
}

function changeUsername() {
  const n = prompt('Enter your display name:', getUsername());
  if (n && n.trim()) {
    localStorage.setItem('letw_username', n.trim().slice(0, 50));
    document.getElementById('chat-username-display').textContent = getUsername();
  }
}

function userColor(name) {
  let h = 0;
  for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) >>> 0;
  return CHAT_COLORS[h % CHAT_COLORS.length];
}

// ── Background Particles ──────────────────────────────────────
(function spawnParticles() {
  const container = document.createElement('div');
  container.id = 'particles-bg';
  document.body.insertBefore(container, document.body.firstChild);
  const GOLD_COLORS = ['rgba(212,168,67,', 'rgba(240,200,90,', 'rgba(180,130,40,'];
  for (let i = 0; i < 28; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    const size   = 1.5 + Math.random() * 3;
    const left   = Math.random() * 100;
    const delay  = Math.random() * 18;
    const dur    = 12 + Math.random() * 14;
    const color  = GOLD_COLORS[Math.floor(Math.random() * GOLD_COLORS.length)];
    const opacity = 0.3 + Math.random() * 0.5;
    p.style.cssText = `width:${size}px;height:${size}px;left:${left}%;bottom:-10px;` +
      `background:${color}${opacity});` +
      `animation-duration:${dur}s;animation-delay:-${delay}s;` +
      `filter:blur(${size > 3 ? 1 : 0}px);`;
    container.appendChild(p);
  }
})();

// ── Vinyl + Track Title helpers ───────────────────────────────
function setVinylPlaying(on) {
  const disc  = document.getElementById('vinyl-disc');
  const title = document.getElementById('track-title');
  const hero  = document.getElementById('hero-status');
  const card  = document.getElementById('player-card');
  if (disc) disc.classList.toggle('visible', on);
  if (title) title.classList.toggle('on-air', on);
  if (hero) {
    hero.classList.toggle('on-air-status', on && !isLive);
    hero.classList.toggle('live-status', isLive);
  }
  // Equalizer bar sync (defined later; called safely)
  if (typeof _syncEqBars === 'function') _syncEqBars();
  // Card glow when playing
  if (card) card.style.boxShadow = on
    ? '0 32px 100px rgba(0,0,0,0.88), 0 0 0 1px rgba(212,168,67,0.18), 0 0 80px rgba(212,168,67,0.1), inset 0 1px 0 rgba(212,168,67,0.18)'
    : '';
}

// ── Socket.IO ─────────────────────────────────────────────────
const socket = io({ transports: ['websocket', 'polling'] });

socket.on('connect', () => {
  setSignal('Connected');
  // For live streams: don't call reconnectAudio() here. The server immediately
  // sends a 'status' event on connect, which calls applyStatus() → switchToLiveMode().
  // switchToLiveMode() sets up the binary WebSocket + MediaSource pipeline properly.
  // Calling reconnectAudio(LIVE_URL) here would start the HTTP fallback path, then
  // switchToLiveMode() would tear it down a frame later — causing a brief audio glitch
  // and sometimes a spurious scheduleLiveReconnect loop.
  if (isPlaying && !isLive) reconnectAudio(getStreamUrl());
  // Stop polling fallback now that socket is connected
  _stopStatusPoll();
});

socket.on('disconnect', () => {
  setSignal('Disconnected');
  // ── DCLM-style polling fallback ──────────────────────────────────────────
  // When Socket.IO disconnects, poll /api/status every 30 s so the now-playing
  // display and live state remain current even without a WebSocket.
  _startStatusPoll();
});

socket.on('status', data => applyStatus(data));

socket.on('trackStart', track => {
  updateTrackInfo(
    track.title  || 'LETW Radio',
    track.artist || 'Light Encounter Tabernacle Worldwide'
  );
  // Show album art if provided (e.g. from NowPlaying API or track metadata)
  if (typeof updateAlbumArt === 'function') updateAlbumArt(track.cover_art_url || track.art || '');
  // Update like button for the new track
  resetLikeBtn();
  currentTrackId = track.id || null;
  // Crossfade: fade in volume
  if (isPlaying && !isMuted) {
    audio.volume = 0;
    fadeTo(currentVolume, crossfadeSecs * 1000);
  }
});

socket.on('listenerChange', count => updateListeners(count));

socket.on('live:started', info => {
  isLive = true;
  if (info && info.mimeType) liveMimeType = info.mimeType;
  switchToLiveMode(info);
});

socket.on('live:ended', () => {
  isLive = false;
  clearTimeout(window._liveConnectTO);
  exitLiveMode();
});

// ── Live audio delivered via Socket.IO (primary path) ─────────
// The server broadcasts each MediaRecorder chunk via socket.broadcast.emit
// so every connected listener receives it over the existing WebSocket.
// Chunks are appended to the MediaSource SourceBuffer; if the SourceBuffer
// isn't ready yet they're queued in _livePending and flushed on sourceopen.
socket.on('live:audio', (data) => {
  // Binary WS is primary; only process Socket.IO audio as fallback when WS is down
  if (_lws && _lws.readyState === WebSocket.OPEN) return;
  if (!isLive || !_liveMS) return;
  const buf = _toAB(data);
  if (!buf) return;
  _livePending.push(buf);
  _liveFlush();
  // If the audio element is paused but we have a SourceBuffer ready,
  // nudge play() — handles the case where the initial play() call got
  // an AbortError before data arrived, or after a silent stall resume.
  // We no longer gate on !reconnectTO: if a reconnect timer is already
  // pending and data is flowing, we should resume rather than wait.
  if (_liveUseMS && !_liveSB?.updating && audio.paused) {
    audio.play().catch(() => {});
  }
});

// Init chunk (WebM EBML header) sent by the server when the client
// requests it (live:request-init) or when it first connects mid-broadcast.
socket.on('live:init', (data) => {
  if (!isLive) return;
  // Buffer even before the SourceBuffer is ready: sourceopen may not have fired
  // yet when this arrives (server sends status + live:init in the same tick).
  // _liveFlush() is a no-op until _liveSB exists, but the data will be drained
  // the moment sourceopen fires and calls _liveFlush().
  if (!_liveMS && !_liveUseMS) return; // not using MediaSource path — skip
  const buf = _toAB(data);
  if (!buf) return;
  // Prepend so the EBML header is the very first thing appended to the SourceBuffer
  _livePending.unshift(buf);
  _liveFlush();
});

// Catchup buffer: a burst of the last ~6 s of audio sent to late-joining listeners
// so MediaSource has enough data to begin decoding without waiting for the next keyframe.
socket.on('live:catchup', (chunks) => {
  if (!isLive) return;
  if (!Array.isArray(chunks)) return;
  if (!_liveMS && !_liveUseMS) return; // not using MediaSource path — skip
  let added = 0;
  for (const chunk of chunks) {
    const buf = _toAB(chunk);
    if (buf) { _livePending.push(buf); added++; }
  }
  if (added > 0) _liveFlush();
});

socket.on('chat:message', msg => appendChatMessage(msg, true));

socket.on('chat:deleted', ({ id }) => {
  const el = document.querySelector('[data-msg-id="' + id + '"]');
  if (el) el.remove();
});

socket.on('chat:cleared', () => {
  document.getElementById('chat-messages').innerHTML =
    '<div class="chat-msg system"><div class="chat-text">Chat has been cleared.</div></div>';
});

socket.on('chat:reaction', ({ emoji }) => spawnFloatingEmoji(emoji));

socket.on('ticker:update', ({ text, enabled }) => setTicker(text, enabled));

socket.on('request:updated', ({ id, status, request_text }) => {
  if (status === 'approved' || status === 'played') {
    showRequestToast(status, request_text);
  }
});

socket.on('flash:alert', ({ message, color }) => {
  showFlashAlert(message, color);
});

socket.on('trackWillEnd', ({ secondsLeft }) => {
  crossfadeSecs = secondsLeft || 3;
  // Crossfade: fade out volume before track ends
  if (isPlaying && !isMuted) {
    fadeTo(0, (secondsLeft || 3) * 1000);
  }
});

// ── Status helpers ────────────────────────────────────────────
function applyStatus(data) {
  if (!data) return;
  const badge      = document.getElementById('status-badge');
  const text       = document.getElementById('status-text');
  const heroStatus = document.getElementById('hero-status');

  // ── Sync isLive flag ─────────────────────────────────────────
  // applyStatus is called both on socket 'status' events AND on page-load
  // fetch('/api/status'). We MUST update the local isLive flag here, otherwise
  // listeners who (a) open the page while already live, or (b) reconnect
  // mid-broadcast will always use /stream instead of /live-stream.
  if (data.isLive && !isLive) {
    // Server is live but we don't know it yet — enter live mode.
    // switchToLiveMode checks isPlaying and only auto-reconnects active listeners.
    isLive = true;
    if (data.liveMimeType) liveMimeType = data.liveMimeType;
    switchToLiveMode({ title: data.liveTitle, artist: data.liveArtist, mimeType: data.liveMimeType });
  } else if (!data.isLive && isLive) {
    // Live broadcast ended while we were in live mode — return to normal stream
    isLive = false;
    exitLiveMode();
  }
  // ── Badge ───────────────────────────────────────────────────
  if (data.isLive || isLive) {
    badge.className = 'status-badge live';
    text.textContent = 'LIVE BROADCAST';
    if (heroStatus) heroStatus.textContent = 'LIVE';
  } else if (data.isPlaying) {
    badge.className = 'status-badge on-air';
    text.textContent = 'ON AIR';
    if (heroStatus) heroStatus.textContent = 'ON AIR';
  } else {
    badge.className = 'status-badge offline';
    text.textContent = 'OFFLINE';
    if (heroStatus) heroStatus.textContent = 'OFFLINE';
  }
  if (data.currentTrack) {
    updateTrackInfo(
      data.currentTrack.title  || 'LETW Radio',
      data.currentTrack.artist || 'Light Encounter Tabernacle Worldwide'
    );
  }
  if (data.liveTitle && (data.isLive || isLive)) {
    updateTrackInfo(
      data.liveTitle  || 'Live Broadcast',
      data.liveArtist || 'Light Encounter Tabernacle Worldwide'
    );
  }
  if (typeof data.listeners === 'number') updateListeners(data.listeners);
  if (data.bitrate) document.getElementById('meta-bitrate').textContent = data.bitrate + ' kbps';
}

// ── DCLM-style polling fallback ──────────────────────────────────────────────
// Polls /api/status every 30 s when the WebSocket is disconnected, so the
// now-playing title and live state stay current without a real-time connection.
let _statusPollTimer = null;
function _startStatusPoll() {
  if (_statusPollTimer) return; // already polling
  _statusPollTimer = setInterval(async () => {
    try {
      const data = await fetch('/api/status').then(r => r.json());
      applyStatus(data);
    } catch(_) {}
  }, 30000);
}
function _stopStatusPoll() {
  if (_statusPollTimer) { clearInterval(_statusPollTimer); _statusPollTimer = null; }
}

function updateTrackInfo(title, artist) {
  document.getElementById('track-title').textContent  = title;
  document.getElementById('track-artist').textContent = artist;
  document.getElementById('onair-title').textContent  = title;
  document.getElementById('onair-artist').textContent = artist;
  updateFavBtn(title, artist);
  if ('mediaSession' in navigator) {
    navigator.mediaSession.metadata = new MediaMetadata({
      title, artist, album: 'LETW Radio',
      artwork: [{ src: '/logo.png', sizes: '512x512', type: 'image/png' }],
    });
  }
}

function updateListeners(count) {
  const el    = document.getElementById('listener-count');
  const label = document.getElementById('listener-label');
  const heroCount = document.getElementById('hero-listener-count');
  // Show "–" until we get an actual update from the server so we never
  // show a misleading "0 listening" when the data hasn't arrived yet.
  const display = (count === null || count === undefined) ? '–' : count;
  if (el)    el.textContent = display;
  if (label) label.textContent = (count === 1) ? 'listening' : 'listening';
  if (heroCount) heroCount.textContent = display;
}

function setSignal(val) {
  document.getElementById('meta-signal').textContent = val;
}

// ── Live MediaSource engine ───────────────────────────────────

/** Release all MediaSource resources for the live stream. */
function cleanupLiveMS() {
  _liveUseMS   = false;
  _livePending = [];
  if (_liveSB) {
    try { _liveSB.abort(); } catch(_) {}
    _liveSB = null;
  }
  // Cancel the sourceopen watchdog so it doesn't fire after cleanup and
  // trigger a spurious HTTP fallback on the newly-created MediaSource.
  if (_liveFailTO) { clearTimeout(_liveFailTO); _liveFailTO = null; }
  // Do NOT call endOfStream() — it would fire 'ended' on the audio element
  // and kick off a second competing reconnect loop.  Just orphan the object
  // and let GC collect it.
  _liveMS = null;
  // ObjectURL is revoked by startLiveViaMS() when it creates a replacement,
  // or by the final call in exitLiveMode().  Don't revoke here to avoid
  // the audio element briefly pointing to a dead blob URL.
}

/** Drain one pending chunk into the SourceBuffer (called after each updateend). */
function _liveFlush() {
  if (!_liveSB || _liveSB.updating || _livePending.length === 0) return;
  // Guard against stale/closed MediaSource — appendBuffer throws InvalidStateError
  // if the MediaSource is not in 'open' state (e.g. after cleanupLiveMS was called
  // on the previous session but sourceopen fired late on the orphaned object).
  if (!_liveMS || _liveMS.readyState !== 'open') return;
  try {
    // Keep buffer lean: max 3 s total, keep only last 1 s.
    // Tighter limits = less latency between admin voice and listener ear.
    if (_liveSB.buffered.length > 0) {
      const end   = _liveSB.buffered.end(_liveSB.buffered.length - 1);
      const start = _liveSB.buffered.start(0);
      if (end - start > 3) {
        _liveSB.remove(start, Math.max(start + 0.1, end - 1));
        return; // updateend will re-call _liveFlush
      }
    }
    _liveSB.appendBuffer(_livePending.shift());
  } catch(e) {
    if (e.name === 'QuotaExceededError' || e.name === 'InvalidStateError') {
      console.warn('[Live] SourceBuffer error', e.name, '— falling back to HTTP');
      _livePending = [];
      cleanupLiveMS();
      if (isLive) reconnectAudio(LIVE_URL);
    }
  }
}

/**
 * Helper to convert Socket.IO binary payloads to ArrayBuffer.
 * Socket.IO v4 delivers binary as ArrayBuffer in the browser.
 */
function _toAB(data) {
  if (data instanceof ArrayBuffer) return data;
  if (ArrayBuffer.isView(data)) {
    return data.buffer.slice(data.byteOffset, data.byteOffset + data.byteLength);
  }
  return null;
}

// ─────────────────────────────────────────────────────────────────────────────
// Unified Audio Processing Graph
// Called once on the first user-gesture (play button tap).  Sets up the full
// 8-band EQ → 2-stage compressor → audio-processor worklet chain.
// All subsequent audio — regular stream AND live — flows through this chain.
// ─────────────────────────────────────────────────────────────────────────────

async function _setupAudioGraph() {
  if (_graphReady || _graphLoading) return;
  _graphLoading = true;

  try {
    // One AudioContext for the entire session (Chrome: 6-per-page limit)
    _audioCtx = new (window.AudioContext || window.webkitAudioContext)({
      latencyHint: 'playback', // prioritise smooth output over low latency
      sampleRate:  48000,      // Opus/WebM native sample rate
    });
    if (_audioCtx.state === 'suspended') await _audioCtx.resume();

    // ── Load worklets ────────────────────────────────────────────────────
    // audio-processor: stereo widening + saturation + true-peak limiter
    // live-worklet:    dropout fade concealment (live mode only)
    // Cache-bust worklet URLs so browsers always load the latest version after a deploy.
    // The query param changes each page load; server responds with 304 if file unchanged.
    const _wv = Date.now();
    let workletsOk = false;
    try {
      await _audioCtx.audioWorklet.addModule('/audio-processor.js?v=' + _wv);
      await _audioCtx.audioWorklet.addModule('/live-worklet.js?v=' + _wv);
      workletsOk = true;
    } catch (wErr) {
      console.warn('[Audio] Worklets unavailable — EQ chain only:', wErr.message);
    }

    // ── MediaElementSourceNode ───────────────────────────────────────────
    // Create ONCE — the browser throws if called twice on the same element.
    _srcNode = _audioCtx.createMediaElementSource(audio);

    // ── 8-Band Equaliser ─────────────────────────────────────────────────
    // Tuned for Gospel/Church radio: warm lows, clear vocals, airy highs.

    // 1. High-Pass 80 Hz — remove floor rumble, A/C noise, mic handling
    const hp = _audioCtx.createBiquadFilter();
    hp.type = 'highpass'; hp.frequency.value = 80; hp.Q.value = 0.707;

    // 2. Low Shelf +3.5 dB @ 120 Hz — body and warmth (music fullness)
    const ls = _audioCtx.createBiquadFilter();
    ls.type = 'lowshelf'; ls.frequency.value = 120; ls.gain.value = 3.5;

    // 3. +2.5 dB @ 220 Hz Q=0.9 — punch and chest resonance
    const b1 = _audioCtx.createBiquadFilter();
    b1.type = 'peaking'; b1.frequency.value = 220; b1.Q.value = 0.9; b1.gain.value = 2.5;

    // 4. -2.0 dB @ 380 Hz Q=1.2 — remove "boxy/telephone" sound
    const b2 = _audioCtx.createBiquadFilter();
    b2.type = 'peaking'; b2.frequency.value = 380; b2.Q.value = 1.2; b2.gain.value = -2.0;

    // 5. -1.0 dB @ 1.2 kHz Q=2.0 — remove nasal/honky room character
    const b3 = _audioCtx.createBiquadFilter();
    b3.type = 'peaking'; b3.frequency.value = 1200; b3.Q.value = 2.0; b3.gain.value = -1.0;

    // 6. +3.0 dB @ 2.8 kHz Q=1.4 — vocal presence and speech intelligibility
    const b4 = _audioCtx.createBiquadFilter();
    b4.type = 'peaking'; b4.frequency.value = 2800; b4.Q.value = 1.4; b4.gain.value = 3.0;

    // 7. +1.5 dB @ 6 kHz Q=1.0 — consonant clarity (s, t, k, ch sounds)
    const b5 = _audioCtx.createBiquadFilter();
    b5.type = 'peaking'; b5.frequency.value = 6000; b5.Q.value = 1.0; b5.gain.value = 1.5;

    // 8. High Shelf +2.5 dB @ 12 kHz — air and sparkle
    const hs = _audioCtx.createBiquadFilter();
    hs.type = 'highshelf'; hs.frequency.value = 12000; hs.gain.value = 2.5;

    // ── Stage 1 Compressor — musical dynamics control ────────────────────
    // Gentle ratio, slow attack (let transients punch through) — music.
    const comp1 = _audioCtx.createDynamicsCompressor();
    comp1.threshold.value = -20; // dB
    comp1.knee.value      = 8;   // dB — soft knee
    comp1.ratio.value     = 3;   // 3:1
    comp1.attack.value    = 0.008; // 8 ms — fast enough to catch loud notes
    comp1.release.value   = 0.2;   // 200 ms — musical release

    // ── Stage 2 Compressor — broadcast brick-wall limiter ────────────────
    // Very high ratio, instant attack — prevents clipping after EQ boosts.
    const comp2 = _audioCtx.createDynamicsCompressor();
    comp2.threshold.value = -4;  // dB — only catches peaks boosted by EQ
    comp2.knee.value      = 1;   // dB — hard knee
    comp2.ratio.value     = 20;  // 20:1 ≈ brick wall
    comp2.attack.value    = 0.001; // 1 ms
    comp2.release.value   = 0.05;  // 50 ms

    // ── Makeup Gain ──────────────────────────────────────────────────────
    // Recover the gain reduced by compression; final level ≈ -9 to -12 LUFS
    // which is loud and punchy (professional broadcast target).
    _outGain = _audioCtx.createGain();
    _outGain.gain.value = 1.5; // +3.5 dB makeup — tuned empirically

    // ── Wire the chain ───────────────────────────────────────────────────
    _srcNode.connect(hp);
    hp.connect(ls);
    ls.connect(b1);
    b1.connect(b2);
    b2.connect(b3);
    b3.connect(b4);
    b4.connect(b5);
    b5.connect(hs);
    hs.connect(comp1);
    comp1.connect(comp2);
    comp2.connect(_outGain);

    if (workletsOk) {
      // audio-processor: stereo widening (width=1.35) + saturation (drive=0.15) + -1dBFS limiter
      const proc = new AudioWorkletNode(_audioCtx, 'audio-processor', {
        processorOptions: { width: 1.35, drive: 0.15, limitDb: -1 },
      });
      proc.port.onmessage = ({ data }) => {
        if (!data || data.type !== 'meter') return;
        // Update GR meter in UI (if element exists)
        const gr = document.getElementById('audio-gr-bar');
        if (gr) gr.style.width = Math.round(data.gainReduction * 100) + '%';
      };
      _outGain.connect(proc);
      _chainTail = proc;
    } else {
      _chainTail = _outGain;
    }

    // Connect tail to destination (disconnected/reconnected in live mode)
    _chainTail.connect(_audioCtx.destination);
    _graphReady = true;

    console.log('[Audio] ✦ Broadcast processing chain active'
      + (workletsOk ? ' (stereo widener + limiter ✓)' : ' (EQ + compressor only)'));

    // Show the "Enhanced" indicator in UI
    const badge = document.getElementById('audio-enhanced-badge');
    if (badge) badge.style.display = 'inline-flex';

  } catch (e) {
    console.warn('[Audio] Processing chain setup failed — unprocessed output:', e.message);
    _graphReady   = false;
    _graphLoading = false;
  }
}

/** Insert the live-stream-processor between _chainTail and destination. */
function _connectLiveWorklet() {
  if (!_graphReady || _liveWorklet) return;
  try {
    _chainTail.disconnect(_audioCtx.destination);
    _liveWorklet = new AudioWorkletNode(_audioCtx, 'live-stream-processor');
    _liveWorklet.port.onmessage = ({ data }) => {
      if (!data) return;
      if (data.type === 'dropout-end') {
        console.debug(`[LiveAudio] network gap concealed: ${Math.round(data.durationMs)} ms`);
      } else if (data.type === 'stats') {
        const el = document.getElementById('live-rtt-display');
        if (el && _lwsRtt !== null) el.textContent = `${Math.round(_lwsRtt)} ms`;
      }
    };
    _chainTail.connect(_liveWorklet);
    _liveWorklet.connect(_audioCtx.destination);
  } catch (e) {
    console.warn('[Audio] Live worklet insert failed:', e.message);
    // Re-connect tail to destination so audio still plays
    try { _chainTail.connect(_audioCtx.destination); } catch (_) {}
  }
}

/** Remove the live-stream-processor and restore direct chain → destination path. */
function _disconnectLiveWorklet() {
  if (!_liveWorklet) return;
  try {
    _chainTail.disconnect();
    _liveWorklet.port.postMessage({ type: 'reset' });
    _liveWorklet.disconnect();
    _liveWorklet = null;
    _chainTail.connect(_audioCtx.destination);
  } catch (e) {
    _liveWorklet = null;
    try { _chainTail?.connect(_audioCtx.destination); } catch (_) {}
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// Binary WebSocket /live-ws — high-performance audio transport
// ─────────────────────────────────────────────────────────────────────────────

function _lwsUrl() {
  const proto = location.protocol === 'https:' ? 'wss' : 'ws';
  return `${proto}://${location.host}/live-ws`;
}

function _lwsMakePing() {
  const buf = new ArrayBuffer(1 + 8);
  const dv  = new DataView(buf);
  dv.setUint8(0, LWS_PING);
  const now = Date.now();
  dv.setUint32(1, Math.floor(now / 0x100000000) >>> 0, false);
  dv.setUint32(5, now >>> 0, false);
  return buf;
}

function _lwsConnect() {
  if (_lws && (_lws.readyState === WebSocket.OPEN || _lws.readyState === WebSocket.CONNECTING)) return;
  if (_lwsTimer) { clearTimeout(_lwsTimer); _lwsTimer = null; }
  try {
    _lws = new WebSocket(_lwsUrl());
    _lws.binaryType = 'arraybuffer';
  } catch (e) {
    console.warn('[LiveWS] Could not open binary WS:', e.message);
    return;
  }

  _lws.onopen = () => {
    console.log('[LiveWS] Binary WebSocket connected ✓');
    _lwsSeq = 0;
    _lwsPingLoop();
  };

  _lws.onmessage = ({ data }) => {
    if (!(data instanceof ArrayBuffer) || data.byteLength < 1) return;
    const dv   = new DataView(data);
    const type = dv.getUint8(0);

    if (type === LWS_HELLO) {
      try {
        const json = JSON.parse(new TextDecoder().decode(new Uint8Array(data, LWS_HDR)));
        if (json.mimeType) liveMimeType = json.mimeType;
      } catch (_) {}
      return;
    }
    if (type === LWS_PONG && data.byteLength >= 9) {
      const hi = dv.getUint32(1, false);
      const lo = dv.getUint32(5, false);
      _lwsRtt  = Date.now() - (hi * 0x100000000 + lo);
      const el = document.getElementById('live-rtt-display');
      if (el) el.textContent = `${Math.round(_lwsRtt)} ms`;
      return;
    }
    if (type === LWS_ENDED) {
      if (isLive) exitLiveMode();
      return;
    }
    // INIT or AUDIO chunk → MediaSource pipeline
    if ((type === LWS_INIT || type === LWS_AUDIO) && isLive && _liveUseMS) {
      if (data.byteLength > LWS_HDR) {
        const payload = data.slice(LWS_HDR);
        if (type === LWS_INIT) {
          _livePending.unshift(payload);
        } else {
          const seq = dv.getUint32(1, true);
          if (seq > _lwsSeq) { _lwsSeq = seq; _livePending.push(payload); }
        }
        _liveFlush();
      }
    }
  };

  _lws.onclose = (ev) => {
    console.log(`[LiveWS] Binary WS closed (${ev.code})`);
    _lws = null;
    if (isLive) _lwsTimer = setTimeout(_lwsConnect, 1000);
  };
  _lws.onerror = () => {};
}

function _lwsDisconnect() {
  if (_lwsPingInterval) { clearInterval(_lwsPingInterval); _lwsPingInterval = null; }
  if (_lwsTimer) { clearTimeout(_lwsTimer); _lwsTimer = null; }
  if (_lws) { try { _lws.close(1000); } catch (_) {} _lws = null; }
  _lwsSeq = 0;
}

let _lwsPingInterval = null;
function _lwsPingLoop() {
  if (_lwsPingInterval) clearInterval(_lwsPingInterval);
  _lwsPingInterval = setInterval(() => {
    if (!_lws || _lws.readyState !== WebSocket.OPEN) {
      clearInterval(_lwsPingInterval); _lwsPingInterval = null; return;
    }
    _lws.send(_lwsMakePing());
  }, 4000);
}

/**
 * Start live stream via MediaSource API.
 * Sets audio.src synchronously so the caller can call audio.play() immediately
 * within the user-gesture context (required by iOS Safari autoplay policy).
 * Falls back to HTTP reconnectAudio(LIVE_URL) if MediaSource is unsupported.
 */
function startLiveViaMS() {
  const mime = liveMimeType || 'audio/webm;codecs=opus';
  if (!window.MediaSource || !MediaSource.isTypeSupported(mime)) {
    // MediaSource unavailable or codec unsupported — use HTTP stream directly
    reconnectAudio(LIVE_URL);
    return;
  }

  cleanupLiveMS(); // clears _liveMS, _liveSB, _liveFailTO, _livePending

  // Capture in a local variable so the sourceopen callback can verify it is
  // still the current session.  If cleanupLiveMS() is called before sourceopen
  // fires (e.g. the user presses Stop or a reconnect cycle starts), the callback
  // checks `_liveMS !== ms` and exits cleanly instead of throwing on a null ref.
  const ms = new MediaSource();
  _liveMS = ms;

  // Revoke the OLD ObjectURL now that audio.src is about to change.
  if (_liveMSObjUrl) {
    try { URL.revokeObjectURL(_liveMSObjUrl); } catch(_) {}
  }
  _liveMSObjUrl = URL.createObjectURL(ms);

  // Watchdog: fall back to HTTP if sourceopen doesn't fire within 5 s.
  // Tracked in _liveFailTO so cleanupLiveMS() can cancel it if called first.
  _liveFailTO = setTimeout(() => {
    _liveFailTO = null;
    if (_liveMS !== ms) return; // already replaced by a newer session
    cleanupLiveMS();
    if (isLive) reconnectAudio(LIVE_URL);
  }, 5000);

  ms.addEventListener('sourceopen', () => {
    if (_liveFailTO) { clearTimeout(_liveFailTO); _liveFailTO = null; }
    // Stale-session guard: if cleanupLiveMS() replaced _liveMS before this
    // callback fired, the reference no longer matches — bail out silently.
    if (_liveMS !== ms) return;
    try {
      _liveSB      = ms.addSourceBuffer(mime);
      _liveSB.mode = 'sequence'; // browser handles timestamps automatically
      _liveSB.addEventListener('updateend', _liveFlush);
      _liveUseMS   = true;

      // Request WebM init chunk (EBML header) via Socket.IO (legacy path).
      // The binary WS server already delivers INIT on connect if live.
      socket.emit('live:request-init');

      // Connect live-stream-processor for dropout fade concealment
      _connectLiveWorklet();

      _liveFlush(); // drain any chunks buffered before sourceopen
    } catch(e) {
      if (_liveMS === ms) { cleanupLiveMS(); if (isLive) reconnectAudio(LIVE_URL); }
    }
  }, { once: true });

  // Set audio.src SYNCHRONOUSLY so the caller can call audio.play() within
  // the same user-gesture task (onclick handler) — required by iOS Safari.
  // Do NOT call audio.load() here: it restarts the resource-selection
  // algorithm and causes audio.play() to get an AbortError ("interrupted by
  // a call to load()"), which used to trigger a spurious scheduleLiveReconnect
  // loop.  Setting audio.src alone is sufficient to attach the MediaSource.
  audio.src = _liveMSObjUrl;
}

/**
 * Schedule a live-stream reconnect with the live-red "RECONNECTING" badge.
 * Unlike scheduleReconnect() there is no exponential back-off — live streams
 * recover as fast as possible.
 *
 * Resets the play-button state immediately so the UI never shows ⏸ while
 * audio is actually disconnected.
 */
function scheduleLiveReconnect(delayMs) {
  clearTimeout(reconnectTO);
  clearStallTimer();

  // Immediately reflect the disconnected state in the UI.
  // (The 'pause' event will also fire later but we want instant feedback.)
  isPlaying = false;
  const playIcon = document.getElementById('play-icon');
  const playBtn  = document.getElementById('play-btn');
  if (playIcon) playIcon.textContent = '▶';
  if (playBtn)  playBtn.classList.remove('playing');
  releaseWakeLock();
  if (vizRaf) { cancelAnimationFrame(vizRaf); vizRaf = null; }
  drawIdleVisualizer();

  const badge = document.getElementById('status-badge');
  const text  = document.getElementById('status-text');
  if (badge) badge.className = 'status-badge live-reconnecting';
  if (text)  text.textContent = 'RECONNECTING';

  reconnectTO = setTimeout(() => {
    reconnectTO = null;          // ← clear so keepalive / live:audio resume work
    if (!isLive) return;
    setJoiningBadge();
    // If the MediaSource pipeline is already set up and working, don't tear it
    // down — just nudge play().  Only fully restart when it isn't running yet.
    if (!_liveUseMS) {
      cleanupLiveMS();
      startLiveViaMS();
    }
    audio.play().catch(err => {
      if (err.name !== 'AbortError') scheduleLiveReconnect(2000);
    });
  }, delayMs);
}

// ── Live mode ─────────────────────────────────────────────────
function startLiveTimer() {
  stopLiveTimer();
  _liveStartedAt = _liveStartedAt || Date.now();
  function tick() {
    const elapsed = Date.now() - _liveStartedAt;
    const h  = Math.floor(elapsed / 3600000);
    const m  = Math.floor((elapsed % 3600000) / 60000);
    const s  = Math.floor((elapsed % 60000) / 1000);
    const ts = (h ? h + ':' : '') + String(m).padStart(h ? 2 : 1,'0') + ':' + String(s).padStart(2,'0');
    const el = document.getElementById('live-timer');
    if (el) el.textContent = '🔴 LIVE  ' + ts;
  }
  tick();
  _liveTimerInterval = setInterval(tick, 1000);
  const el = document.getElementById('live-timer');
  if (el) el.classList.add('visible');
  const rttWrap = document.getElementById('live-rtt-wrap');
  if (rttWrap) rttWrap.classList.add('visible');
}
function stopLiveTimer() {
  if (_liveTimerInterval) { clearInterval(_liveTimerInterval); _liveTimerInterval = null; }
  const el = document.getElementById('live-timer');
  if (el) { el.classList.remove('visible'); el.textContent = ''; }
  const rttWrap = document.getElementById('live-rtt-wrap');
  if (rttWrap) { rttWrap.classList.remove('visible'); }
  const rttEl = document.getElementById('live-rtt-display');
  if (rttEl) rttEl.textContent = '– ms';
  _lwsRtt = null;
  _liveStartedAt = null;
}

function switchToLiveMode(info) {
  // Propagate mimeType immediately so startLiveViaMS() uses the correct codec.
  // Without this, MP3 streams (from butt/Icecast) would attempt MediaSource with
  // the default 'audio/webm;codecs=opus' before the HELLO frame arrives.
  if (info && info.mimeType) liveMimeType = info.mimeType;

  document.getElementById('player-card').classList.add('live-mode');
  document.getElementById('play-btn').classList.add('live-mode');
  document.getElementById('player-shimmer').classList.add('live');
  document.getElementById('panel-shimmer').classList.add('live');
  const badge = document.getElementById('status-badge');
  badge.className = 'status-badge live';
  document.getElementById('status-text').textContent = 'LIVE';
  const heroStatus = document.getElementById('hero-status');
  if (heroStatus) heroStatus.textContent = 'LIVE';
  const heroDot = document.getElementById('hero-dot');
  if (heroDot) heroDot.style.background = '#e03060';
  if (info && (info.title || info.artist)) {
    updateTrackInfo(info.title || 'Live Broadcast', info.artist || 'LETW Radio');
  }
  startLiveTimer();

  // Only switch streams for listeners who are ALREADY playing.
  // Visitors who haven't pressed Play yet just get the UI update plus the
  // "Join Live" banner — they connect when they tap the banner or Play button.
  // Auto-connecting idle visitors creates real HTTP connections to /live-stream
  // that inflate the listener count with phantom entries.
  if (!isPlaying) {
    showLiveJoinBanner();
    return;
  }
  hideLiveJoinBanner();

  // Already playing live stream (either via MediaSource or HTTP) — nothing to do.
  if (!audio.paused && (_liveUseMS || (audio.src && audio.src.includes('/live-stream')))) return;

  clearTimeout(window._liveConnectTO);
  window._liveConnectTO = null;
  audio.pause();                // stop any currently-playing stream cleanly
  cleanupLiveMS();              // reset any previous MediaSource state
  setJoiningBadge();            // show "JOINING LIVE…" while connecting
  startLiveEdgeMonitor();       // begin buffer watch immediately
  startLiveJoinTimeout();       // retry if stream doesn't start within 10 s

  // ── Connect binary WebSocket (primary fast path) ──────────────
  _lwsConnect();

  // Audio graph is set up in startPlayback() or on first play gesture.
  // _connectLiveWorklet() is called inside startLiveViaMS sourceopen handler.

  startLiveViaMS();             // try MediaSource first; falls back to HTTP inside
  audio.play().catch(err => { if (err.name !== 'AbortError') scheduleLiveReconnect(800); });
  // Tell server this listener has joined live — used for live-listener count display in admin
  socket.emit('live:join');
}

function exitLiveMode() {
  document.getElementById('player-card').classList.remove('live-mode');
  document.getElementById('play-btn').classList.remove('live-mode');
  document.getElementById('player-shimmer').classList.remove('live');
  document.getElementById('panel-shimmer').classList.remove('live');
  hideLiveJoinBanner();
  stopLiveEdgeMonitor();
  clearLiveJoinTimeout();
  clearTimeout(reconnectTO); reconnectTO = null;
  clearStallTimer();
  // cleanupLiveMS clears the state; we also need to revoke the ObjectURL
  // and clear audio.src when leaving live mode permanently.
  cleanupLiveMS();
  if (_liveMSObjUrl) {
    try { URL.revokeObjectURL(_liveMSObjUrl); } catch(_) {}
    _liveMSObjUrl = null;
  }
  if (audio.src && audio.src.startsWith('blob:')) {
    audio.pause();
    audio.src = '';
  }
  stopLiveTimer();
  // Tell server this listener is no longer in live mode
  socket.emit('live:leave');
  // Disconnect binary WebSocket and live dropout-fade worklet
  _lwsDisconnect();
  _disconnectLiveWorklet();
  // Use setStatusBadge so hero-dot, hero-status, and progress bar are all
  // updated correctly.  Show ON AIR if already playing, OFFLINE if not.
  setStatusBadge(isPlaying);
  if (isPlaying) reconnectAudio(_activeStreamUrl);
}

function getStreamUrl() { return isLive ? LIVE_URL : STREAM_URL; }
// Note: getStreamUrl() is overridden at the bottom of the page to return
// _activeStreamUrl instead of the const STREAM_URL, keeping reconnects
// on the selected channel.  The const stays as the initial default.

// ── Audio ─────────────────────────────────────────────────────
const audio = document.getElementById('audio-element');
audio.volume = currentVolume;

audio.addEventListener('playing', () => {
  isPlaying = true;
  _wasEverPlaying = true;
  _streamErrorCount = 0;
  hideStreamErrorBanner();
  reconnectDelay = 2000;
  document.getElementById('play-icon').textContent = '⏸';
  document.getElementById('play-btn').classList.add('playing');
  if (isLive) {
    // Audio connected — cancel join timeout and set the LIVE badge.
    // setStatusBadge() returns early in live mode, so set directly.
    clearLiveJoinTimeout();
    const badge = document.getElementById('status-badge');
    const text  = document.getElementById('status-text');
    if (badge) badge.className = 'status-badge live';
    if (text)  text.textContent = 'LIVE';
  } else {
    setStatusBadge(true);
  }
  startVisualizerFromAudio();
  requestWakeLock();
  clearStallTimer();
});

audio.addEventListener('pause', () => {
  isPlaying = false;
  document.getElementById('play-icon').textContent = '▶';
  document.getElementById('play-btn').classList.remove('playing');
  setStatusBadge(false);
  releaseWakeLock();
  // Stop the visualizer animation when audio pauses
  if (vizRaf) { cancelAnimationFrame(vizRaf); vizRaf = null; }
  drawIdleVisualizer();
});

audio.addEventListener('waiting', () => {
  if (!isLive) {
    const badge = document.getElementById('status-badge');
    const text  = document.getElementById('status-text');
    // Show "Connecting" when the user just pressed Play and hasn't heard audio yet.
    // Show "Buffering" for a mid-play network hiccup.
    if (!_wasEverPlaying) {
      if (badge) badge.className = 'status-badge connecting';
      if (text)  text.textContent = 'CONNECTING…';
    } else {
      if (badge) badge.className = 'status-badge buffering';
      if (text)  text.textContent = 'BUFFERING…';
    }
    startStallTimer();
  } else {
    // Live mode: keep the live-tinted badge style so "JOINING LIVE…" or
    // "RECONNECTING" aren't overwritten by the yellow buffering state.
    // Only update the text if we're not already in a joining/reconnecting state.
    const badge = document.getElementById('status-badge');
    const text  = document.getElementById('status-text');
    const cls   = badge ? badge.className : '';
    if (!cls.includes('joining') && !cls.includes('live-reconnecting')) {
      if (badge) badge.className = 'status-badge joining';
      if (text)  text.textContent = _wasEverPlaying ? 'BUFFERING…' : 'CONNECTING…';
    }
    // 'waiting' fires naturally on the normal decoder-init gap between the
    // WebM header chunk and the first audio cluster.  Use a longer grace
    // period so we don't reconnect during normal initial buffering.
    startLiveStallTimer();
  }
});

// stalled = browser stopped fetching data even though more is expected.
// For MediaSource live streams this fires NORMALLY during the initial
// buffering gap between play() and the first appended chunk — it is NOT
// a sign of a network problem.  Once we append data the browser resumes
// automatically; a reconnect here would tear down the working pipeline.
// Only reconnect immediately for HTTP-based live streams (_liveMS == null).
audio.addEventListener('stalled', () => {
  if (isLive) {
    if (_liveMS) {
      // MediaSource pipeline is active (or being set up) — give it time.
      startLiveStallTimer(); // 8-second grace before deciding it's truly stuck
    } else {
      // HTTP fallback — stall means network dropped; reconnect quickly.
      scheduleLiveReconnect(800);
    }
  } else if (isPlaying) {
    scheduleReconnect();
  }
});

// ended = stream closed by the server (admin stopped OR network hiccup).
// If we're in live mode and the socket hasn't sent 'live:ended', treat it
// as a transient drop and reconnect after a 1-second grace period so the
// socket event has time to arrive and exitLiveMode() can run instead.
audio.addEventListener('ended', () => {
  if (isLive) {
    clearTimeout(reconnectTO);
    reconnectTO = setTimeout(() => {
      if (isLive) scheduleLiveReconnect(0); // still live → network hiccup
    }, 1000);
  } else if (isPlaying) {
    scheduleReconnect();
  }
});

audio.addEventListener('error', () => {
  _streamErrorCount++;
  if (isLive) {
    scheduleLiveReconnect(800);
  } else {
    const badge = document.getElementById('status-badge');
    const text  = document.getElementById('status-text');
    if (badge) badge.className = 'status-badge error';
    if (text)  text.textContent = 'ERROR';
    isPlaying = false;
    document.getElementById('play-icon').textContent = '▶';
    document.getElementById('play-btn').classList.remove('playing');
    // After 2 consecutive errors show the manual retry banner
    if (_streamErrorCount >= 2) showStreamErrorBanner();
    else scheduleReconnect();
  }
});

function showStreamErrorBanner() {
  const el = document.getElementById('stream-error-banner');
  if (el) el.classList.add('visible');
}
function hideStreamErrorBanner() {
  const el = document.getElementById('stream-error-banner');
  if (el) el.classList.remove('visible');
}
function retryStream() {
  _streamErrorCount = 0;
  hideStreamErrorBanner();
  startPlayback();
}

function setStatusBadge(playing) {
  if (isLive) return;
  const badge      = document.getElementById('status-badge');
  const text       = document.getElementById('status-text');
  const heroStatus = document.getElementById('hero-status');
  const heroDot    = document.getElementById('hero-dot');
  const progress   = document.getElementById('now-playing-progress');
  badge.className = playing ? 'status-badge on-air' : 'status-badge offline';
  text.textContent = playing ? 'ON AIR' : 'OFFLINE';
  if (heroStatus) heroStatus.textContent = playing ? 'ON AIR' : 'OFFLINE';
  if (heroDot) heroDot.style.background = playing ? 'var(--gold)' : 'rgba(180,160,120,0.3)';
  if (progress) progress.classList.toggle('active', playing);
  setVinylPlaying(playing);
}

function togglePlay() {
  if (isPlaying) stopPlayback(); else startPlayback();
}

function startPlayback() {
  // ── Broadcast-grade audio processing chain ────────────────────────────────
  // Set up once on the first user gesture (required by browser autoplay policy).
  // Routes all audio through 8-band EQ → 2-stage compressor → stereo widener
  // → true-peak limiter.  Safe to call if already set up (_graphLoading guard).
  _setupAudioGraph(); // async; fires in background — no await needed here

  // Visualiser AudioContext (separate from processing chain;
  // uses captureStream() NOT createMediaElementSource — see comment in initViz)
  if (!audioCtx && (window.AudioContext || window.webkitAudioContext)) {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  }
  if (audioCtx && audioCtx.state === 'suspended') {
    audioCtx.resume().catch(() => {});
  }

  if (isLive) {
    hideLiveJoinBanner();
    setJoiningBadge();
    // Optimistic UI: show ⏸ immediately so the user gets instant feedback that
    // their tap registered.  Real playback state will sync when audio fires
    // 'playing' (or we revert in scheduleLiveReconnect on genuine failure).
    isPlaying = true;
    const _spPlayIcon = document.getElementById('play-icon');
    const _spPlayBtn  = document.getElementById('play-btn');
    if (_spPlayIcon) _spPlayIcon.textContent = '⏸';
    if (_spPlayBtn)  _spPlayBtn.classList.add('playing');
    requestWakeLock();
    startLiveEdgeMonitor();
    startLiveJoinTimeout();
    // Connect binary WebSocket (primary fast path for audio delivery)
    _lwsConnect();
    // startLiveViaMS() sets audio.src synchronously; play() is called here
    // inside the onclick user-gesture context — required by iOS Safari.
    startLiveViaMS();
    audio.play().catch(err => {
      // AbortError fires when the browser itself interrupted the play() call
      // (e.g. while the MediaSource is still opening).  The 'sourceopen'
      // handler / live:audio flush will resume playback as soon as data
      // arrives — no reconnect needed.
      if (err.name === 'AbortError') return;
      scheduleLiveReconnect(1500);
    });
    // Tell server this listener has joined live
    socket.emit('live:join');
    return;
  }

  // Regular stream — use selected channel (overridden by switchChannel)
  reconnectAudio(_activeStreamUrl);
}

function stopPlayback() {
  audio.pause();
  audio.src = '';
  isPlaying = false;
  _wasEverPlaying = false;  // reset so next Play shows "Connecting" not "Buffering"
  _streamErrorCount = 0;
  hideStreamErrorBanner();
  // Cancel any pending reconnect so the user's stop action is respected
  clearTimeout(reconnectTO);
  reconnectTO = null;
  reconnectDelay = 2000; // reset backoff for next play session
  document.getElementById('play-icon').textContent = '▶';
  document.getElementById('play-btn').classList.remove('playing');
  // Clear sermon mode UI if active
  if (_sermonActive) {
    _sermonActive    = false;
    _currentSermonId = null;
    document.getElementById('sermon-seek-wrap').classList.remove('visible');
    const backBtn = document.getElementById('sermon-back-btn');
    if (backBtn) backBtn.classList.remove('visible');
    filterSermons((document.getElementById('sermon-search') || {}).value || '');
  }
  setStatusBadge(false);
  cancelSleepTimer();
  releaseWakeLock();
  clearStallTimer();
}

// Append a cache-buster so each (re)connect opens a BRAND-NEW TCP socket.
// Without this, mobile browsers frequently reuse a half-open / dead keep-alive
// connection after a network change (Wi-Fi↔cellular) or after the tab was
// backgrounded — so audio.play() resumes a stale buffer and immediately stalls
// again, making the "reconnect" silently fail.  A fresh query string guarantees
// the browser performs a real new GET to /stream.
function _bust(url) {
  if (!url || url.startsWith('blob:')) return url;   // MediaSource object URLs
  return url + (url.includes('?') ? '&' : '?') + '_=' + Date.now();
}

function reconnectAudio(url) {
  clearTimeout(reconnectTO);
  reconnectTO = null;
  clearStallTimer();
  const was = isPlaying;
  audio.pause();
  // Always tear down and re-open with a fresh URL.  The previous "skip reload if
  // already loaded" optimisation broke reconnect-after-drop: a dead stream can
  // still report readyState >= 2 from its leftover buffer, so we'd replay stale
  // audio and stall instead of actually reconnecting.
  audio.src = _bust(url);
  audio.load();
  audio.play().catch(() => {
    if (isLive) scheduleLiveReconnect(1000);
    else if (was) scheduleReconnect();
  });
}

function scheduleReconnect() {
  // For live streams use the fast live-reconnect path, not exponential back-off
  if (isLive) { scheduleLiveReconnect(800); return; }

  clearTimeout(reconnectTO);
  clearStallTimer();
  const badge = document.getElementById('status-badge');
  const text  = document.getElementById('status-text');
  const heroStatus = document.getElementById('hero-status');
  badge.className = 'status-badge reconnecting';
  text.textContent = 'RECONNECTING';
  if (heroStatus) heroStatus.textContent = 'RECONNECTING';
  reconnectTO = setTimeout(() => {
    if (isLive) { scheduleLiveReconnect(0); return; } // live mode started mid-backoff
    reconnectDelay = Math.min(reconnectDelay * 2, MAX_RECONNECT_DELAY);
    if (isPlaying) {
      audio.src = _bust(getStreamUrl());
      audio.load();
      audio.play().catch(() => scheduleReconnect());
    }
  }, reconnectDelay);
}

// ── Live-edge buffer manager ──────────────────────────────────
// A live HTTP stream accumulates a growing audio buffer in the browser.
// Without intervention, a listener who joined 10 seconds ago is 10 seconds
// behind the live edge — they hear the admin's words long after they were
// spoken.
//
// Every second we check how far ahead the audio buffer extends beyond the
// current playback position:
//   • > 2.5 s ahead → speed up slightly (≤ 6%) so the player catches up
//   • < 0.6 s ahead → slow down to 99% to prevent stutter
//   • 0.6 – 2.5 s  → normal 1× speed
//
// playbackRate changes are nearly imperceptible for speech (±6% pitch
// shift at most) and invisible for music in this range.  preservesPitch
// is set where supported so browsers apply pitch-correction automatically.
function startLiveEdgeMonitor() {
  stopLiveEdgeMonitor();
  // Opt-in to pitch-preserving rate changes where the browser supports it
  try { audio.preservesPitch = true; audio.mozPreservesPitch = true; } catch(_) {}

  _liveEdgeTimer = setInterval(() => {
    if (!isLive || audio.paused || !audio.buffered || !audio.buffered.length) return;
    try {
      const bufEnd = audio.buffered.end(audio.buffered.length - 1);
      const ahead  = bufEnd - audio.currentTime;

      if (ahead > 2.5) {
        // We are >2.5 s behind the live edge — hard-snap to 0.5 s behind edge
        audio.currentTime = Math.max(audio.currentTime, bufEnd - 0.5);
        audio.playbackRate = 1.0;
      } else if (ahead > 1.0) {
        // Moderately behind — speed up gradually (max +8%)
        audio.playbackRate = Math.min(1.08, 1 + (ahead - 0.8) * 0.05);
      } else if (ahead < 0.3 && !audio.paused) {
        // Buffer running thin — slow down slightly to avoid stutter
        audio.playbackRate = 0.97;
      } else {
        audio.playbackRate = 1.0;
      }

      // Update the live delay indicator
      const delayEl = document.getElementById('live-delay-label');
      if (delayEl) {
        delayEl.style.display = 'block';
        delayEl.textContent   = ahead < 0.5 ? 'live edge' : `~${Math.round(ahead)}s delay`;
      }
    } catch(_) {}
  }, 500); // check twice per second for tighter latency control
}

function stopLiveEdgeMonitor() {
  if (_liveEdgeTimer) { clearInterval(_liveEdgeTimer); _liveEdgeTimer = null; }
  try { audio.playbackRate = 1.0; } catch(_) {}
  const delayEl = document.getElementById('live-delay-label');
  if (delayEl) { delayEl.style.display = 'none'; delayEl.textContent = ''; }
}

// ── Live join timeout ─────────────────────────────────────────
// If the live stream hasn't fired 'playing' within 10 s of the user tapping
// "Join Live" / Play, the connection may be hanging.  Automatically retry once
// and show a feedback badge so the user knows what's happening.
function startLiveJoinTimeout() {
  clearLiveJoinTimeout();
  _liveJoinTO = setTimeout(() => {
    if (isLive && !isPlaying) {
      const badge = document.getElementById('status-badge');
      const text  = document.getElementById('status-text');
      if (badge) badge.className = 'status-badge live-reconnecting';
      if (text)  text.textContent = 'RETRYING…';
      scheduleLiveReconnect(500);
    }
  }, 10000);
}
function clearLiveJoinTimeout() {
  if (_liveJoinTO) { clearTimeout(_liveJoinTO); _liveJoinTO = null; }
}

// ── Join-live banner ──────────────────────────────────────────
function showLiveJoinBanner() {
  const el = document.getElementById('live-join-banner');
  if (el) el.style.display = 'block';
}
function hideLiveJoinBanner() {
  const el = document.getElementById('live-join-banner');
  if (el) el.style.display = 'none';
}
function setJoiningBadge() {
  const badge = document.getElementById('status-badge');
  const text  = document.getElementById('status-text');
  if (badge) badge.className = 'status-badge joining';
  if (text)  text.textContent = 'JOINING LIVE…';
}

function startStallTimer() {
  clearStallTimer();
  stallTimer = setTimeout(() => {
    // Only reconnect if the stall is genuine — readyState < 3 (HAVE_FUTURE_DATA)
    // means the browser truly doesn't have enough data to continue playing.
    // If readyState recovered to 3 or 4 while the timer was pending, the stall
    // resolved itself and we must NOT tear down a working stream.
    if (isPlaying && !isLive && audio.readyState < 3) {
      audio.src = _bust(getStreamUrl());
      audio.load();
      audio.play().catch(() => scheduleReconnect());
    }
  }, 4000);
}

// Live-stream stall watchdog — 5 s grace period.
// The normal decoder-init gap between the WebM header and the first audio
// cluster is ~100–300 ms.  5 s catches genuine network stalls faster than the
// previous 8 s while still being well above the normal buffering gap.
// The MediaSource race conditions that used to cause false positives here have
// been fixed (stale-session guard in startLiveViaMS), so 5 s is safe.
function startLiveStallTimer() {
  clearStallTimer();
  stallTimer = setTimeout(() => {
    if (isLive) scheduleLiveReconnect(0);
  }, 5000);
}

function clearStallTimer() {
  if (stallTimer) { clearTimeout(stallTimer); stallTimer = null; }
}

// Verify audio is genuinely progressing and reconnect if it died silently.
// Mobile browsers frequently kill the stream socket while the tab is backgrounded
// (and throttle our keepalive interval) WITHOUT firing 'error'/'ended', so on
// return-to-foreground or network-recovery the player thinks it's playing while
// the audio clock is frozen.  This catches that zombie state.
function _verifyPlaybackHealth() {
  if (!isPlaying || reconnectTO) return;  // not playing, or a reconnect already pending
  if (audio.paused) {                     // obviously dead
    if (isLive) scheduleLiveReconnect(300);
    else        reconnectAudio(_activeStreamUrl);
    return;
  }
  // Not paused — confirm the playback position actually advances.
  const t0 = audio.currentTime;
  setTimeout(() => {
    if (!isPlaying || reconnectTO) return;
    if (!audio.paused && audio.currentTime === t0) {
      // Position frozen while "playing" → silent stream death.
      if (isLive) scheduleLiveReconnect(300);
      else        reconnectAudio(_activeStreamUrl);
    }
  }, 1500);
}

// ── Network change recovery ───────────────────────────────────
// Reconnect the moment connectivity returns (e.g. phone leaves a dead zone or
// switches Wi-Fi↔cellular).  Without this the listener waits for the slow
// exponential-backoff timer (up to 20 s) before audio resumes.
window.addEventListener('online', () => {
  setSignal('Connected');
  if (isPlaying) {
    if (isLive) scheduleLiveReconnect(300);
    else        reconnectAudio(_activeStreamUrl);
  }
  // Nudge Socket.IO to reconnect now instead of waiting for its own backoff.
  if (socket && socket.disconnected) { try { socket.connect(); } catch(_) {} }
});
window.addEventListener('offline', () => {
  setSignal('Disconnected');
});

// Keepalive: every 10 s, check for the zombie state where the player is
// logically on but the audio element is silently paused.
// This catches autoplay-policy kills and silent network drops with no error event.
// For live mode we only trigger if BOTH isLive AND isPlaying — if the user
// hasn't pressed Play yet (e.g. they're on the Join Live banner) we must NOT
// reconnect because we'd be starting playback without a user gesture.
setInterval(() => {
  if (audio.paused && !reconnectTO) {
    if (isLive && isPlaying) {
      console.warn('[Keepalive] Live audio paused silently — reconnecting');
      scheduleLiveReconnect(500);
    } else if (isPlaying && !isLive) {
      console.warn('[Keepalive] Audio paused while active — reconnecting');
      scheduleReconnect();
    }
  }
}, 10000);

// ── Volume ────────────────────────────────────────────────────
const volSlider = document.getElementById('vol-slider');
volSlider.value = currentVolume;

volSlider.addEventListener('input', () => {
  currentVolume = parseFloat(volSlider.value);
  audio.volume  = isMuted ? 0 : currentVolume;
  localStorage.setItem('letw_volume', currentVolume);
  updateVolIcon();
});

function toggleMute() {
  isMuted = !isMuted;
  audio.volume = isMuted ? 0 : currentVolume;
  updateVolIcon();
}

function updateVolIcon() {
  const icon = document.getElementById('vol-icon');
  if (isMuted || currentVolume === 0) icon.textContent = '🔇';
  else if (currentVolume < 0.4)       icon.textContent = '🔈';
  else if (currentVolume < 0.75)      icon.textContent = '🔉';
  else                                icon.textContent = '🔊';
}

// ── Web Audio Visualizer ──────────────────────────────────────
const canvas = document.getElementById('visualizer');
const ctx2d  = canvas.getContext('2d');

function startVisualizerFromAudio() {
  if (vizRaf) cancelAnimationFrame(vizRaf);

  // ── Why captureStream() and NOT createMediaElementSource() ────────────────
  // createMediaElementSource() permanently hijacks the <audio> element: from
  // that moment the audio goes EXCLUSIVELY through the Web Audio graph and
  // ONLY reaches speakers via audioCtx.destination.  If the AudioContext is
  // suspended for ANY reason (browser policy, background tab, first load before
  // user gesture, etc.) the destination is blocked and listeners hear SILENCE —
  // even though the audio element shows "playing".
  //
  // captureStream() returns a read-only MediaStream copy of the element's output.
  // The element CONTINUES to play directly through the system audio unchanged.
  // We pipe the captured stream into an AnalyserNode just for the visualiser.
  // Audio is NEVER at risk of being silenced by the Web Audio context state.

  try {
    const captured = typeof audio.captureStream     === 'function' ? audio.captureStream()
                   : typeof audio.mozCaptureStream  === 'function' ? audio.mozCaptureStream()
                   : null;

    if (!captured) {
      // captureStream not supported (e.g. Safari/iOS) — animate without real data
      drawFakeVisualizer();
      return;
    }

    if (!audioCtx) {
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    }
    if (audioCtx.state === 'suspended') audioCtx.resume().catch(() => {});

    // Reconnect analyserSource each time — the underlying MediaStream changes
    // every time audio.src is reassigned (stream switch, reconnect, etc.)
    if (analyserSource) { try { analyserSource.disconnect(); } catch (_) {} }
    analyserSource = audioCtx.createMediaStreamSource(captured);

    if (!analyser) {
      analyser         = audioCtx.createAnalyser();
      analyser.fftSize = 128;
    }

    // Tap-only: analyserSource → analyser (read data for bars)
    // analyser is intentionally NOT connected to audioCtx.destination —
    // doing so would mix a second copy of the audio into the speakers.
    analyserSource.connect(analyser);

    drawAnalyserBars();
  } catch(e) {
    drawFakeVisualizer();
  }
}

function drawAnalyserBars() {
  if (!analyser) return;
  const bufLen = analyser.frequencyBinCount;
  const data   = new Uint8Array(bufLen);

  function frame() {
    vizRaf = requestAnimationFrame(frame);
    analyser.getByteFrequencyData(data);
    const W = canvas.offsetWidth  || canvas.width;
    const H = canvas.offsetHeight || canvas.height;
    canvas.width  = W;
    canvas.height = H;
    ctx2d.clearRect(0, 0, W, H);

    const barCount = Math.min(bufLen, 48);
    const totalGap = barCount - 1;
    const barW     = Math.max(2, (W - totalGap * 2) / barCount);
    const radius   = Math.min(barW / 2, 3);

    for (let i = 0; i < barCount; i++) {
      const v    = data[Math.floor(i * bufLen / barCount)] / 255;
      const barH = Math.max(2, v * (H * 0.82));
      const x    = i * (barW + 2);
      const y    = H - barH;

      // Gradient colour per bar position
      let hue;
      if (isLive) { hue = 340; }
      else if (i < barCount * 0.25) { hue = 350; }
      else if (i < barCount * 0.6)  { hue = 42;  }
      else                           { hue = 270; }

      const grd = ctx2d.createLinearGradient(x, y, x, H);
      grd.addColorStop(0,   `hsla(${hue},80%,70%,0.9)`);
      grd.addColorStop(0.5, `hsla(${hue},70%,55%,0.7)`);
      grd.addColorStop(1,   `hsla(${hue},60%,35%,0.25)`);

      ctx2d.fillStyle = grd;
      // Rounded top bar
      ctx2d.beginPath();
      if (barH > radius * 2) {
        ctx2d.moveTo(x, y + radius);
        ctx2d.arcTo(x, y, x + barW, y, radius);
        ctx2d.arcTo(x + barW, y, x + barW, y + barH, radius);
        ctx2d.lineTo(x + barW, H);
        ctx2d.lineTo(x, H);
        ctx2d.closePath();
      } else {
        ctx2d.rect(x, y, barW, barH);
      }
      ctx2d.fill();

      // Subtle reflection
      ctx2d.fillStyle = `hsla(${hue},70%,55%,0.12)`;
      ctx2d.fillRect(x, H, barW, Math.min(barH * 0.3, 8));
    }
  }
  frame();
}

function drawIdleVisualizer() {
  if (vizRaf) cancelAnimationFrame(vizRaf);
  vizRaf = null;
  const W = canvas.offsetWidth || 360;
  const H = canvas.offsetHeight || 48;
  ctx2d.clearRect(0, 0, W, H);
  const n = 32;
  const bw = (W / n) * 0.75;
  const gap = (W / n) * 0.25;
  for (let i = 0; i < n; i++) {
    const h = 3 + Math.abs(Math.sin(i * 0.6)) * 5;
    ctx2d.fillStyle = 'rgba(212,168,67,0.10)';
    ctx2d.beginPath();
    if (ctx2d.roundRect) {
      ctx2d.roundRect(i * (bw + gap), H - h, bw, h, [1, 1, 0, 0]);
    } else {
      ctx2d.rect(i * (bw + gap), H - h, bw, h);
    }
    ctx2d.fill();
  }
}

// Animated "active" visualizer for when captureStream() is unavailable (Safari/iOS).
// Produces a sine-wave-driven bar animation that looks alive without real audio data.
function drawFakeVisualizer() {
  if (vizRaf) cancelAnimationFrame(vizRaf);
  let phase = 0;
  function frame() {
    vizRaf = requestAnimationFrame(frame);
    phase += 0.06;
    const W = canvas.offsetWidth  || canvas.width;
    const H = canvas.offsetHeight || canvas.height;
    canvas.width  = W;
    canvas.height = H;
    ctx2d.clearRect(0, 0, W, H);
    const barCount = 32;
    const barW     = Math.max(2, (W - (barCount - 1) * 2) / barCount);
    const radius   = Math.min(barW / 2, 3);
    for (let i = 0; i < barCount; i++) {
      const v    = 0.15 + 0.85 * Math.abs(
                     Math.sin(phase * 2.7 + i * 0.55) *
                     Math.cos(phase * 1.8 + i * 0.38)
                   );
      const barH = Math.max(2, v * H * 0.82);
      const x    = i * (barW + 2);
      const y    = H - barH;
      const hue  = isLive ? 340 : (i < barCount * 0.25 ? 350 : i < barCount * 0.6 ? 42 : 270);
      const grd  = ctx2d.createLinearGradient(x, y, x, H);
      grd.addColorStop(0,   `hsla(${hue},80%,70%,0.9)`);
      grd.addColorStop(0.5, `hsla(${hue},70%,55%,0.7)`);
      grd.addColorStop(1,   `hsla(${hue},60%,35%,0.25)`);
      ctx2d.fillStyle = grd;
      ctx2d.beginPath();
      if (ctx2d.roundRect) ctx2d.roundRect(x, y, barW, barH, [radius, radius, 0, 0]);
      else                  ctx2d.rect(x, y, barW, barH);
      ctx2d.fill();
    }
  }
  frame();
}

// ── Sleep Timer ───────────────────────────────────────────────
function toggleSleepMenu() {
  document.getElementById('sleep-menu').classList.toggle('open');
}

function setSleepTimer(minutes) {
  cancelSleepTimer();
  document.getElementById('sleep-menu').classList.remove('open');
  sleepEndTime = Date.now() + minutes * 60 * 1000;
  const totalMs = minutes * 60 * 1000;

  // Initialise ring
  const ring = document.getElementById('sleep-ring');
  const circumference = 2 * Math.PI * 16;
  if (ring) {
    ring.style.strokeDasharray  = circumference;
    ring.style.strokeDashoffset = 0;
  }

  sleepTick = setInterval(() => {
    const remaining = sleepEndTime - Date.now();
    if (remaining <= 0) {
      cancelSleepTimer();
      const fadeInterval = setInterval(() => {
        if (audio.volume > 0.04) {
          audio.volume = Math.max(0, audio.volume - 0.04);
        } else {
          clearInterval(fadeInterval);
          stopPlayback();
        }
      }, 200);
      return;
    }
    const m = Math.floor(remaining / 60000);
    const s = Math.floor((remaining % 60000) / 1000);
    document.getElementById('sleep-icon').textContent =
      m + ':' + (s < 10 ? '0' : '') + s;
    // Update ring progress
    const ringEl = document.getElementById('sleep-ring');
    if (ringEl) {
      const progress = remaining / totalMs;
      ringEl.style.strokeDashoffset = circumference * (1 - progress);
    }
  }, 1000);

  document.getElementById('sleep-btn').classList.add('active');
}

function cancelSleepTimer() {
  if (sleepTick) { clearInterval(sleepTick); sleepTick = null; }
  sleepEndTime = null;
  document.getElementById('sleep-icon').textContent = '💤';
  document.getElementById('sleep-btn').classList.remove('active');
  const ring = document.getElementById('sleep-ring');
  if (ring) { ring.style.strokeDashoffset = 2 * Math.PI * 16; }
}

// ── Favourites ────────────────────────────────────────────────
function loadFavourites() {
  try { return JSON.parse(localStorage.getItem('letw_favourites') || '[]'); } catch(e) { return []; }
}

function saveFavourites(favs) {
  localStorage.setItem('letw_favourites', JSON.stringify(favs));
}

function isFavourite(title, artist) {
  return loadFavourites().some(f => f.title === title && f.artist === artist);
}

function toggleFavourite() {
  const title  = document.getElementById('track-title').textContent;
  const artist = document.getElementById('track-artist').textContent;
  if (!title || title === 'LETW Radio') return;
  let favs = loadFavourites();
  if (isFavourite(title, artist)) {
    favs = favs.filter(f => !(f.title === title && f.artist === artist));
  } else {
    favs.unshift({ title, artist, savedAt: Date.now() });
    if (favs.length > 50) favs = favs.slice(0, 50);
  }
  saveFavourites(favs);
  updateFavBtn(title, artist);
}

function updateFavBtn(title, artist) {
  const btn = document.getElementById('fav-btn');
  if (!btn) return;
  const active = isFavourite(title, artist);
  btn.textContent = active ? '❤️' : '🤍';
  btn.classList.toggle('active', active);
}

