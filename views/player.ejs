}

// ── Share / Copy Link ─────────────────────────────────────────
function copyListenLink() {
  const url = window.location.origin + '/listen';
  navigator.clipboard.writeText(url).then(() => {
    const btns = document.querySelectorAll('.link-btn');
    btns.forEach(b => { if (b.textContent.includes('Share')) { const orig = b.textContent; b.textContent = '✓ Copied!'; setTimeout(() => { b.textContent = orig; }, 2000); } });
  }).catch(() => {
    if (navigator.share) navigator.share({ title: 'LETW Radio', url }).catch(() => {});
  });
}

function shareStation() {
  // Open the share drawer
  const url   = window.location.origin + '/listen';
  const track = document.getElementById('track-title').textContent;
  const nowPlayingEl = document.getElementById('share-now-playing');
  if (nowPlayingEl) {
    nowPlayingEl.textContent = (track && track !== 'LETW Radio')
      ? 'Now playing: ' + track
      : 'Live Gospel & Christian radio';
  }
  const backdrop = document.getElementById('share-drawer-backdrop');
  const drawer   = document.getElementById('share-drawer');
  if (!backdrop || !drawer) {
    // Fallback if drawer HTML isn't present
    if (navigator.share) navigator.share({ title: 'LETW Radio', url }).catch(() => {});
    else navigator.clipboard.writeText(url).catch(() => {});
    return;
  }
  backdrop.style.display = 'block';
  drawer.style.display   = 'block';
  requestAnimationFrame(() => {
    backdrop.style.opacity  = '1';
    drawer.style.transform  = 'translateY(0)';
  });
}

function closeShareDrawer() {
  const backdrop = document.getElementById('share-drawer-backdrop');
  const drawer   = document.getElementById('share-drawer');
  if (!drawer) return;
  drawer.style.transform  = 'translateY(100%)';
  backdrop.style.opacity  = '0';
  setTimeout(() => {
    drawer.style.display   = 'none';
    backdrop.style.display = 'none';
  }, 350);
}

function shareVia(platform) {
  const url  = encodeURIComponent(window.location.origin + '/listen');
  const raw  = window.location.origin + '/listen';
  const track = document.getElementById('track-title').textContent;
  const msg  = encodeURIComponent(
    '🎙 ' + (track && track !== 'LETW Radio' ? 'Listening to ' + track + ' on ' : '') +
    'LETW Radio — Tune in live: ' + raw
  );
  let target = '';
  if (platform === 'youtube') target = window.__S.social_youtube || 'https://www.youtube.com';
  if (platform === 'copy') {
    navigator.clipboard.writeText(raw).then(() => {
      const btn = document.getElementById('share-copy-btn');
      if (btn) { const orig = btn.innerHTML; btn.innerHTML = '<span style="font-size:20px;">✅</span> Copied!'; setTimeout(() => { btn.innerHTML = orig; }, 2200); }
    }).catch(() => {});
    return;
  }
  if (target) window.open(target, '_blank', 'noopener,noreferrer,width=600,height=500');
  closeShareDrawer();
}

// ── Push Notifications ────────────────────────────────────────
async function initPush() {
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
  try {
    const res  = await fetch('/api/push/vapid-public');
    const data = await res.json();
    vapidPublicKey = data.publicKey || '';
    if (!vapidPublicKey) return;
    const reg      = await navigator.serviceWorker.ready;
    const existing = await reg.pushManager.getSubscription();
    if (existing) {
      pushSub     = existing;
      pushEnabled = true;
      updatePushBtn();
    }
  } catch(e) {}
}

async function togglePush() {
  if (!vapidPublicKey) { alert('Push notifications are not configured yet.'); return; }
  if (pushEnabled) await unsubscribePush();
  else             await subscribePush();
}

async function subscribePush() {
  try {
    const perm = await Notification.requestPermission();
    if (perm !== 'granted') return;
    const reg = await navigator.serviceWorker.ready;
    const sub = await reg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: urlB64ToUint8(vapidPublicKey),
    });
    pushSub = sub;
    const p256dh = sub.getKey('p256dh');
    const auth   = sub.getKey('auth');
    await fetch('/api/push/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        endpoint: sub.endpoint,
        p256dh: btoa(String.fromCharCode(...new Uint8Array(p256dh))),
        auth:   btoa(String.fromCharCode(...new Uint8Array(auth))),
      }),
    });
    pushEnabled = true;
    updatePushBtn();
  } catch(e) {}
}

async function unsubscribePush() {
  try {
    if (pushSub) {
      await fetch('/api/push/subscribe', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ endpoint: pushSub.endpoint }),
      });
      await pushSub.unsubscribe();
      pushSub = null;
    }
    pushEnabled = false;
    updatePushBtn();
  } catch(e) {}
}

function updatePushBtn() {
  const btn = document.getElementById('push-btn');
  btn.textContent = pushEnabled ? '🔕' : '🔔';
  btn.classList.toggle('active', pushEnabled);
}

function urlB64ToUint8(b64) {
  const pad = '='.repeat((4 - b64.length % 4) % 4);
  const raw = window.atob((b64 + pad).replace(/-/g, '+').replace(/_/g, '/'));
  const arr = new Uint8Array(raw.length);
  for (let i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
  return arr;
}

