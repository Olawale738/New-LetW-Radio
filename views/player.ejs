// ── Chat ──────────────────────────────────────────────────────
async function loadChatHistory() {
  try {
    const res  = await fetch('/api/chat');
    const msgs = await res.json();
    const list = document.getElementById('chat-messages');
    list.innerHTML = '<div class="chat-msg system"><div class="chat-text">Welcome to LETW Radio! 🙏</div></div>';
    msgs.forEach(m => appendChatMessage(m, false));
    list.scrollTop = list.scrollHeight;
  } catch(e) {}
}

function appendChatMessage(msg, scroll) {
  const list = document.getElementById('chat-messages');
  const el   = document.createElement('div');
  el.className  = 'chat-msg';
  el.dataset.msgId = msg.id || '';

  if (msg.type === 'system') {
    el.classList.add('system');
    el.innerHTML = '<div class="chat-text">' + esc(msg.message) + '</div>';
  } else {
    const rawColor = msg.color || userColor(msg.username || '');
    // Validate: accept only #rrggbb / #rgb hex — never inject raw strings into style
    const color = /^#[0-9a-fA-F]{3,6}$/.test(rawColor) ? rawColor : '#d4a843';
    const d     = msg.created_at ? new Date(msg.created_at) : new Date();
    const time  = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    el.innerHTML =
      '<div class="chat-msg-header">' +
        '<span class="chat-user-dot"></span>' +
        '<span class="chat-username">' + esc(msg.username) + '</span>' +
        '<span class="chat-time">' + time + '</span>' +
      '</div>' +
      '<div class="chat-text">' + esc(msg.message) + '</div>';
    // Apply colour via DOM property — never via inline style string injection
    const dot  = el.querySelector('.chat-user-dot');
    const name = el.querySelector('.chat-username');
    if (dot)  dot.style.background = color;
    if (name) name.style.color     = color;
  }

  list.appendChild(el);
  if (scroll !== false) list.scrollTop = list.scrollHeight;
}

async function sendChat() {
  const input   = document.getElementById('chat-input');
  const message = input.value.trim();
  if (!message) return;
  const username = getUsername();
  const color    = userColor(username);
  input.value    = '';
  try {
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, message, color }),
    });
    if (res.status === 403) {
      const data = await res.json().catch(() => ({}));
      input.value = message;
      showFlashAlert(data.message || 'You have been banned from the community.', '#e03060');
      // Lock the chat input to make the ban visible
      input.disabled = true;
      input.placeholder = 'You are banned from this chat.';
      const sendBtn = document.querySelector('.send-btn');
      if (sendBtn) sendBtn.disabled = true;
    }
  } catch(e) {
    input.value = message;
  }
}

