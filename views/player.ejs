  if (badge) { badge.textContent = ''; badge.classList.remove('visible'); }
  currentTrackId = null;
  likeDebounce   = false;
}

// ── Crossfade volume animation ────────────────────────────────
function fadeTo(targetVol, durationMs) {
  if (crossfadeRAF) { cancelAnimationFrame(crossfadeRAF); crossfadeRAF = null; }
  if (durationMs <= 0) { if (!isMuted) audio.volume = Math.max(0, Math.min(1, targetVol)); return; }
  const startVol  = isMuted ? 0 : audio.volume;
  const startTime = performance.now();
  function step(now) {
    const p = Math.min(1, (now - startTime) / durationMs);
    if (!isMuted) audio.volume = startVol + (targetVol - startVol) * p;
    if (p < 1) { crossfadeRAF = requestAnimationFrame(step); } else { crossfadeRAF = null; }
  }
  crossfadeRAF = requestAnimationFrame(step);
}

