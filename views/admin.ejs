// =================== DAILY GENERATION ===================
async function loadDailyGen() {
  const date = document.getElementById('dailygen-date').value;
  if (!date) return;
  try {
    const rows = await api('GET', `/daily-queue?date=${date}`);
    const tbody = document.getElementById('dailygen-tbody');
    const stats = document.getElementById('dailygen-stats');
    stats.textContent = `${rows.length} tracks in queue`;

    if (!rows.length) {
      tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text3);">No tracks generated for this date. Click "Generate Day" to create the queue.</td></tr>`;
      return;
    }

    let totalDuration = 0;
    tbody.innerHTML = rows.map((r, i) => {
      totalDuration += r.duration || 0;
      return `
        <tr draggable="true" data-queue-id="${r.id}" style="${r.played ? 'opacity:0.5;' : ''}cursor:grab;">
          <td style="color:var(--text3);font-family:var(--mono);">${i+1}</td>
          <td style="font-weight:500;">${esc(r.title)}</td>
          <td style="color:var(--text3);">${esc(r.artist)}</td>
          <td style="font-family:var(--mono);color:var(--text3);">${formatDuration(r.duration)}</td>
          <td><span class="badge badge-cyan" style="font-family:var(--mono);">${r.start_time || '—'}</span></td>
          <td><span class="badge ${r.played ? 'badge-orange' : 'badge-green'}">${r.played ? 'Played' : 'Pending'}</span></td>
        </tr>`;
    }).join('');

    stats.textContent = `${rows.length} tracks · ${formatDuration(totalDuration)} total`;
    initQueueDragDrop(tbody);
  } catch (e) { toast('Failed to load queue', 'error'); }
}

async function generateDay() {
  const date = document.getElementById('dailygen-date').value;
  if (!date) return toast('Select a date', 'error');
  try {
    const r = await api('POST', '/daily-queue/generate', { date });
    toast(`Generated ${r.trackCount} tracks for ${date}`, 'success');
    loadDailyGen();
  } catch (e) { toast(e.message, 'error'); }
}

async function playDay() {
  const date = document.getElementById('dailygen-date').value;
  if (!date) return toast('Select a date', 'error');
  try {
    const r = await api('POST', '/daily-queue/play', { date });
    toast(`Playing ${r.queueLength} tracks`, 'success');
  } catch (e) { toast(e.message, 'error'); }
}

document.getElementById('dailygen-date').addEventListener('change', loadDailyGen);

