<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= settings.radio_name || 'LETW Radio' %> — Admin Dashboard</title>
  <script>window.__S=<%- JSON.stringify(settings).replace(/<\//g, '<\\/') %>;</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <style>
    :root {
      --bg: #06080f;
      --bg2: #090d1c;
      --bg3: #0d1226;
      --panel: #101628;
      --panel2: #141c32;
      --border: #1c2540;
      --border2: #222d4e;
      --cyan: #4a7fd4;
      --cyan2: #3a6bbf;
      --orange: #1a3a8f;
      --orange2: #152e70;
      --green: #4caf82;
      --red: #e05070;
      --yellow: #d4a843;
      --purple: #6b4fae;
      --text: #ffffff;
      --text2: #b8c8e8;
      --text3: #5a7aaa;
      --font: 'Space Grotesk', sans-serif;
      --mono: 'Space Mono', monospace;
      --radius: 10px;
      --shadow: 0 4px 24px rgba(0,0,0,0.6);
      --gold: #d4a843;
      --gold2: #f0c85a;
      --navy: #1a3a8f;
      --blue: #1a3a8f;
      --blue2: #2a55c0;
      --blue3: #4a7fd4;
      --white: #ffffff;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      min-height: 100vh;
      display: flex;
      overflow: hidden;
      background-image: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(26,58,143,0.15) 0%, transparent 60%);
    }

    /* SCROLLBAR */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: var(--bg2); }
    ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 10px; }

    /* SIDEBAR */
    .sidebar {
      width: 220px;
      min-width: 220px;
      background: var(--bg2);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      padding: 0;
      height: 100vh;
      overflow-y: auto;
    }

    .sidebar-logo {
      padding: 20px 20px 18px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
      background: linear-gradient(135deg, rgba(26,58,143,0.15) 0%, transparent 100%);
    }

    .logo-icon {
      width: 36px;
      height: 36px;
      background: linear-gradient(135deg, var(--blue2), var(--blue));
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
    }

    .logo-text { 
      font-family: 'Cinzel', serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--white);
      line-height: 1.2;
      letter-spacing: 0.5px;
    }
    .logo-sub { font-size: 10px; color: var(--text3); font-family: var(--mono); }

    .nav-section {
      padding: 16px 10px 6px;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      color: var(--text3);
      text-transform: uppercase;
      font-family: var(--mono);
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      margin: 1px 8px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      color: var(--text2);
      transition: all 0.15s;
      position: relative;
    }

    .nav-item:hover { background: var(--panel); color: var(--white); }
    .nav-item.active {
      background: rgba(26,58,143,0.25);
      color: var(--white);
      font-weight: 600;
    }
    .nav-item.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 20px;
      background: var(--blue3);
      border-radius: 0 3px 3px 0;
    }

    .nav-icon { font-size: 16px; width: 20px; text-align: center; }

    /* NOW PLAYING MINI (sidebar bottom) */
    .sidebar-now-playing {
      margin-top: auto;
      border-top: 1px solid var(--border);
      padding: 14px;
    }

    .snp-label { font-size: 9px; color: var(--text3); letter-spacing: 2px; text-transform: uppercase; font-family: var(--mono); margin-bottom: 8px; }

    .snp-track { 
      font-size: 12px; 
      font-weight: 600; 
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .snp-artist { font-size: 11px; color: var(--text3); margin-top: 2px; }

    .snp-controls { display: flex; gap: 6px; margin-top: 10px; }
    .snp-btn {
      flex: 1;
      padding: 6px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: var(--panel);
      color: var(--text2);
      cursor: pointer;
      font-size: 12px;
      transition: all 0.15s;
    }
    .snp-btn:hover { background: var(--panel2); color: var(--text); }
    .snp-btn.active { background: rgba(74,127,212,0.2); color: var(--white); border-color: var(--blue3); }

    /* EQUALIZER ANIMATION */
    .eq-bars {
      display: flex;
      gap: 2px;
      align-items: flex-end;
      height: 16px;
      margin-top: 8px;
    }
    .eq-bar {
      width: 3px;
      background: var(--blue3);
      border-radius: 2px;
      animation: eqAnimate 0.8s ease-in-out infinite;
    }
    .eq-bar:nth-child(1) { animation-delay: 0s; }
    .eq-bar:nth-child(2) { animation-delay: 0.1s; }
    .eq-bar:nth-child(3) { animation-delay: 0.2s; }
    .eq-bar:nth-child(4) { animation-delay: 0.15s; }
    .eq-bar:nth-child(5) { animation-delay: 0.05s; }
    @keyframes eqAnimate {
      0%, 100% { height: 4px; opacity: 0.5; }
      50% { height: 16px; opacity: 1; }
    }
    .eq-bars.paused .eq-bar { animation-play-state: paused; height: 4px; }
    @keyframes liveDot { 0%,100%{opacity:1;} 50%{opacity:0;} }

    /* MAIN CONTENT */
    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }

    /* TOP BAR */
    .topbar {
      height: 60px;
      min-height: 60px;
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 24px;
      gap: 16px;
    }

    .topbar-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--text);
      flex: 1;
    }

    .topbar-sub { font-size: 12px; color: var(--text3); font-weight: 400; margin-left: 8px; }

    .status-pill {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      font-family: var(--mono);
    }

    .status-pill.live {
      background: rgba(0,230,118,0.1);
      color: var(--green);
      border: 1px solid rgba(0,230,118,0.3);
    }
    .status-pill.offline {
      background: rgba(255,23,68,0.1);
      color: var(--red);
      border: 1px solid rgba(255,23,68,0.3);
    }

    .dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: currentColor;
    }

    .dot.pulse { animation: pulse 1.5s infinite; }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }

    .listeners-badge {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 6px 12px;
      background: var(--panel);
      border-radius: 20px;
      border: 1px solid var(--border);
      font-size: 12px;
      color: var(--text2);
    }

    /* PAGE CONTENT */
    .page-content {
      flex: 1;
      overflow-y: auto;
      padding: 24px;
    }

    .page { display: none; }
    .page.active { display: block; }

    /* CARDS */
    .card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .card-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--text2);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-family: var(--mono);
    }

    /* GRID LAYOUTS */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }

    /* STATS */
    .stat-block {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
    }

    .stat-label { font-size: 11px; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; font-family: var(--mono); }
    .stat-value { font-size: 28px; font-weight: 700; color: var(--text); font-family: var(--mono); }
    .stat-sub { font-size: 11px; color: var(--text3); margin-top: 4px; }

    /* NOW PLAYING BIG CARD */
    .now-playing-card {
      background: linear-gradient(135deg, rgba(26,58,143,0.15) 0%, rgba(74,127,212,0.05) 100%);
      border: 1px solid rgba(74,127,212,0.3);
      border-radius: var(--radius);
      padding: 24px;
      position: relative;
      overflow: hidden;
    }

    .now-playing-card::before {
      content: '';
      position: absolute;
      top: -40px;
      right: -40px;
      width: 150px;
      height: 150px;
      background: radial-gradient(circle, rgba(74,127,212,0.12), transparent 70%);
      pointer-events: none;
    }

    .np-track { font-size: 20px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
    .np-artist { font-size: 14px; color: var(--blue3); font-weight: 300; }

    .np-meta { display: flex; gap: 16px; margin-top: 16px; flex-wrap: wrap; }
    .np-meta-item { font-size: 11px; color: var(--text3); display: flex; align-items: center; gap: 4px; font-family: var(--mono); }

    .progress-bar-wrap { margin-top: 16px; position: relative; }
    .progress-track { height: 3px; background: var(--border2); border-radius: 3px; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, var(--blue), var(--blue3)); border-radius: 3px; transition: width 1s linear; }

    /* BUTTONS */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      font-family: var(--font);
      font-size: 13px;
      font-weight: 600;
      transition: all 0.15s;
    }

    .btn-primary { background: linear-gradient(135deg, var(--blue), var(--blue2)); color: #ffffff; }
    .btn-primary:hover { background: linear-gradient(135deg, var(--blue2), var(--blue3)); }
    .btn-secondary { background: var(--panel2); color: var(--text); border: 1px solid var(--border); }
    .btn-secondary:hover { background: var(--border); }
    .btn-danger { background: rgba(255,23,68,0.1); color: var(--red); border: 1px solid rgba(255,23,68,0.3); }
    .btn-danger:hover { background: rgba(255,23,68,0.2); }
    .btn-orange { background: var(--orange); color: #fff; }
    .btn-orange:hover { background: var(--orange2); }
    .btn-sm { padding: 5px 10px; font-size: 11px; border-radius: 6px; }
    .btn-icon { padding: 7px; }

    /* TABS */
    .tabs {
      display: flex;
      gap: 4px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 20px;
    }

    .tab {
      padding: 10px 16px;
      cursor: pointer;
      font-size: 13px;
      color: var(--text3);
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      font-weight: 500;
      transition: all 0.15s;
    }

    .tab:hover { color: var(--text2); }
    .tab.active { color: var(--white); border-bottom-color: var(--blue3); }

    /* TABLE */
    .table-wrap { overflow-x: auto; }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }

    thead th {
      text-align: left;
      padding: 10px 14px;
      color: var(--text3);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      border-bottom: 1px solid var(--border);
      font-family: var(--mono);
    }

    tbody tr {
      border-bottom: 1px solid rgba(35,44,61,0.5);
      transition: background 0.1s;
    }

    tbody tr:hover { background: rgba(255,255,255,0.02); }

    tbody td {
      padding: 10px 14px;
      color: var(--text);
      vertical-align: middle;
    }

    .track-title-cell { font-weight: 500; }
    .track-artist-cell { color: var(--text3); }
    .duration-cell { font-family: var(--mono); font-size: 12px; color: var(--text3); }

    /* DRAG OVER */
    .drag-over { background: rgba(74,127,212,0.05) !important; border: 1px dashed var(--blue3) !important; }

    /* UPLOAD ZONE */
    .upload-zone {
      border: 2px dashed var(--border2);
      border-radius: var(--radius);
      padding: 48px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
    }

    .upload-zone:hover, .upload-zone.drag-active {
      border-color: var(--blue3);
      background: rgba(74,127,212,0.04);
    }

    .upload-icon { font-size: 40px; margin-bottom: 12px; }
    .upload-text { font-size: 15px; font-weight: 500; color: var(--text2); margin-bottom: 6px; }
    .upload-sub { font-size: 12px; color: var(--text3); }

    /* BADGE */
    .badge {
      display: inline-flex;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .badge-cyan { background: rgba(74,127,212,0.15); color: #a0c0f0; }
    .badge-orange { background: rgba(26,58,143,0.2); color: var(--blue3); }
    .badge-green { background: rgba(76,175,130,0.12); color: var(--green); }
    .badge-purple { background: rgba(107,79,174,0.12); color: var(--purple); }

    /* PLANNING CALENDAR */
    .planning-calendar {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .cal-header {
      display: grid;
      grid-template-columns: 60px repeat(7, 1fr);
      border-bottom: 1px solid var(--border);
    }

    .cal-day-header {
      padding: 12px 8px;
      text-align: center;
      font-size: 11px;
      font-weight: 700;
      color: var(--text3);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-family: var(--mono);
      border-right: 1px solid var(--border);
    }

    .cal-day-header.today { color: var(--cyan); }
    .cal-day-header:last-child { border-right: none; }

    .cal-body {
      display: flex;
      height: 600px;
      overflow-y: auto;
      position: relative;
    }

    .cal-times {
      width: 60px;
      min-width: 60px;
      border-right: 1px solid var(--border);
      position: sticky;
      left: 0;
      background: var(--panel);
      z-index: 2;
    }

    .cal-time-slot {
      height: 40px;
      display: flex;
      align-items: flex-start;
      justify-content: flex-end;
      padding: 2px 8px 0 0;
      font-size: 10px;
      color: var(--text3);
      font-family: var(--mono);
      border-bottom: 1px solid rgba(35,44,61,0.4);
    }

    .cal-grid {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(7, 1fr);
    }

    .cal-col {
      border-right: 1px solid var(--border);
      position: relative;
    }

    .cal-col:last-child { border-right: none; }

    .cal-hour-line {
      height: 40px;
      border-bottom: 1px solid rgba(35,44,61,0.4);
    }

    .cal-slot {
      position: absolute;
      left: 2px;
      right: 2px;
      border-radius: 6px;
      padding: 4px 6px;
      font-size: 10px;
      font-weight: 600;
      overflow: hidden;
      cursor: pointer;
      transition: opacity 0.15s;
      z-index: 1;
    }

    .cal-slot:hover { opacity: 0.85; }
    .cal-slot-title { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cal-slot-time { font-family: var(--mono); opacity: 0.7; margin-top: 2px; font-size: 9px; }

    /* CURRENT TIME LINE */
    .current-time-line {
      position: absolute;
      height: 2px;
      background: var(--red);
      left: 0;
      right: 0;
      z-index: 10;
      pointer-events: none;
    }

    .current-time-line::before {
      content: '';
      position: absolute;
      left: -4px;
      top: -4px;
      width: 10px;
      height: 10px;
      background: var(--red);
      border-radius: 50%;
    }

    /* MODAL */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      backdrop-filter: blur(4px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
    }

    .modal-overlay.open { opacity: 1; pointer-events: all; }

    .modal {
      background: var(--bg3);
      border: 1px solid var(--border2);
      border-radius: 14px;
      padding: 28px;
      width: 480px;
      max-width: 95vw;
      max-height: 90vh;
      overflow-y: auto;
      transform: translateY(20px) scale(0.97);
      transition: transform 0.2s;
      box-shadow: 0 20px 60px rgba(0,0,0,0.7);
    }

    .modal-overlay.open .modal {
      transform: translateY(0) scale(1);
    }

    .modal-title {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .modal-close {
      cursor: pointer;
      color: var(--text3);
      font-size: 20px;
      padding: 4px;
      line-height: 1;
    }

    .modal-close:hover { color: var(--text); }

    /* FORM ELEMENTS */
    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-size: 12px; color: var(--text3); margin-bottom: 6px; font-weight: 500; letter-spacing: 0.5px; }

    .form-control {
      width: 100%;
      padding: 10px 12px;
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: var(--font);
      font-size: 13px;
      transition: border-color 0.15s;
    }

    .form-control:focus {
      outline: none;
      border-color: var(--blue3);
    }

    select.form-control option { background: var(--bg3); }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .checkbox-label {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      font-size: 13px;
      color: var(--text2);
    }

    .checkbox-label input { accent-color: var(--cyan); width: 15px; height: 15px; }

    /* COLOR PICKER ROW */
    .color-row { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 6px; }
    .color-dot {
      width: 24px; height: 24px;
      border-radius: 50%;
      cursor: pointer;
      border: 2px solid transparent;
      transition: border-color 0.1s;
    }
    .color-dot.selected { border-color: #fff; }

    /* HISTORY LIST */
    .history-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid rgba(35,44,61,0.5);
    }

    .history-time { font-family: var(--mono); font-size: 11px; color: var(--text3); min-width: 80px; }
    .history-title { font-size: 13px; font-weight: 500; }
    .history-artist { font-size: 11px; color: var(--text3); }

    /* TRAY SELECTOR */
    .tray-chips { display: flex; gap: 6px; flex-wrap: wrap; }
    .tray-chip {
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      border: 1px solid var(--border);
      cursor: pointer;
      color: var(--text3);
      transition: all 0.15s;
    }
    .tray-chip.active { background: rgba(26,58,143,0.25); color: var(--white); border-color: var(--blue3); }

    /* PLAYLIST COLOR SWATCH */
    .playlist-swatch {
      width: 12px;
      height: 12px;
      border-radius: 3px;
      display: inline-block;
    }

    /* EMPTY STATE */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: var(--text3);
    }

    .empty-icon { font-size: 48px; margin-bottom: 12px; }
    .empty-title { font-size: 16px; color: var(--text2); margin-bottom: 6px; }
    .empty-sub { font-size: 13px; }

    /* TOAST */
    .toast-container {
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 2000;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .toast {
      padding: 12px 18px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 500;
      border: 1px solid var(--border);
      max-width: 320px;
      animation: slideInRight 0.3s ease;
      box-shadow: var(--shadow);
    }

    @keyframes slideInRight {
      from { transform: translateX(100px); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }

    /* Live broadcast — pulsing dot for the stats panel */
    @keyframes live-dot-pulse {
      0%, 100% { opacity: 1;    transform: scale(1);    box-shadow: 0 0 0 0 rgba(255,32,80,0.7); }
      50%       { opacity: 0.7; transform: scale(1.15); box-shadow: 0 0 0 5px rgba(255,32,80,0); }
    }
    /* ON AIR chip pulse when broadcasting */
    @keyframes onair-chip-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(224,80,112,0.55); }
      50%       { box-shadow: 0 0 0 6px rgba(224,80,112,0); }
    }
    .live-status-chip-on {
      animation: onair-chip-pulse 1.6s ease-in-out infinite;
    }

    .toast-success { background: rgba(76,175,130,0.1); border-color: rgba(76,175,130,0.3); color: var(--green); }
    .toast-error { background: rgba(224,80,112,0.1); border-color: rgba(224,80,112,0.3); color: var(--red); }
    .toast-info { background: rgba(74,127,212,0.1); border-color: rgba(74,127,212,0.3); color: #a0c0f0; }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      .sidebar { width: 60px; min-width: 60px; }
      .sidebar-logo .logo-text, .sidebar-logo .logo-sub,
      .nav-item span:last-child, .sidebar-now-playing { display: none; }
      .nav-section { display: none; }
      .nav-item { justify-content: center; padding: 12px; }
      .grid-4 { grid-template-columns: 1fr 1fr; }
      .grid-3 { grid-template-columns: 1fr 1fr; }
      .grid-2 { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <img src="/logo.png" alt="LETW" style="width:44px;height:44px;border-radius:8px;object-fit:contain;border:1px solid rgba(212,168,67,0.4);background:#fff;padding:2px;">
    <div>
      <div class="logo-text" id="sidebar-radio-name">LETW Radio</div>
      <div class="logo-sub">Radio Manager</div>
    </div>
  </div>

  <div class="nav-section">Overview</div>
  <div class="nav-item active" data-page="dashboard">
    <span class="nav-icon">📊</span><span>Dashboard</span>
  </div>

  <div class="nav-section">Content</div>
  <div class="nav-item" data-page="library">
    <span class="nav-icon">🎵</span><span>Library</span>
  </div>
  <div class="nav-item" data-page="playlists">
    <span class="nav-icon">📂</span><span>Playlists</span>
  </div>
  <div class="nav-item" data-page="programs">
    <span class="nav-icon">🎙️</span><span>Programs</span>
  </div>

  <div class="nav-section">Scheduling</div>
  <div class="nav-item" data-page="planning">
    <span class="nav-icon">📅</span><span>Planning</span>
  </div>
  <div class="nav-item" data-page="breaks">
    <span class="nav-icon">⏱️</span><span>Breaks</span>
  </div>
  <div class="nav-item" data-page="dailygen">
    <span class="nav-icon">🔄</span><span>Daily Gen.</span>
  </div>

  <div class="nav-section">Broadcast</div>
  <div class="nav-item" data-page="golive" style="position:relative;">
    <span class="nav-icon">🎙️</span><span>Go Live</span>
    <span id="live-nav-dot" style="display:none;position:absolute;right:10px;top:50%;transform:translateY(-50%);width:8px;height:8px;background:#e05070;border-radius:50%;animation:liveDot 1s infinite;"></span>
  </div>

  <div class="nav-item" data-page="community">
    <span class="nav-icon">💬</span><span>Community</span>
    <span id="community-badge" style="display:none;margin-left:auto;background:#e03060;color:#fff;font-size:9px;font-weight:900;padding:2px 6px;border-radius:10px;letter-spacing:0.5px;">NEW</span>
  </div>

  <div class="nav-section">Other</div>
  <div class="nav-item" data-page="streams">
    <span class="nav-icon">📡</span><span>Streams</span>
  </div>
  <div class="nav-item" data-page="sermons">
    <span class="nav-icon">🎧</span><span>Sermons</span>
  </div>
  <div class="nav-item" data-page="history">
    <span class="nav-icon">📜</span><span>History</span>
  </div>
  <div class="nav-item" data-page="settings">
    <span class="nav-icon">⚙️</span><span>Settings</span>
  </div>
  <div class="nav-item" onclick="location.href='/admin-logout'" style="color:var(--text3);margin-top:4px;">
    <span class="nav-icon">🔒</span><span>Logout</span>
  </div>

  <!-- NOW PLAYING MINI -->
  <div class="sidebar-now-playing">
    <div class="snp-label">Now Playing</div>
    <div id="snp-track" class="snp-track">No track playing</div>
    <div id="snp-artist" class="snp-artist">—</div>
    <div class="eq-bars" id="eq-bars">
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
    </div>
    <div class="snp-controls">
      <button class="snp-btn" id="btn-play-stop" title="Play/Stop">▶</button>
      <button class="snp-btn" onclick="skipTrack()" title="Skip">⏭</button>
      <a href="/listen" target="_blank" class="snp-btn" style="text-decoration:none;text-align:center;" title="Listen">🔊</a>
    </div>
  </div>
</aside>

<!-- MAIN -->
<main class="main">
  <!-- TOP BAR -->
  <div class="topbar">
    <div class="topbar-title" id="topbar-title">Dashboard</div>
    <div id="status-pill" class="status-pill offline">
      <div class="dot"></div>
      <span>Offline</span>
    </div>
    <div class="listeners-badge">
      👤 <span id="listener-count">0</span> listeners
    </div>
    <div id="admin-conn-pill" style="display:flex;align-items:center;gap:5px;padding:5px 10px;border-radius:20px;background:var(--panel);border:1px solid var(--border);font-size:11px;color:var(--text3);font-family:var(--mono);cursor:default;" title="Admin socket connection quality">
      <span id="admin-conn-dot" style="width:7px;height:7px;border-radius:50%;background:#4caf82;display:inline-block;flex-shrink:0;"></span>
      <span id="admin-conn-label">—</span>
      <button id="admin-reconn-btn" onclick="reconnectAdmin()" style="display:none;margin-left:2px;font-size:10px;padding:2px 6px;border:1px solid rgba(212,168,67,0.4);border-radius:4px;background:rgba(212,168,67,0.08);color:#d4a843;cursor:pointer;font-family:inherit;">Reconnect</button>
    </div>
  </div>

  <!-- PAGE CONTENT -->
  <div class="page-content">

    <!-- ===== DASHBOARD ===== -->
    <div class="page active" id="page-dashboard">
      <div class="grid-4" style="margin-bottom:20px;">
        <div class="stat-block">
          <div class="stat-label">Listeners</div>
          <div class="stat-value" id="stat-listeners">0</div>
          <div class="stat-sub">Connected now</div>
        </div>
        <div class="stat-block">
          <div class="stat-label">Queue</div>
          <div class="stat-value" id="stat-queue">0</div>
          <div class="stat-sub">Tracks remaining</div>
        </div>
        <div class="stat-block">
          <div class="stat-label">Library</div>
          <div class="stat-value" id="stat-tracks">0</div>
          <div class="stat-sub">Total tracks</div>
        </div>
        <div class="stat-block">
          <div class="stat-label">Playlists</div>
          <div class="stat-value" id="stat-playlists">0</div>
          <div class="stat-sub">Created</div>
        </div>
      </div>

      <!-- NOW PLAYING BIG -->
      <div class="now-playing-card" style="margin-bottom:20px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:16px;">
          <div style="flex:1;">
            <div style="font-size:11px;color:var(--blue3);letter-spacing:2px;text-transform:uppercase;font-family:var(--mono);margin-bottom:8px;">
              ● ON AIR NOW
            </div>
            <div class="np-track" id="np-track">No track playing</div>
            <div class="np-artist" id="np-artist">—</div>
            <div class="np-meta">
              <div class="np-meta-item">⏱ <span id="np-duration">0:00</span></div>
              <div class="np-meta-item">📡 <span id="np-bitrate">128kbps</span></div>
              <div class="np-meta-item">🎚 <span id="np-format">MP3</span></div>
            </div>
          </div>
          <div style="display:flex;gap:8px;align-items:center;">
            <button class="btn btn-primary" onclick="playRadio()" id="dash-play-btn">▶ Start Radio</button>
            <button class="btn btn-secondary" onclick="skipTrack()">⏭ Skip</button>
            <a href="/listen" target="_blank" class="btn btn-secondary">🎧 Listen</a>
          </div>
        </div>
        <div class="progress-bar-wrap">
          <div class="progress-track">
            <div class="progress-fill" id="progress-fill" style="width:0%"></div>
          </div>
        </div>
      </div>

      <div class="grid-2">
        <!-- RECENT HISTORY -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">Recently Played</div>
          </div>
          <div id="history-mini-list">
            <div class="empty-state" style="padding:30px;">
              <div>No play history yet</div>
            </div>
          </div>
        </div>

        <!-- QUICK ACTIONS -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">Quick Actions</div>
          </div>
          <div style="display:flex;flex-direction:column;gap:10px;">
            <button class="btn btn-secondary" style="justify-content:flex-start;" onclick="navigate('library')">
              🎵 Upload Tracks to Library
            </button>
            <button class="btn btn-secondary" style="justify-content:flex-start;" onclick="navigate('playlists')">
              📂 Create Playlist
            </button>
            <button class="btn btn-secondary" style="justify-content:flex-start;" onclick="navigate('planning')">
              📅 Add to Planning
            </button>
            <button class="btn btn-secondary" style="justify-content:flex-start;" onclick="navigate('breaks')">
              ⏱ Schedule a Break
            </button>
            <button class="btn btn-secondary" style="justify-content:flex-start;" onclick="navigate('dailygen')">
              🔄 Generate Today's Queue
            </button>
            <a href="/listen" target="_blank" class="btn btn-secondary" style="justify-content:flex-start;text-decoration:none;">
              🔗 Share Radio Link
            </a>
            <button class="btn" style="justify-content:flex-start;background:rgba(200,30,50,0.1);border:1px solid rgba(200,30,50,0.35);color:#ff6b8a;font-weight:700;" onclick="emergencyStop()">
              🛑 Emergency Stop All
            </button>
          </div>
        </div>
      </div>

      <!-- STATION CONTROLS + ANNOUNCEMENT ROW -->
      <div class="grid-2" style="margin-top:20px;">

        <!-- BROADCAST ANNOUNCEMENT -->
        <div class="card">
          <div class="card-header"><div class="card-title">📢 Broadcast Announcement</div></div>
          <div style="padding:4px 0;">
            <div style="font-size:11px;color:var(--text3);margin-bottom:10px;">Push a scrolling message to all listeners in real time.</div>
            <input type="text" class="form-control" id="announce-text" placeholder="Type your announcement..." style="margin-bottom:8px;">
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <button class="btn btn-primary" style="flex:1;" onclick="broadcastAnnounce(true)">📡 Enable &amp; Broadcast</button>
              <button class="btn btn-secondary" onclick="broadcastAnnounce(false)">✕ Clear</button>
            </div>
            <div id="announce-status" style="font-size:11px;color:#4caf82;margin-top:8px;display:none;">Sent to all listeners!</div>
          </div>
        </div>

        <!-- FLASH ALERT CARD -->
        <div class="card" style="border-color:rgba(212,168,67,0.3);">
          <div class="card-header"><div class="card-title">⚡ Flash Alert</div></div>
          <div style="padding:4px 0;">
            <div style="font-size:11px;color:var(--text3);margin-bottom:10px;">Send an instant pop-up message to all listeners right now.</div>
            <input type="text" class="form-control" id="flash-alert-text" maxlength="280" placeholder="Type your urgent message (max 280 chars)..." style="margin-bottom:8px;">
            <div style="display:flex;gap:8px;align-items:center;margin-bottom:8px;">
              <label style="font-size:11px;color:var(--text3);white-space:nowrap;">Colour</label>
              <input type="color" id="flash-alert-color" value="#d4a843" style="width:36px;height:28px;border:none;background:none;cursor:pointer;border-radius:6px;">
            </div>
            <button class="btn btn-primary" style="width:100%;" onclick="sendFlashAlert()">⚡ Send Flash Alert to All Listeners</button>
            <div id="flash-alert-status" style="font-size:11px;color:#4caf82;margin-top:8px;display:none;">Sent!</div>
          </div>
        </div>

        <!-- ACTIVITY LOG -->
        <div class="card">
          <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
            <div class="card-title">📋 Activity Log</div>
            <button class="btn btn-secondary" style="padding:3px 10px;font-size:11px;" onclick="clearActivityLog()">Clear</button>
          </div>
          <div id="activity-log" style="max-height:180px;overflow-y:auto;font-size:11px;font-family:var(--mono);display:flex;flex-direction:column;gap:4px;">
            <div style="color:var(--text3);font-style:italic;">Waiting for events...</div>
          </div>
        </div>

      </div>

      <!-- LISTENERS CHART -->
      <div class="card" style="margin-top:20px;" id="listeners-chart-card">
        <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
          <div class="card-title">📊 Listener Activity — Last 24 Hours</div>
          <button class="btn btn-secondary" style="padding:4px 12px;font-size:11px;" onclick="loadListenersChart()">Refresh</button>
        </div>
        <div style="padding:16px;">
          <div style="position:relative;height:200px;width:100%;">
            <canvas id="listeners-chart"></canvas>
          </div>
          <div style="margin-top:8px;font-size:10px;color:rgba(192,168,216,0.35);letter-spacing:0.5px;text-align:right;">
            Recorded every 60 seconds — last 1440 data points max
          </div>
        </div>
      </div>
      <div class="card" style="margin-top:20px;">
        <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
          <div class="card-title">🏆 Top Played Tracks</div>
          <button class="btn btn-secondary" style="padding:3px 10px;font-size:11px;" onclick="loadTopPlayed()">Refresh</button>
        </div>
        <div id="top-played-list" style="padding:0;">
          <div style="padding:20px;text-align:center;font-size:13px;color:var(--text3);">Loading...</div>
        </div>
      </div>

      <!-- STATION & CONNECTION HEALTH (SAM Broadcaster-equivalent stability panel) -->
      <div class="card" style="margin-top:20px;">
        <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
          <div class="card-title">🖥 Station & Connection Health</div>
          <div style="display:flex;gap:8px;">
            <button class="btn btn-secondary" style="padding:3px 10px;font-size:11px;" onclick="loadServerHealth()">Refresh</button>
            <button class="btn btn-secondary" style="padding:3px 10px;font-size:11px;" onclick="reconnectAdmin()">🔄 Force Reconnect</button>
          </div>
        </div>
        <!-- Metric tiles -->
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:10px;padding:4px 0 12px;">
          <div style="text-align:center;padding:12px 8px;background:rgba(74,127,212,0.06);border:1px solid rgba(74,127,212,0.2);border-radius:10px;">
            <div id="sh-uptime" style="font-size:17px;font-weight:700;color:var(--blue3);font-family:var(--mono);">—</div>
            <div style="font-size:9px;color:var(--text3);letter-spacing:1px;margin-top:3px;text-transform:uppercase;">Server Uptime</div>
          </div>
          <div style="text-align:center;padding:12px 8px;background:rgba(76,175,130,0.06);border:1px solid rgba(76,175,130,0.2);border-radius:10px;">
            <div id="sh-mem" style="font-size:17px;font-weight:700;color:#4caf82;font-family:var(--mono);">—</div>
            <div style="font-size:9px;color:var(--text3);letter-spacing:1px;margin-top:3px;text-transform:uppercase;">Heap Used</div>
          </div>
          <div style="text-align:center;padding:12px 8px;background:rgba(212,168,67,0.06);border:1px solid rgba(212,168,67,0.2);border-radius:10px;">
            <div id="sh-rtt" style="font-size:17px;font-weight:700;color:var(--gold);font-family:var(--mono);">—</div>
            <div style="font-size:9px;color:var(--text3);letter-spacing:1px;margin-top:3px;text-transform:uppercase;">Latency (RTT)</div>
          </div>
          <div style="text-align:center;padding:12px 8px;background:rgba(107,79,174,0.06);border:1px solid rgba(107,79,174,0.2);border-radius:10px;">
            <div id="sh-watchdog" style="font-size:17px;font-weight:700;color:var(--purple);font-family:var(--mono);">—</div>
            <div style="font-size:9px;color:var(--text3);letter-spacing:1px;margin-top:3px;text-transform:uppercase;">Watchdog</div>
          </div>
          <div style="text-align:center;padding:12px 8px;background:rgba(224,80,112,0.06);border:1px solid rgba(224,80,112,0.2);border-radius:10px;">
            <div id="sh-rss" style="font-size:17px;font-weight:700;color:#e05070;font-family:var(--mono);">—</div>
            <div style="font-size:9px;color:var(--text3);letter-spacing:1px;margin-top:3px;text-transform:uppercase;">RSS Memory</div>
          </div>
        </div>
        <!-- Socket status bar -->
        <div style="padding:10px 14px;background:rgba(0,0,0,0.2);border-radius:8px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
          <div style="font-size:11px;color:var(--text3);">Admin Socket:</div>
          <div id="sh-socket-status" style="font-size:12px;font-weight:700;color:#4caf82;">● Connected</div>
          <div style="font-size:11px;color:var(--text3);">Auto-Reconnect:</div>
          <div style="font-size:12px;font-weight:700;color:#4caf82;">Always On</div>
          <div style="font-size:11px;color:var(--text3);">Reconnect Attempts:</div>
          <div id="sh-reconn-count" style="font-size:12px;font-weight:700;color:var(--text2);">0</div>
          <div style="flex:1;"></div>
          <div style="font-size:10px;color:var(--text3);">Watchdog auto-stops dead broadcasts after 20 s of silence · Admin socket reconnects automatically on any network interruption</div>
        </div>
      </div>

    </div>

    <!-- ===== LIBRARY ===== -->
    <div class="page" id="page-library">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap;">
        <div class="tray-chips" id="tray-chips">
          <div class="tray-chip active" data-tray="">All</div>
          <div class="tray-chip" data-tray="music">Music</div>
          <div class="tray-chip" data-tray="jingles">Jingles</div>
          <div class="tray-chip" data-tray="ads">Ads</div>
          <div class="tray-chip" data-tray="recordings">Recordings</div>
        </div>
        <div style="flex:1;"></div>
        <input type="text" class="form-control" style="width:200px;" placeholder="🔍 Search tracks..." id="track-search" oninput="filterTracks()">
        <button class="btn btn-primary" onclick="openUploadModal()">⬆ Upload Files</button>
      </div>

      <div id="bulk-bar" style="display:none;align-items:center;gap:10px;padding:10px 14px;background:rgba(212,168,67,0.07);border:1px solid rgba(212,168,67,0.2);border-radius:10px;margin-bottom:12px;flex-wrap:wrap;">
        <span id="bulk-count" style="font-size:12px;color:var(--gold);font-weight:700;">0 selected</span>
        <div style="flex:1;"></div>
        <select id="bulk-tray-select" class="form-control" style="width:130px;padding:5px 10px;">
          <option value="">Move to tray…</option>
          <option value="music">Music</option>
          <option value="jingles">Jingles</option>
          <option value="ads">Ads</option>
          <option value="recordings">Recordings</option>
        </select>
        <button class="btn btn-secondary" style="padding:5px 12px;font-size:12px;" onclick="bulkMoveTray()">Move</button>
        <button class="btn btn-secondary" style="padding:5px 12px;font-size:12px;color:#e05070;border-color:rgba(224,80,112,0.4);" onclick="bulkDelete()">🗑 Delete Selected</button>
        <button class="btn btn-secondary" style="padding:5px 12px;font-size:12px;" onclick="clearBulkSelection()">✕ Clear</button>
      </div>

      <div class="card">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th style="width:36px;"><input type="checkbox" id="select-all-tracks" onchange="toggleSelectAll(this.checked)" style="accent-color:var(--gold);"></th>
                <th style="width:40px;">#</th>
                <th>Title</th>
                <th>Artist</th>
                <th>Album</th>
                <th>Duration</th>
                <th>Plays</th>
                <th>❤️</th>
                <th>Tray</th>
                <th style="width:120px;">Actions</th>
              </tr>
            </thead>
            <tbody id="tracks-tbody">
              <tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text3);">Loading tracks...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ===== PLAYLISTS ===== -->
    <div class="page" id="page-playlists">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <div></div>
        <button class="btn btn-primary" onclick="openPlaylistModal()">+ New Playlist</button>
      </div>
      <div class="grid-3" id="playlists-grid">
        <div class="empty-state"><div class="empty-icon">📂</div><div class="empty-title">No playlists yet</div><div class="empty-sub">Create your first playlist</div></div>
      </div>
    </div>

    <!-- ===== PROGRAMS ===== -->
    <div class="page" id="page-programs">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <div></div>
        <button class="btn btn-primary" onclick="openProgramModal()">+ New Program</button>
      </div>
      <div class="grid-3" id="programs-grid">
