<script>
// =================== STATE ===================
let state = {
  currentPage: 'dashboard',
  tracks: [],
  playlists: [],
  programs: [],
  planning: [],
  breaks: [],
  settings: {},
  status: {},
  currentTray: '',
  selectedPlanColor: '#00d4ff',
  currentTrackInfo: null,
  progressInterval: null,
  trackStartTime: null,
  trackDuration: 0,
};

const COLORS = ['#00e5ff','#ff6d3b','#00e676','#d500f9','#ffea00','#ff1744','#7c4dff','#76ff03'];

// =================== SOCKET ===================
const socket = io({
  auth:                 { token: getAdminToken() },
  transports:           ['websocket', 'polling'],  // WebSocket first — skip polling handshake
  upgrade:              true,
  rememberUpgrade:      true,   // go straight to WS on subsequent connects
  reconnection:         true,
  reconnectionAttempts: Infinity,   // never give up — admin may run for hours
  reconnectionDelay:    400,        // first retry in 400 ms — minimise live gap
  reconnectionDelayMax: 2000,       // cap at 2 s for near-instant recovery
  randomizationFactor:  0.2,        // add ±20 % jitter to avoid thundering herd
  timeout:              15000,      // fail fast and retry rather than hang for 20 s
});

// Force an immediate reconnect the moment connectivity returns (network switch,
// laptop wakes from sleep, leaving a dead zone) instead of waiting for the
// backoff timer — critical when a live broadcast is in progress.
window.addEventListener('online', () => {
  if (socket && socket.disconnected) { try { socket.connect(); } catch(_) {} }
});

// ── Broadcast resilience: recover live session after socket reconnect ──────────
// ── Station & Connection Health ───────────────────────────────────────────────
let _adminRtt    = 0;
let _reconnCount = 0;

// Generic latency probe result
socket.on('admin:pong', ({ clientTs }) => {
  _adminRtt = Date.now() - clientTs;
  const rttEl  = document.getElementById('sh-rtt');
  const topLbl = document.getElementById('admin-conn-label');
  const dot    = document.getElementById('admin-conn-dot');
  const rttColor = _adminRtt < 80 ? '#4caf82' : _adminRtt < 200 ? '#8bc34a' : _adminRtt < 400 ? '#d4a843' : _adminRtt < 700 ? '#ff9800' : '#e05070';
  const rttGrade = _adminRtt < 80 ? '⚡ Excellent' : _adminRtt < 200 ? '✓ Good' : _adminRtt < 400 ? '△ Fair' : _adminRtt < 700 ? '⚠ Poor' : '✗ Critical';
  if (rttEl)  { rttEl.textContent = _adminRtt + ' ms'; rttEl.style.color = rttColor; }
  if (topLbl) { topLbl.textContent = _adminRtt + ' ms · ' + rttGrade; topLbl.style.color = rttColor; }
  if (dot)    dot.style.background = rttColor;
});

// ── Single consolidated connect handler ───────────────────────────────────────
// Handles: station health topbar + live broadcast reconnect-resume.
// ALL socket.on('connect') logic lives here — do not add another one elsewhere.
socket.on('connect', () => {
  // 1. Station health UI
  const statusEl  = document.getElementById('sh-socket-status');
  const dot       = document.getElementById('admin-conn-dot');
  const reconnBtn = document.getElementById('admin-reconn-btn');
  if (statusEl)  { statusEl.textContent = '● Connected'; statusEl.style.color = '#4caf82'; }
  if (dot)       dot.style.background = '#4caf82';
  if (reconnBtn) reconnBtn.style.display = 'none';
  socket.emit('admin:ping', Date.now());  // refresh latency reading
  _flushOfflineChunks();                  // replay any chunks that were queued while offline

  // 2. Live broadcast reconnect — re-signal the server with the correct mimeType
  // so existing listeners keep streaming without interruption.
  // Only re-emit if the disconnect handler flagged us as reconnecting (_liveWasReconnecting).
  if (_liveWasReconnecting && liveMediaRecorder && liveMediaRecorder.state !== 'inactive') {
    _liveWasReconnecting = false;
    const w = document.getElementById('live-conn-warning');
    if (w) w.style.display = 'none';
    socket.auth = { token: getAdminToken() };
    socket.emit('live:start', {
      title:    document.getElementById('live-title').value.trim()  || 'Live Broadcast',
      artist:   document.getElementById('live-artist').value.trim() || 'LETW Radio',
      record:   false,  // recording file already open on server — don't open another
      mimeType: _liveReconnectMimeType
    });
    logActivity('🔄 Socket reconnected — live broadcast resumed');
  } else if (liveMediaRecorder && liveMediaRecorder.state !== 'inactive') {
    // Edge case: still recording but flag not set (very fast reconnect)
    setLiveUIState(true);
    logActivity('✓ Connection restored — broadcast continuing');
  }
});

// ── Single consolidated disconnect handler ────────────────────────────────────
// Handles: station health topbar + live broadcast warning + reconnect flag.
// ALL socket.on('disconnect') logic lives here — do not add another one elsewhere.
socket.on('disconnect', (reason) => {
  // 1. Station health UI
  const statusEl  = document.getElementById('sh-socket-status');
  const dot       = document.getElementById('admin-conn-dot');
  const topLbl    = document.getElementById('admin-conn-label');
  const reconnBtn = document.getElementById('admin-reconn-btn');
  if (statusEl)  { statusEl.textContent = '● Disconnected'; statusEl.style.color = '#e05070'; }
  if (dot)       dot.style.background = '#e05070';
  if (topLbl)    topLbl.textContent = '---';
  if (reconnBtn) reconnBtn.style.display = '';

  // 2. Live broadcast warning
  if (liveMediaRecorder && liveMediaRecorder.state !== 'inactive') {
    _liveWasReconnecting = true;
    const chip = document.getElementById('live-status-chip');
    if (chip) {
      chip.textContent       = '⚠ RECONNECTING…';
      chip.style.background  = 'rgba(212,168,67,0.15)';
      chip.style.borderColor = 'rgba(212,168,67,0.50)';
      chip.style.color       = '#d4a843';
    }
    const w = document.getElementById('live-conn-warning');
    if (w) w.style.display = 'block';
    logActivity('⚠ Server connection lost — reconnecting… (broadcast may be interrupted)');
  }
});

socket.on('reconnect_attempt', (n) => {
  _reconnCount++;
  const statusEl  = document.getElementById('sh-socket-status');
  const countEl   = document.getElementById('sh-reconn-count');
  const dot       = document.getElementById('admin-conn-dot');
  const topLbl    = document.getElementById('admin-conn-label');
  if (statusEl)  { statusEl.textContent = `● Reconnecting… (${n})`; statusEl.style.color = '#d4a843'; }
  if (countEl)   countEl.textContent = _reconnCount;
  if (dot)       dot.style.background = '#d4a843';
  if (topLbl)    topLbl.textContent = 'reconnecting…';
});

