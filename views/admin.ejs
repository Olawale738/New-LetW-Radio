    <!-- ===== GO LIVE ===== -->
    <div class="page" id="page-golive">
      <div class="grid-2" style="max-width:900px;">

        <!-- LIVE CONTROL CARD -->
        <div class="card" style="border-color:rgba(224,80,112,0.3);">
          <div class="card-header">
            <div class="card-title">🎙️ Live Broadcast Control</div>
            <div id="live-status-chip" style="display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:700;letter-spacing:1px;background:rgba(90,90,90,0.15);border:1px solid rgba(90,90,90,0.3);color:#888;">● OFF AIR</div>
          </div>

          <!-- Broadcast info inputs -->
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Broadcast Title</label>
              <input class="form-control" id="live-title" placeholder="e.g. Sunday Service" value="Live Service"
                oninput="localStorage.setItem('letw_live_title',this.value)">
            </div>
            <div class="form-group">
              <label class="form-label">Speaker / Artist</label>
              <input class="form-control" id="live-artist" placeholder="e.g. Pastor Name" value="Light Encounter Tabernacle Worldwide"
                oninput="localStorage.setItem('letw_live_artist',this.value)">
            </div>
          </div>

          <!-- Record toggle (opt-in: must check to save broadcast) -->
          <div style="margin-bottom:14px;padding:10px 14px;background:rgba(76,175,130,0.05);border:1px solid rgba(76,175,130,0.2);border-radius:10px;display:flex;align-items:center;gap:10px;">
            <input type="checkbox" id="live-record-check" style="accent-color:#4caf82;width:16px;height:16px;cursor:pointer;flex-shrink:0;"
              onchange="localStorage.setItem('letw_live_record',this.checked?'1':'0')">
            <div>
              <div style="font-size:12px;font-weight:700;color:var(--text);letter-spacing:0.3px;">🔴 Save recording to Library</div>
              <div style="font-size:10px;color:var(--text3);margin-top:2px;">When checked, the broadcast is automatically saved to the Recordings tray after you stop.</div>
            </div>
          </div>

          <!-- Mic selector -->
          <div class="form-group">
            <label class="form-label">Microphone</label>
            <select class="form-control" id="live-mic-select">
              <option value="">— Select microphone —</option>
            </select>
          </div>

          <!-- Mic level meter -->
          <div style="margin-bottom:16px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
              <div style="font-size:10px;color:var(--text3);letter-spacing:2px;text-transform:uppercase;">Mic Level</div>
              <span id="mic-clip-indicator" style="font-size:9px;font-weight:700;letter-spacing:1.5px;color:#ff2050;opacity:0;transition:opacity 0.15s;">CLIP</span>
            </div>
            <div style="height:12px;background:rgba(255,255,255,0.05);border-radius:6px;overflow:hidden;border:1px solid rgba(255,255,255,0.06);">
              <div id="mic-level-bar" style="height:100%;width:0%;border-radius:6px;background:linear-gradient(90deg,#4caf82,#d4a843,#e05070);transition:width 0.05s;"></div>
            </div>
            <div id="mic-peak-label" style="font-size:9px;color:rgba(255,255,255,0.2);margin-top:3px;text-align:right;font-family:var(--mono);">—</div>
          </div>

          <!-- Mic Boost (input gain) -->
          <div style="margin-bottom:16px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
              <div style="font-size:10px;color:var(--text3);letter-spacing:2px;text-transform:uppercase;">🔊 Mic Boost</div>
              <span id="live-gain-display" style="font-size:11px;color:var(--gold);font-family:var(--mono);font-weight:700;">400%</span>
            </div>
            <input type="range" id="live-gain-slider" min="1" max="15" step="0.1" value="4"
              oninput="updateLiveGain(this.value);localStorage.setItem('letw_live_gain',this.value)"
              style="width:100%;accent-color:var(--gold);cursor:pointer;">
            <div style="font-size:10px;color:rgba(212,168,67,0.45);margin-top:4px;">Raise until voice is clearly loud. Lower only if it sounds distorted.</div>
          </div>

          <!-- Voice EQ (Bass / Presence / Soprano) -->
          <div style="margin-bottom:16px;padding:12px 14px;background:rgba(212,168,67,0.04);border:1px solid rgba(212,168,67,0.18);border-radius:10px;">
            <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px;margin-bottom:12px;">
              <div style="font-size:11px;font-weight:700;color:var(--text);letter-spacing:0.5px;">🎚 Voice EQ</div>
              <div style="display:flex;gap:5px;flex-wrap:wrap;">
                <button onclick="applyEqPreset('sermon')"
                  style="font-size:9px;padding:3px 8px;border-radius:10px;border:1px solid rgba(212,168,67,0.35);background:rgba(212,168,67,0.07);color:var(--text2);cursor:pointer;letter-spacing:0.5px;font-family:inherit;" title="Warm, intimate tone for preaching">⛪ Sermon</button>
                <button onclick="applyEqPreset('standard')"
                  style="font-size:9px;padding:3px 8px;border-radius:10px;border:1px solid rgba(212,168,67,0.35);background:rgba(212,168,67,0.07);color:var(--text2);cursor:pointer;letter-spacing:0.5px;font-family:inherit;" title="Balanced radio voice">📻 Standard</button>
                <button onclick="applyEqPreset('announce')"
                  style="font-size:9px;padding:3px 8px;border-radius:10px;border:1px solid rgba(212,168,67,0.35);background:rgba(212,168,67,0.07);color:var(--text2);cursor:pointer;letter-spacing:0.5px;font-family:inherit;" title="Crisp, cut-through clarity for announcements">📣 Announce</button>
              </div>
            </div>

            <!-- Bass -->
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
              <span style="font-size:10px;color:var(--text3);width:64px;letter-spacing:1px;text-transform:uppercase;flex-shrink:0;">🔉 Bass</span>
              <input type="range" id="live-bass-slider" min="-6" max="12" step="0.5" value="4"
                oninput="updateLiveBass(this.value);localStorage.setItem('letw_live_bass',this.value)"
                style="flex:1;accent-color:#4a9fd4;cursor:pointer;">
              <span id="live-bass-display" style="font-size:11px;color:#4a9fd4;width:36px;text-align:right;font-family:var(--mono);font-weight:700;">+4dB</span>
            </div>

            <!-- Presence (mid clarity) -->
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
              <span style="font-size:10px;color:var(--text3);width:64px;letter-spacing:1px;text-transform:uppercase;flex-shrink:0;">✨ Clarity</span>
              <input type="range" id="live-presence-slider" min="-6" max="12" step="0.5" value="5"
                oninput="updateLivePresence(this.value);localStorage.setItem('letw_live_presence',this.value)"
                style="flex:1;accent-color:#d4a843;cursor:pointer;">
              <span id="live-presence-display" style="font-size:11px;color:var(--gold);width:36px;text-align:right;font-family:var(--mono);font-weight:700;">+5dB</span>
            </div>

            <!-- Soprano / Treble / Air -->
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
              <span style="font-size:10px;color:var(--text3);width:64px;letter-spacing:1px;text-transform:uppercase;flex-shrink:0;">🎵 Treble</span>
              <input type="range" id="live-treble-slider" min="-6" max="12" step="0.5" value="3"
                oninput="updateLiveTreble(this.value);localStorage.setItem('letw_live_treble',this.value)"
                style="flex:1;accent-color:#9b6fd4;cursor:pointer;">
              <span id="live-treble-display" style="font-size:11px;color:#9b6fd4;width:36px;text-align:right;font-family:var(--mono);font-weight:700;">+3dB</span>
            </div>
            <div style="font-size:10px;color:rgba(212,168,67,0.4);margin-top:8px;line-height:1.5;">Bass = warmth &amp; body · Clarity = voice cut-through · Treble = air &amp; sparkle (soprano range)</div>
          </div>

          <!-- Noise Filter (noise gate + LPF) -->
          <div style="margin-bottom:16px;padding:12px 14px;background:rgba(76,175,130,0.05);border:1px solid rgba(76,175,130,0.2);border-radius:10px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
              <div style="font-size:11px;font-weight:700;color:var(--text);letter-spacing:0.5px;">🔕 Noise Filter</div>
              <label style="display:flex;align-items:center;gap:6px;cursor:pointer;user-select:none;">
                <input type="checkbox" id="live-noise-toggle" checked
                  onchange="toggleNoiseFilter(this.checked);localStorage.setItem('letw_live_noise_on',this.checked?'1':'0')"
                  style="accent-color:#4caf82;width:15px;height:15px;cursor:pointer;">
                <span id="live-noise-label" style="font-size:11px;color:#4caf82;font-weight:700;min-width:24px;">ON</span>
              </label>
            </div>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <span style="font-size:10px;color:var(--text3);white-space:nowrap;letter-spacing:1px;text-transform:uppercase;">Strength</span>
              <input type="range" id="live-noise-threshold" min="1" max="100" value="30"
                oninput="updateNoiseThreshold(this.value);localStorage.setItem('letw_live_noise_thresh',this.value)"
                style="flex:1;accent-color:#4caf82;cursor:pointer;">
              <span id="live-noise-level" style="font-size:11px;color:var(--text3);min-width:30px;text-align:right;font-family:var(--mono);">30%</span>
            </div>
            <div style="font-size:10px;color:rgba(76,175,130,0.55);line-height:1.5;">Blocks background noise between words. Increase strength if noise breaks through; decrease if your voice gets clipped.</div>
          </div>

          <!-- Monitor (hear yourself) -->
          <div style="margin-bottom:16px;padding:12px 14px;background:rgba(212,168,67,0.04);border:1px solid rgba(212,168,67,0.15);border-radius:10px;">
            <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
              <button id="btn-monitor" onclick="toggleMonitor()"
                style="background:rgba(255,255,255,0.05);border:1px solid rgba(212,168,67,0.3);color:var(--text2);border-radius:8px;padding:7px 14px;font-size:12px;font-weight:700;letter-spacing:0.5px;cursor:pointer;font-family:inherit;transition:all 0.2s;white-space:nowrap;">
                🎧 Monitor: OFF
              </button>
              <div style="display:flex;align-items:center;gap:8px;flex:1;min-width:120px;">
                <span style="font-size:11px;color:var(--text3);white-space:nowrap;">Vol</span>
                <input type="range" id="monitor-vol" min="0" max="100" value="80"
                  oninput="setMonitorVolume(this.value)"
                  style="flex:1;accent-color:var(--gold);cursor:pointer;">
                <span id="monitor-vol-display" style="font-size:11px;color:var(--text3);width:30px;">80%</span>
              </div>
            </div>
            <div style="font-size:10px;color:rgba(212,168,67,0.45);margin-top:8px;letter-spacing:0.3px;">
              ⚠ Use headphones when monitoring — speakers will cause feedback echo.
            </div>
          </div>

          <!-- Encoder quality selector -->
          <div style="margin-bottom:16px;padding:12px 14px;background:rgba(74,127,212,0.05);border:1px solid rgba(74,127,212,0.2);border-radius:10px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
              <div style="font-size:11px;font-weight:700;color:var(--text);letter-spacing:0.5px;">📡 Broadcast Quality</div>
              <span id="live-bitrate-label" style="font-size:11px;color:#4a9fd4;font-family:var(--mono);font-weight:700;">128 kbps</span>
            </div>
            <select class="form-control" id="live-bitrate-select" style="margin-bottom:6px;"
              onchange="document.getElementById('live-bitrate-label').textContent=this.options[this.selectedIndex].dataset.label;localStorage.setItem('letw_bitrate',this.value)">
              <option value="64000"  data-label="64 kbps" >64 kbps — Mobile (saves data)</option>
              <option value="96000"  data-label="96 kbps" >96 kbps — Standard</option>
              <option value="128000" data-label="128 kbps" selected>128 kbps — Studio (recommended)</option>
              <option value="192000" data-label="192 kbps" >192 kbps — Hi-Fi</option>
              <option value="256000" data-label="256 kbps" >256 kbps — Ultra HD</option>
            </select>
            <div style="font-size:10px;color:rgba(74,127,212,0.55);line-height:1.5;">Higher quality uses more upload bandwidth. 128 kbps gives broadcast-quality voice on most connections. Use 64 kbps on weak mobile data.</div>
          </div>

          <!-- Connection pre-check -->
          <div style="margin-bottom:14px;display:flex;align-items:center;gap:10px;">
            <button onclick="runPreBroadcastCheck()" style="font-size:11px;padding:5px 13px;border-radius:8px;border:1px solid rgba(212,168,67,0.35);background:rgba(212,168,67,0.07);color:var(--gold);cursor:pointer;font-family:inherit;font-weight:700;white-space:nowrap;transition:all 0.2s;">🔍 Check Connection</button>
            <div id="precheck-result" style="font-size:11px;color:var(--text3);"></div>
          </div>

          <!-- Go Live / Stop buttons -->
          <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <button class="btn" id="btn-go-live" onclick="startLiveBroadcast()"
              style="background:linear-gradient(135deg,#8b1a35,#e05070);color:#fff;border:none;font-weight:700;padding:12px 28px;font-size:14px;letter-spacing:1px;">
              🔴 GO LIVE
            </button>
            <button class="btn" id="btn-go-live-youtube" onclick="startYouTubeRelay()"
              style="background:linear-gradient(135deg,#c4302b,#ff5252);color:#fff;border:none;font-weight:700;padding:12px 22px;font-size:14px;letter-spacing:0.5px;"
              title="Broadcast the LETW YouTube live service to all listeners — runs on the server, works on every device">
              ▶ Stream from YouTube
            </button>
            <button class="btn" id="btn-go-live-tab" onclick="startTabBroadcast()"
              style="background:linear-gradient(135deg,#7a1fa2,#c2185b);color:#fff;border:none;font-weight:700;padding:12px 22px;font-size:14px;letter-spacing:0.5px;"
              title="Stream audio from a YouTube tab or any other browser tab to all listeners">
              📺 Stream Tab Audio
            </button>
            <button class="btn btn-secondary" id="btn-stop-live" onclick="stopLiveBroadcast()" disabled style="opacity:0.4;">
              ⏹ Stop Broadcast
            </button>
            <button class="btn btn-secondary" onclick="refreshMics()">🔄 Refresh Mics</button>
          </div>

          <!-- Server-side YouTube relay status -->
