async function loadSettings() {
  const s = await api('GET', '/settings').catch(() => window.__S || {});
  state.settings = s;
  document.getElementById('set-name').value = s.radio_name || '';
  document.getElementById('set-desc').value = s.radio_description || '';
  document.getElementById('set-genre').value = s.radio_genre || '';
  document.getElementById('set-lang').value = s.radio_language || '';
  document.getElementById('set-bitrate').value = s.stream_bitrate || '128';
  document.getElementById('set-filler').checked = s.filler_enabled === '1';

  const xfEl = document.getElementById('set-crossfade');
  const djEl  = document.getElementById('set-autodj');
  if (xfEl) { xfEl.value = s.crossfade_time || '0'; document.getElementById('crossfade-val').textContent = (s.crossfade_time||'0') + 's'; }
  if (djEl)  djEl.checked = s.auto_dj === '1';

  const base = window.location.origin;
  document.getElementById('stream-url').value = `${base}/stream`;
  document.getElementById('player-url').value = `${base}/listen`;

  document.getElementById('sidebar-radio-name').textContent = s.radio_name || 'LETW Radio';

  // App download + social links
  const wbEl = document.getElementById('set-website-url');
  const anEl = document.getElementById('set-android-url');
  const ioEl = document.getElementById('set-ios-url');
  const waEl = document.getElementById('set-whatsapp');
  if (wbEl) wbEl.value = s.website_url || '';
  if (anEl) anEl.value = s.app_store_android || '';
  if (ioEl) ioEl.value = s.app_store_ios || '';
  if (waEl) waEl.value = s.app_store_whatsapp || '';
  // Announcement modal
  const annEn   = document.getElementById('set-announce-enabled');
  const annTitle = document.getElementById('set-announce-title');
  const annBody  = document.getElementById('set-announce-body');
  if (annEn)    annEn.checked      = s.announce_modal_enabled === '1';
  if (annTitle) annTitle.value     = s.announce_modal_title || 'Hello Beloved';
  if (annBody)  annBody.value      = s.announce_modal_body  || '';
  // Tawk.to
  const twkEn = document.getElementById('set-tawkto-enabled');
  const twkId = document.getElementById('set-tawkto-id');
  if (twkEn) twkEn.checked = s.tawkto_enabled === '1';
  if (twkId) twkId.value   = s.tawkto_id || '';
  // Google Analytics
  const gaEn = document.getElementById('set-ga-enabled');
  const gaId = document.getElementById('set-ga-id');
  if (gaEn) gaEn.checked = s.ga_enabled === '1';
  if (gaId) gaId.value   = s.ga_id || '';
  // YouTube
  const ytEl = document.getElementById('set-social-youtube');
  if (ytEl) ytEl.value = s.social_youtube || 'https://www.youtube.com/watch?v=8wTuN77RZJ4';
  // YouTube live relay (server-side broadcast source)
  // Defaults to the LETW channel /live feed so it works out of the box.
  const ytRelayEl = document.getElementById('set-youtube-relay-url');
  if (ytRelayEl) ytRelayEl.value = s.youtube_relay_url || 'https://www.youtube.com/channel/UCehHnYcFV4AqGSWu29ib_Pw/live';
