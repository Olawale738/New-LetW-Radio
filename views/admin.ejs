// =================== GO LIVE — BROWSER MIC STREAMING ===================
// Captures microphone audio in the browser, encodes as WebM/Opus via
// MediaRecorder, and sends chunks to the server via Socket.IO.
// No external app (Butt, Icecast, etc.) required.

let liveMediaRecorder = null;
let liveMicStream     = null;
let liveMicAnalyser   = null;
let liveMicCtx        = null;
let liveMicRAF        = null;
let liveTimerInterval = null;
let liveGainNode      = null;   // pre-gain (main loudness)
let liveBassNode      = null;   // low-shelf EQ (bass warmth)
let livePresenceNode  = null;   // peaking EQ (voice clarity)
let _liveChunksSent   = 0;      // chunks emitted to socket since last timer tick
// Offline chunk buffer: when the admin socket is briefly disconnected during a
// live broadcast, chunks are queued here and flushed when the socket reconnects.
// Capped at MAX_OFFLINE_CHUNKS to prevent unbounded memory growth during long outages.
const MAX_OFFLINE_CHUNKS = 80;  // ~8 s of audio at 100 ms timeslice
let   _offlineChunks    = [];   // Array<ArrayBuffer>
let liveTrebleNode    = null;   // high-shelf EQ (soprano / air)
let liveNoiseGateNode = null;   // AudioWorkletNode (or ScriptProcessorNode fallback) noise gate
let liveDestStream    = null;   // processed MediaStream from MediaStreamDestination (for monitor)
let _ngUsingWorklet   = false;  // true when AudioWorklet is used instead of ScriptProcessorNode
// Noise gate state
let _ngEnabled   = true;
let _ngThreshold = 0.002;  // Pre-gain RMS threshold; raw mic voice ≈ 0.005–0.05, bg noise ≈ 0.0005–0.003
let _ngSmoothed  = 1.0;    // smoothed gate gain (avoids clicks on open/close — only used by ScriptProcessorNode fallback)
let monitorGainNode   = null;
let monitorSourceNode = null;
let monitorActive     = false;
let monitorCtx        = null;
let liveStartTime     = null;
let livePageInited    = false;

// ── Live quality / health tracking ────────────────────────────────────────────
let _livePingTimer        = null;  // setInterval for live:ping heartbeat
let _liveRtt              = null;  // last measured round-trip time (ms)
let _liveBytesFromServer  = 0;     // bytes sent, as reported back by server via live:pong
let _liveWasReconnecting  = false; // true while socket is disconnected during a live broadcast
let _liveReconnectMimeType = '';   // mimeType stored for socket reconnect
let _ytRelayLocalActive   = false; // true while THIS admin started the server-side YouTube relay

// Format byte count to a human-readable string (B / KB / MB)
function _fmtBytes(b) {
  if (b < 1024)            return b + 'B';
  if (b < 1024 * 1024)     return (b / 1024).toFixed(1) + 'KB';
  return (b / (1024 * 1024)).toFixed(2) + 'MB';
}

// Update the quality badge colour & text based on chunk rate and RTT
// Emit a live audio chunk, buffering it if the socket is temporarily disconnected.
// On reconnect, _flushOfflineChunks() drains the queue so listeners hear continuous
// audio instead of a gap.  Chunks older than the ring-buffer window are harmless
// duplicates for listeners who already received them via the server ring buffer.
function _emitLiveChunk(buf) {
  if (socket && socket.connected) {
    // Drain any buffered chunks first so order is preserved
    if (_offlineChunks.length > 0) {
      _offlineChunks.forEach(b => socket.emit('live:chunk', b));
      _offlineChunks = [];
    }
    socket.emit('live:chunk', buf);
  } else {
    // Socket momentarily offline — buffer chunk, evict oldest if over cap
    _offlineChunks.push(buf);
    if (_offlineChunks.length > MAX_OFFLINE_CHUNKS) _offlineChunks.shift();
  }
}

function _flushOfflineChunks() {
  if (_offlineChunks.length === 0) return;
  const queued = _offlineChunks.length;
  _offlineChunks.forEach(b => socket.emit('live:chunk', b));
  _offlineChunks = [];
  if (queued > 0) logActivity(`🔄 Flushed ${queued} buffered chunk${queued > 1 ? 's' : ''} after reconnect`);
}

function _updateLiveQuality(chunkRate, rtt) {
  const badge = document.getElementById('live-quality-badge');
  if (!badge) return;
  const bad = chunkRate < 4 || (rtt !== null && rtt > 600);
  const warn = chunkRate < 8 || (rtt !== null && rtt > 250);
  if (bad)  { badge.textContent = '● POOR';   badge.style.background = 'rgba(224,80,112,0.12)'; badge.style.borderColor = 'rgba(224,80,112,0.4)'; badge.style.color = '#e05070'; }
  else if (warn) { badge.textContent = '● FAIR'; badge.style.background = 'rgba(212,168,67,0.12)'; badge.style.borderColor = 'rgba(212,168,67,0.4)'; badge.style.color = '#d4a843'; }
  else           { badge.textContent = '● GOOD'; badge.style.background = 'rgba(76,175,130,0.12)'; badge.style.borderColor = 'rgba(76,175,130,0.35)'; badge.style.color = '#4caf82'; }
}

