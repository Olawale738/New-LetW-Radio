// Run 3 ping-pong cycles and return average RTT; shows result in #precheck-result
async function runPreBroadcastCheck() {
  const el = document.getElementById('precheck-result');
  if (el) { el.textContent = '⏳ Testing…'; el.style.color = 'var(--text3)'; }
  const rtts = [];
  for (let i = 0; i < 3; i++) {
    await new Promise((resolve) => {
      const ts = Date.now();
      const handler = ({ clientTs }) => { rtts.push(Date.now() - clientTs); resolve(); };
      socket.once('admin:pong', handler);
      socket.emit('admin:ping', ts);
      setTimeout(() => { socket.off('admin:pong', handler); resolve(); }, 2000);
    });
    if (i < 2) await new Promise(r => setTimeout(r, 250));
  }
  const avg = rtts.length ? Math.round(rtts.reduce((a, b) => a + b, 0) / rtts.length) : 9999;
  const grade = avg < 80 ? '⚡ Excellent — great for live streaming' : avg < 200 ? '✓ Good' : avg < 400 ? '△ Fair — may have minor audio gaps' : avg < 700 ? '⚠ Poor — expect interruptions' : '✗ Critical — do not go live on this connection';
  const color = avg < 80 ? '#4caf82' : avg < 200 ? '#8bc34a' : avg < 400 ? '#d4a843' : avg < 700 ? '#ff9800' : '#e05070';
  if (el) { el.textContent = `${avg} ms · ${grade}`; el.style.color = color; }
  return avg;
}

