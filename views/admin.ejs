                <div style="font-size:8px;color:rgba(255,255,255,0.3);letter-spacing:1px;margin-top:2px;">LATENCY</div>
              </div>
              <div style="text-align:center;padding:6px 4px;background:rgba(0,0,0,0.25);border-radius:6px;">
                <div id="live-bytes-display" style="font-size:12px;color:#d4a843;font-family:var(--mono);font-weight:700;">0B</div>
                <div style="font-size:8px;color:rgba(255,255,255,0.3);letter-spacing:1px;margin-top:2px;">SENT</div>
              </div>
              <div style="text-align:center;padding:6px 4px;background:rgba(0,0,0,0.25);border-radius:6px;">
