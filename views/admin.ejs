// =================== API HELPERS ===================
async function api(method, path, body = null) {
  const opts = { method, headers: { 'Content-Type': 'application/json' } };
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(`/api${path}`, opts);
  const data = await res.json();
  if (!res.ok) throw new Error(data.error || 'API error');
  return data;
}

// =================== STATUS ===================
function updateStatusUI(s) {
  const pill = document.getElementById('status-pill');
  // isLive covers both normal queue playback (isPlaying) and live broadcasts (isLive).
  // audioEngine.startLive() resets isPlaying=false, so we must check both flags.
  const isLive = !!(s.isPlaying || s.isLive);
  pill.className = `status-pill ${isLive ? 'live' : 'offline'}`;
  pill.innerHTML = `<div class="dot ${isLive ? 'pulse' : ''}"></div><span>${isLive ? 'LIVE' : 'Offline'}</span>`;

  document.getElementById('stat-queue').textContent = s.queueLength || 0;
  document.getElementById('listener-count').textContent = s.listeners || 0;
  document.getElementById('stat-listeners').textContent = s.listeners || 0;

  const playBtn = document.getElementById('dash-play-btn');
  const sideBtn = document.getElementById('btn-play-stop');
  if (isLive) {
    playBtn.textContent = '⏹ Stop Radio';
    playBtn.onclick = stopRadio;
    sideBtn.textContent = '⏹';
    sideBtn.classList.add('active');
    document.getElementById('eq-bars').classList.remove('paused');
  } else {
    playBtn.textContent = '▶ Start Radio';
    playBtn.onclick = playRadio;
    sideBtn.textContent = '▶';
    sideBtn.classList.remove('active');
    document.getElementById('eq-bars').classList.add('paused');
  }

  if (s.currentTrack) {
    updateNowPlaying(s.currentTrack);
    if (s.startTime && !state.progressInterval) {
      state.trackStartTime = s.startTime;
      state.trackDuration = (s.currentTrack.duration || 0) * 1000;
      startProgressUpdate();
    }
  }
}

function updateNowPlaying(track) {
  if (!track) return;
  const title = track.title || 'Unknown';
  const artist = track.artist || 'Unknown Artist';
  document.getElementById('np-track').textContent = title;
  document.getElementById('np-artist').textContent = artist;
  document.getElementById('snp-track').textContent = title;
  document.getElementById('snp-artist').textContent = artist;
  document.getElementById('np-duration').textContent = formatDuration(track.duration || 0);
  document.getElementById('np-bitrate').textContent = `${track.bitrate || 128}kbps`;
}

function startProgressUpdate() {
  if (state.progressInterval) clearInterval(state.progressInterval);
  state.progressInterval = setInterval(() => {
    if (!state.trackStartTime || !state.trackDuration) return;
    const elapsed = Date.now() - state.trackStartTime;
    const pct = Math.min(100, (elapsed / state.trackDuration) * 100);
    document.getElementById('progress-fill').style.width = pct + '%';
    if (pct >= 100) clearInterval(state.progressInterval);
  }, 1000);
}

