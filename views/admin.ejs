async function refreshMics() {
  try {
    // Request permission first so deviceId labels are populated
    const tmp = await navigator.mediaDevices.getUserMedia({ audio: true });
    tmp.getTracks().forEach(t => t.stop());

    const devices = await navigator.mediaDevices.enumerateDevices();
    const mics = devices.filter(d => d.kind === 'audioinput');
    const sel = document.getElementById('live-mic-select');
    sel.innerHTML = mics.map((d, i) =>
      `<option value="${d.deviceId}">${d.label || ('Microphone ' + (i+1))}</option>`
    ).join('');
  } catch (err) {
    alert('Microphone permission denied or not available.\n\n' + err.message);
  }
}

async function startLiveBroadcast() {
  const title  = document.getElementById('live-title').value.trim()  || 'Live Broadcast';
  const artist = document.getElementById('live-artist').value.trim() || 'Light Encounter Tabernacle Worldwide';
  const micId  = document.getElementById('live-mic-select').value;

  if (!micId) { alert('Please select a microphone first.'); return; }

  // Pre-broadcast connection quality check
  const preRtt = await runPreBroadcastCheck();
  if (preRtt > 700) {
    const ok = confirm(`⚠ Connection quality is CRITICAL (${preRtt} ms latency).\n\nListeners will likely hear constant interruptions. It is strongly recommended to fix your internet connection first.\n\nGo live anyway?`);
    if (!ok) return;
  } else if (preRtt > 400) {
    const ok = confirm(`⚠ Connection quality is POOR (${preRtt} ms latency).\n\nListeners may experience some audio gaps. Continue?`);
    if (!ok) return;
  }

  try {
    liveMicStream = await navigator.mediaDevices.getUserMedia({
      audio: {
        deviceId:                 micId ? { exact: micId } : undefined,
        echoCancellation:         true,   // browser AEC removes speaker echo
        noiseSuppression:         true,   // browser NS removes background noise
        autoGainControl:          false,  // we apply our own gain via GainNode
        suppressLocalAudioPlayback: true, // Chrome 113+: excludes local playback from mic
        channelCount:             1,      // mono — voice only needs one channel
        sampleRate:               48000,  // 48 kHz: broadcast standard, best Opus quality
        // NOTE: do NOT set latency:0 here — it shrinks the AEC processing window
        // and degrades echo cancellation. Let the browser choose its own latency.
      }
    });
  } catch (err) {
    // Fallback: retry without advanced constraints (some older browsers reject them)
    try {
      liveMicStream = await navigator.mediaDevices.getUserMedia({
        audio: {
          deviceId:         micId ? { exact: micId } : undefined,
          echoCancellation: true,
          noiseSuppression: true,
        }
      });
    } catch (err2) {
      alert('Could not access microphone:\n' + (err2.message || err.message));
      return;
    }
  }

  // ── Audio processing chain ────────────────────────────────────────────────────
  // mic → HPF → Presence EQ → LPF → Gain → Compressor → Limiter → Gate → Analyser → out
  //
  // HPF removes low-end rumble; Presence EQ adds voice clarity at 2.8 kHz;
  // LPF is raised to 14 kHz so consonants (S, T, F) are fully preserved;
  // Gain gives the volume boost; Compressor+Limiter keep level consistent
  // and prevent clipping; Gate cuts dead-air noise between words.
  liveMicCtx = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: 48000 });
  if (liveMicCtx.state === 'suspended') await liveMicCtx.resume();

  const src = liveMicCtx.createMediaStreamSource(liveMicStream);

  // 1. High-pass filter — kill rumble, A/C hum, mic handling noise below 100 Hz
  const hpf           = liveMicCtx.createBiquadFilter();
  hpf.type            = 'highpass';
  hpf.frequency.value = 100;  // slightly raised for cleaner radio voice
  hpf.Q.value         = 0.65;

  // 2. Bass boost — low-shelf at 100 Hz, adds warmth and body to voice
  liveBassNode = liveMicCtx.createBiquadFilter();
  liveBassNode.type            = 'lowshelf';
  liveBassNode.frequency.value = 100;
  const bassSlider = document.getElementById('live-bass-slider');
  liveBassNode.gain.value = bassSlider ? parseFloat(bassSlider.value) : 4;

  // 3. Presence / clarity boost — peaking EQ at 2800 Hz
  //    The "radio voice" frequency: makes speech intelligible and cuts through
  livePresenceNode = liveMicCtx.createBiquadFilter();
  livePresenceNode.type            = 'peaking';
  livePresenceNode.frequency.value = 2800;
  livePresenceNode.Q.value         = 0.8;
  const presSlider = document.getElementById('live-presence-slider');
  livePresenceNode.gain.value = presSlider ? parseFloat(presSlider.value) : 5;

  // 4. Treble / Soprano — high-shelf at 8 kHz, adds air, sparkle, and consonant brightness
  liveTrebleNode = liveMicCtx.createBiquadFilter();
  liveTrebleNode.type            = 'highshelf';
  liveTrebleNode.frequency.value = 8000;
  const trebSlider = document.getElementById('live-treble-slider');
  liveTrebleNode.gain.value = trebSlider ? parseFloat(trebSlider.value) : 3;

  // 5. Low-pass filter — gentle ceiling at 18 kHz removes only extreme hiss
  const lpf           = liveMicCtx.createBiquadFilter();
  lpf.type            = 'lowpass';
  lpf.frequency.value = 18000;
  lpf.Q.value         = 0.5;

  // 6. Pre-gain — main loudness control; default 8× (800%)
  liveGainNode = liveMicCtx.createGain();
  const gainSlider = document.getElementById('live-gain-slider');
  liveGainNode.gain.value = gainSlider ? parseFloat(gainSlider.value) : 8;

  // 7. Broadcast compressor — levels out soft and loud speech for consistent loudness
  const comp           = liveMicCtx.createDynamicsCompressor();
  comp.threshold.value = -18;   // start compressing at -18 dBFS
  comp.knee.value      = 4;     // tight knee for firm, consistent output
  comp.ratio.value     = 6;     // 6:1 — strong but not squashed
  comp.attack.value    = 0.003; // 3 ms
  comp.release.value   = 0.10;  // 100 ms — fast recovery keeps every word loud

  // 8. Makeup gain — compensates for the level reduction caused by compression.
  //    Without this the compressed signal is quieter than the raw mic input.
  //    +8 dB (≈ 2.5×) brings it back to a full, hot broadcast level.
  const makeupGain       = liveMicCtx.createGain();
  makeupGain.gain.value  = 2.5; // +8 dB makeup

  // 9. Output limiter — hard ceiling at –0.5 dB, prevents any clipping reaching the encoder
  const limiter           = liveMicCtx.createDynamicsCompressor();
  limiter.threshold.value = -0.5;
  limiter.knee.value      = 0;    // brickwall
  limiter.ratio.value     = 20;   // ≈ hard limit
  limiter.attack.value    = 0.001;// 1 ms
  limiter.release.value   = 0.04;

  // 7. Noise gate — AudioWorklet (preferred) or ScriptProcessorNode fallback
  //
  //    WHY AUDIOWORKLET?
  //    ScriptProcessorNode has 2048-sample buffer = 42.7 ms of variable latency.
  //    The browser's AEC (echoCancellation) needs to know the exact latency to
  //    subtract the speaker echo from the mic. Variable latency confuses AEC →
  //    echo slips through. AudioWorklet runs in 128-sample frames (2.67 ms) with
  //    DETERMINISTIC latency, so AEC works correctly and echo is eliminated.
  //
  //    Gate is placed BEFORE the gain: operates on quiet raw mic (RMS ≈0.001–0.005)
  //    not amplified signal (RMS ≈0.008–0.040). This prevents cricket chirping.

  const noiseChk = document.getElementById('live-noise-toggle');
  const noiseSld = document.getElementById('live-noise-threshold');
  _ngEnabled   = noiseChk ? noiseChk.checked : true;
  // Pre-gain scale: raw mic RMS ≈ 0.001–0.006, so 30 on slider → ~0.0018 threshold
  _ngThreshold = noiseSld ? (parseInt(noiseSld.value) / 100) * 0.006 : 0.002;

  // AudioWorklet code embedded as Blob URL — no extra server file needed
  const _GATE_CODE = `
class NoiseGateProcessor extends AudioWorkletProcessor {
  constructor(opts) {
    super(opts);
    this._s = 1; this._hc = 0; this._en = true; this._thr = 0.002;
    this.port.onmessage = ({ data: d }) => {
      if (d.enabled   !== undefined) this._en  = !!d.enabled;
      if (d.threshold !== undefined) this._thr = +d.threshold;
    };
  }
  process(inputs, outputs) {
    const i = inputs[0]?.[0], o = outputs[0]?.[0];
    if (!i || !o || !i.length) return true;
    let sq = 0;
    for (let n = 0; n < i.length; n++) sq += i[n] * i[n];
    const rms = Math.sqrt(sq / i.length);
    let tgt;
    if (!this._en)         { tgt = 1; this._hc = 0; }
    else if (rms > this._thr) { tgt = 1; this._hc = 20; }
    else if (this._hc > 0)    { tgt = 1; this._hc--; }
    else                       { tgt = 0; }
    this._s += tgt > this._s ? 0.4 * (tgt - this._s) : 0.008 * (tgt - this._s);
    for (let n = 0; n < o.length; n++) o[n] = i[n] * this._s;
    return true;
  }
}
registerProcessor('letw-noise-gate', NoiseGateProcessor);
`;
  _ngUsingWorklet = false;
  try {
    const _blob = new Blob([_GATE_CODE], { type: 'application/javascript' });
    const _burl = URL.createObjectURL(_blob);
    await liveMicCtx.audioWorklet.addModule(_burl);
    URL.revokeObjectURL(_burl);
    liveNoiseGateNode = new AudioWorkletNode(liveMicCtx, 'letw-noise-gate');
    liveNoiseGateNode.port.postMessage({ enabled: _ngEnabled, threshold: _ngThreshold });
    _ngUsingWorklet = true;
  } catch (_awErr) {
    // Fallback: ScriptProcessorNode (older browsers)
    console.warn('[NoiseGate] AudioWorklet unavailable, using ScriptProcessorNode fallback:', _awErr.message);
    _ngSmoothed = 1.0;
    let _ngHoldCount = 0;
    liveNoiseGateNode = liveMicCtx.createScriptProcessor(512, 1, 1); // 512 instead of 2048 — less latency
    liveNoiseGateNode.onaudioprocess = (evt) => {
      const inp = evt.inputBuffer.getChannelData(0);
      const out = evt.outputBuffer.getChannelData(0);
      let sq = 0;
      for (let i = 0; i < inp.length; i++) sq += inp[i] * inp[i];
      const rms = Math.sqrt(sq / inp.length);
      let target;
      if (!_ngEnabled)           { target = 1.0; _ngHoldCount = 0; }
      else if (rms > _ngThreshold) { target = 1.0; _ngHoldCount = 20; }
      else if (_ngHoldCount > 0)   { target = 1.0; _ngHoldCount--; }
      else                          { target = 0.0; }
      _ngSmoothed += target > _ngSmoothed
        ? 0.40 * (target - _ngSmoothed)
        : 0.008 * (target - _ngSmoothed);
      for (let i = 0; i < out.length; i++) out[i] = inp[i] * _ngSmoothed;
    };
    _ngUsingWorklet = false;
  }

  // 8. Analyser — drives the level meter; reads post-compression/post-limiter
  liveMicAnalyser         = liveMicCtx.createAnalyser();
  liveMicAnalyser.fftSize = 256;

  // 9. MediaStreamDestination — captures processed audio for MediaRecorder
  const dest = liveMicCtx.createMediaStreamDestination();
  liveDestStream = dest.stream;  // store so monitor can play processed audio (not raw mic)

  // Wire: mic → HPF → Gate(raw) → Bass → Presence → Treble → LPF → Gain → Comp → MakeupGain → Limiter → Analyser → out
  // Gate is BEFORE gain: it sees the quiet raw signal, not the amplified one.
  // This eliminates the cricket/chirping that happened when amplified room noise
  // bounced against the gate threshold.
  src.connect(hpf);
  hpf.connect(liveNoiseGateNode);        // ← gate on raw signal
  liveNoiseGateNode.connect(liveBassNode);
  liveBassNode.connect(livePresenceNode);
  livePresenceNode.connect(liveTrebleNode);
  liveTrebleNode.connect(lpf);
  lpf.connect(liveGainNode);             // ← then amplify
  liveGainNode.connect(comp);
  comp.connect(makeupGain);
  makeupGain.connect(limiter);
  limiter.connect(liveMicAnalyser);      // ← analyser after final limiting
  liveMicAnalyser.connect(dest);

  animateMicLevel();

  // ── MediaRecorder ─────────────────────────────────────────────────────────
  // Prefer Opus codec — quality controlled by the admin's bitrate selector
  const mimeType = ['audio/webm;codecs=opus','audio/webm','audio/ogg;codecs=opus','audio/ogg']
    .find(m => MediaRecorder.isTypeSupported(m)) || '';
  const bitrateEl = document.getElementById('live-bitrate-select');
  const audioBitsPerSecond = bitrateEl ? parseInt(bitrateEl.value, 10) : 128000;

  liveMediaRecorder = new MediaRecorder(dest.stream, {
    mimeType,
    audioBitsPerSecond,
  });
  logActivity(`🎚 Encoding at ${Math.round(audioBitsPerSecond / 1000)} kbps Opus`);

  liveMediaRecorder.addEventListener('dataavailable', e => {
    if (e.data && e.data.size > 0) {
      _liveChunksSent++;
      e.data.arrayBuffer().then(buf => {
        _emitLiveChunk(buf);
      });
    }
  });

  // Store mimeType for potential socket-reconnect re-announce
  _liveReconnectMimeType = mimeType;
  _liveWasReconnecting   = false;
  _liveRtt               = null;
  _liveBytesFromServer   = 0;

  // Send the admin token so server accepts live events
  socket.auth = { token: getAdminToken() };
  const recordCheck = document.getElementById('live-record-check');
  socket.emit('live:start', { title, artist, record: recordCheck ? recordCheck.checked : false, mimeType });

  liveMediaRecorder.start(60); // 60 ms timeslice — ~40% lower end-to-end latency vs 100 ms
  // Note: going below 60 ms risks producing WebM clusters that Chrome can't
  // decode in real time; 60 ms is the practical minimum for Opus in WebM.

  // UI: on-air state
  setLiveUIState(true);
  liveStartTime = Date.now();
  liveTimerInterval = setInterval(updateLiveTimer, 1000);
}

// ════════════════════════════════════════════════════════════════════════════
// STREAM BROWSER TAB AUDIO (YouTube etc.) → all public listeners
// Reuses the exact same socket pipeline as the mic broadcast (live:start /
// live:chunk / live:stop) so the server needs no changes.  The audio chain is
// MUSIC-optimised (stereo, no noise gate, no voice EQ) instead of voice-optimised.
// Capture uses getDisplayMedia with "share tab audio"; Chrome / Edge desktop only.
// ════════════════════════════════════════════════════════════════════════════
// Detect the LETW desktop app wrapper (Electron / Nativefier), where the browser
// getDisplayMedia tab-picker is unavailable. In that context we steer the admin
// to the server-side YouTube relay, which needs no tab capture.
function _isDesktopApp() {
  try { return /electron|nativefier|letw-radio-admin-desktop/i.test(navigator.userAgent || ''); }
  catch { return false; }
}

async function startTabBroadcast() {
  // Guard: refuse if a broadcast (mic or tab) is already running
  if (liveMediaRecorder && liveMediaRecorder.state !== 'inactive') {
    alert('A broadcast is already live. Stop it first before starting another.');
    return;
  }
  // Desktop app / unsupported browser → offer the server-side relay instead of
  // dead-ending with "Not supported".
  if (!navigator.mediaDevices || !navigator.mediaDevices.getDisplayMedia || _isDesktopApp()) {
    if (confirm('📺 Tab-audio capture is not available in the desktop app.\n\nUse “▶ Stream from YouTube” instead — it broadcasts the LETW YouTube service to all listeners directly from the server, and works on every device.\n\nStart the YouTube relay now?')) {
      startYouTubeRelay();
    }
    return;
  }

  const title  = document.getElementById('live-title').value.trim()  || 'Live Broadcast';
  const artist = document.getElementById('live-artist').value.trim() || 'Light Encounter Tabernacle Worldwide';

  let captureStream;
  try {
    // video:true is REQUIRED for the browser to offer the "share tab audio" option.
    // We discard the video track immediately and only stream the audio.
    captureStream = await navigator.mediaDevices.getDisplayMedia({
      video: true,
      audio: {
        echoCancellation: false,  // music — keep the audio pristine
        noiseSuppression: false,
        autoGainControl:  false,
      },
    });
  } catch (err) {
    // User cancelled the picker, or permission denied — not a real error
    if (err && err.name === 'NotAllowedError') { logActivity('📺 Tab capture cancelled'); return; }
    // Desktop webviews throw NotSupportedError / "Not supported" — offer the relay.
    if (err && (err.name === 'NotSupportedError' || /not supported/i.test(err.message || ''))) {
      if (confirm('📺 Tab-audio capture is not supported here (this is usually the desktop app).\n\nUse the server-side “▶ Stream from YouTube” relay instead? It works on every device.\n\nStart it now?')) {
        startYouTubeRelay();
      }
      return;
    }
    alert('Could not capture tab audio:\n' + (err.message || err.name || 'unknown error'));
    return;
  }

  // Drop the video track — we only need audio
  captureStream.getVideoTracks().forEach(t => t.stop());

  const audioTracks = captureStream.getAudioTracks();
  if (audioTracks.length === 0) {
    captureStream.getTracks().forEach(t => t.stop());
    alert('No tab audio was shared.\n\nWhen the picker appears you must:\n1. Choose the "Chrome Tab" option\n2. Select your YouTube tab\n3. Tick the "Share tab audio" checkbox (bottom-left)\n\nThen try again.');
    return;
  }

  // Store in the same vars the mic path uses so stopLiveBroadcast(), the reconnect
  // handler, the monitor, and the level meter all work unchanged.
  liveMicStream = captureStream;

  // ── Music-optimised audio chain: source → gain → limiter → analyser → dest ──
  liveMicCtx = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: 48000 });
  if (liveMicCtx.state === 'suspended') await liveMicCtx.resume();

  const src = liveMicCtx.createMediaStreamSource(captureStream);

  // Gain — default 1.0 (100%); YouTube audio is already at full level.
  // Tied to liveGainNode so the existing gain slider can still nudge it if needed.
  liveGainNode = liveMicCtx.createGain();
  liveGainNode.gain.value = 1.0;

  // Safety limiter — brickwall at -0.5 dB so a loud track can never clip the encoder
  const limiter           = liveMicCtx.createDynamicsCompressor();
  limiter.threshold.value = -0.5;
  limiter.knee.value      = 0;
  limiter.ratio.value     = 20;
  limiter.attack.value    = 0.001;
  limiter.release.value   = 0.05;

  liveMicAnalyser         = liveMicCtx.createAnalyser();
  liveMicAnalyser.fftSize = 256;

  const dest = liveMicCtx.createMediaStreamDestination();
  liveDestStream = dest.stream;

  src.connect(liveGainNode);
  liveGainNode.connect(limiter);
  limiter.connect(liveMicAnalyser);
  liveMicAnalyser.connect(dest);

  animateMicLevel();

  // ── MediaRecorder — identical to the mic path so the server flow is unchanged ──
  const mimeType = ['audio/webm;codecs=opus','audio/webm','audio/ogg;codecs=opus','audio/ogg']
    .find(m => MediaRecorder.isTypeSupported(m)) || '';
  const tabBitrateEl = document.getElementById('live-bitrate-select');
  const audioBitsPerSecond = tabBitrateEl ? parseInt(tabBitrateEl.value, 10) : 128000;

  liveMediaRecorder = new MediaRecorder(dest.stream, {
    mimeType,
    audioBitsPerSecond,
  });
  logActivity(`🎚 Tab audio encoding at ${Math.round(audioBitsPerSecond / 1000)} kbps Opus`);

  liveMediaRecorder.addEventListener('dataavailable', e => {
    if (e.data && e.data.size > 0) {
      _liveChunksSent++;
      e.data.arrayBuffer().then(buf => { _emitLiveChunk(buf); });
    }
  });

  _liveReconnectMimeType = mimeType;
  _liveWasReconnecting   = false;
  _liveRtt               = null;
  _liveBytesFromServer   = 0;

  // If the user clicks the browser's native "Stop sharing" bar, end cleanly.
  audioTracks[0].addEventListener('ended', () => {
    if (liveMediaRecorder && liveMediaRecorder.state !== 'inactive') {
      logActivity('📺 Tab sharing stopped by browser — ending broadcast');
      stopLiveBroadcast();
    }
  });

  socket.auth = { token: getAdminToken() };
  const recordCheck = document.getElementById('live-record-check');
  socket.emit('live:start', { title, artist, record: recordCheck ? recordCheck.checked : false, mimeType });

  liveMediaRecorder.start(60);

  setLiveUIState(true);
  liveStartTime = Date.now();
  liveTimerInterval = setInterval(updateLiveTimer, 1000);
  logActivity('📺 Streaming tab audio live: "' + title + '"');
}

// ════════════════════════════════════════════════════════════════════════════
// STREAM FROM YOUTUBE (server-side relay) → all public listeners
// The server pulls + re-streams the YouTube audio, so this works from ANY admin
// device — including the desktop app and phones where tab-capture is unavailable.
// No MediaRecorder / AudioContext here: the relay produces the live feed itself.
// ════════════════════════════════════════════════════════════════════════════
async function startYouTubeRelay() {
  if (liveMediaRecorder && liveMediaRecorder.state !== 'inactive') {
    alert('A broadcast is already live. Stop it first before starting another.');
    return;
  }
  const relayUrl = (window.__S && window.__S.youtube_relay_url || '').trim();

  const statusEl  = document.getElementById('yt-relay-status');
  const statusTxt = document.getElementById('yt-relay-status-text');
  if (statusEl)  statusEl.style.display = 'block';
  if (statusTxt) statusTxt.textContent = '📡 Connecting to YouTube…';

  const title = document.getElementById('live-title').value.trim() || '';
  try {
    // Send the cached URL if we have one; the server falls back to the saved
    // setting (single source of truth) when the body URL is empty.
    await api('POST', '/youtube/start', { url: relayUrl, title });
    _ytRelayLocalActive = true;
    setLiveUIState(true);                      // server will also emit live:started
    liveStartTime = Date.now();
    if (liveTimerInterval) clearInterval(liveTimerInterval);
    liveTimerInterval = setInterval(updateLiveTimer, 1000);
    logActivity('▶ Streaming from YouTube (server relay)' + (relayUrl ? ': ' + relayUrl : ''));
    if (statusTxt) statusTxt.textContent = '📡 Relay armed — fetching audio from YouTube…';
  } catch (e) {
    if (statusEl) statusEl.style.display = 'none';
    const msg = e.message || String(e);
    if (/no youtube|url set|settings/i.test(msg)) {
      alert('No LETW YouTube URL is set yet.\n\nGo to Settings → 📡 LETW YouTube Live Relay, paste your channel /live URL (or a video link), Save, then try again.');
      navigate('settings');
      return;
    }
    alert('Could not start YouTube relay:\n' + msg);
  }
}

async function stopYouTubeRelay() {
  try { await api('POST', '/youtube/stop'); } catch (e) {}
  _ytRelayLocalActive = false;
  const statusEl = document.getElementById('yt-relay-status');
  if (statusEl) statusEl.style.display = 'none';
  if (liveTimerInterval) { clearInterval(liveTimerInterval); liveTimerInterval = null; }
  setLiveUIState(false);
  logActivity('⏹ Stopped YouTube relay');
}

function stopLiveBroadcast() {
  // If the server-side YouTube relay is the active source, stop it via the API.
  if (_ytRelayLocalActive) { stopYouTubeRelay(); return; }

  if (liveMediaRecorder && liveMediaRecorder.state !== 'inactive') {
    liveMediaRecorder.stop();
  }
  liveMediaRecorder = null;

  if (liveMicStream) {
    liveMicStream.getTracks().forEach(t => t.stop());
    liveMicStream = null;
  }

  if (liveMicCtx) { liveMicCtx.close(); liveMicCtx = null; }
  liveGainNode      = null;
  liveBassNode      = null;
  livePresenceNode  = null;
  liveTrebleNode    = null;
  liveNoiseGateNode = null;
  liveDestStream    = null;
  _ngUsingWorklet   = false;
  if (liveMicRAF) { cancelAnimationFrame(liveMicRAF); liveMicRAF = null; }
  if (liveTimerInterval) { clearInterval(liveTimerInterval); liveTimerInterval = null; }

  document.getElementById('mic-level-bar').style.width = '0%';
  document.getElementById('mic-peak-label').textContent = '—';
  _liveChunksSent      = 0;
  _offlineChunks       = [];  // discard buffered chunks — broadcast is over
  _liveRtt             = null;
  _liveBytesFromServer = 0;
  _liveWasReconnecting = false;

  if (_livePingTimer) { clearInterval(_livePingTimer); _livePingTimer = null; }

  socket.auth = { token: getAdminToken() };
  socket.emit('live:stop');

  setLiveUIState(false);
  // Stop monitor when broadcast stops
  if (monitorActive) stopMonitor();
}

// ── Live gain control ─────────────────────────────────────────────────────────
function updateLiveGain(val) {
  const pct = Math.round(parseFloat(val) * 100);
  const display = document.getElementById('live-gain-display');
  if (display) display.textContent = pct + '%';
  if (liveGainNode) liveGainNode.gain.value = parseFloat(val);
}

// ── EQ controls ───────────────────────────────────────────────────────────────
function updateLiveBass(val) {
  const db = parseFloat(val);
  const display = document.getElementById('live-bass-display');
  if (display) display.textContent = (db >= 0 ? '+' : '') + db + 'dB';
  if (liveBassNode) liveBassNode.gain.value = db;
}

function updateLivePresence(val) {
  const db = parseFloat(val);
  const display = document.getElementById('live-presence-display');
  if (display) display.textContent = (db >= 0 ? '+' : '') + db + 'dB';
  if (livePresenceNode) livePresenceNode.gain.value = db;
}

function updateLiveTreble(val) {
  const db = parseFloat(val);
  const display = document.getElementById('live-treble-display');
  if (display) display.textContent = (db >= 0 ? '+' : '') + db + 'dB';
  if (liveTrebleNode) liveTrebleNode.gain.value = db;
}

// ── Noise filter controls ─────────────────────────────────────────────────────
function toggleNoiseFilter(enabled) {
  _ngEnabled = !!enabled;
  // Propagate to AudioWorklet via message port (or ScriptProcessorNode reads _ngEnabled directly)
  if (_ngUsingWorklet && liveNoiseGateNode && liveNoiseGateNode.port) {
    liveNoiseGateNode.port.postMessage({ enabled: _ngEnabled });
  }
  const label = document.getElementById('live-noise-label');
  if (label) {
    label.textContent = _ngEnabled ? 'ON' : 'OFF';
    label.style.color = _ngEnabled ? '#4caf82' : 'var(--text3)';
  }
}

function updateNoiseThreshold(val) {
  // Pre-gain scale: raw mic RMS ≈ 0.001–0.006, so 1–100 maps to 0.00006–0.006
  _ngThreshold = (parseInt(val) / 100) * 0.006;
  if (_ngUsingWorklet && liveNoiseGateNode && liveNoiseGateNode.port) {
    liveNoiseGateNode.port.postMessage({ threshold: _ngThreshold });
  }
  const display = document.getElementById('live-noise-level');
  if (display) display.textContent = val + '%';
}

// ── Monitor (hear yourself while live) ───────────────────────────────────────
async function toggleMonitor() {
  if (monitorActive) {
    stopMonitor();
  } else {
    await startMonitor();
  }
}

async function startMonitor() {
  try {
    // When live, monitor plays the PROCESSED audio (dest.stream = what listeners hear).
    // This is critical for two reasons:
    //   1. Admin hears exactly what listeners hear (processed, EQ'd, limited).
    //   2. The browser's AEC reference is the processed stream — NOT the raw mic — so
    //      the AEC can properly subtract speaker output from the mic signal.
    //      Playing raw liveMicStream to speakers creates a self-referential loop that
    //      confuses AEC and causes repetitive echo artifacts.
    //
    // When not live, we fall back to opening a raw mic stream for preview.
    let stream = liveDestStream || liveMicStream;
    if (!stream) {
      const micId = document.getElementById('live-mic-select').value;
      if (!micId) { alert('Select a microphone first.'); return; }
      stream = await navigator.mediaDevices.getUserMedia({
        audio: { deviceId: { exact: micId }, echoCancellation: true, noiseSuppression: true }
      });
      monitorCtx = stream; // store so we can stop these tracks on monitor off
    }

    const ctx = liveMicCtx || new (window.AudioContext || window.webkitAudioContext)();
    if (!liveMicCtx) liveMicCtx = ctx;
    if (ctx.state === 'suspended') await ctx.resume();

    monitorSourceNode = ctx.createMediaStreamSource(stream);
    monitorGainNode   = ctx.createGain();
    const vol = parseInt(document.getElementById('monitor-vol').value, 10) / 100;
    monitorGainNode.gain.value = vol;
    monitorSourceNode.connect(monitorGainNode);
    monitorGainNode.connect(ctx.destination);

    monitorActive = true;
    const btn = document.getElementById('btn-monitor');
    btn.textContent = '🎧 Monitor: ON';
    btn.style.background    = 'rgba(212,168,67,0.15)';
    btn.style.borderColor   = 'rgba(212,168,67,0.6)';
    btn.style.color         = 'var(--gold)';
  } catch(e) {
    alert('Could not start monitor: ' + e.message);
  }
}

function stopMonitor() {
  if (monitorSourceNode) { try { monitorSourceNode.disconnect(); } catch(e) {} monitorSourceNode = null; }
  if (monitorGainNode)   { try { monitorGainNode.disconnect(); }   catch(e) {} monitorGainNode = null; }
  // If we opened a dedicated monitor stream (not the live stream), close it
  if (monitorCtx && monitorCtx !== liveMicStream) {
    monitorCtx.getTracks && monitorCtx.getTracks().forEach(t => t.stop());
  }
  monitorCtx    = null;
  monitorActive = false;
  const btn = document.getElementById('btn-monitor');
  btn.textContent = '🎧 Monitor: OFF';
  btn.style.background  = 'rgba(255,255,255,0.05)';
  btn.style.borderColor = 'rgba(212,168,67,0.3)';
  btn.style.color       = 'var(--text2)';
}

function setMonitorVolume(val) {
  document.getElementById('monitor-vol-display').textContent = val + '%';
  if (monitorGainNode) monitorGainNode.gain.value = parseInt(val, 10) / 100;
}

function animateMicLevel() {
  liveMicRAF = requestAnimationFrame(animateMicLevel);
  if (!liveMicAnalyser) return;

  const freqData = new Uint8Array(liveMicAnalyser.frequencyBinCount);
  liveMicAnalyser.getByteFrequencyData(freqData);

  // Use RMS of time-domain signal for a truer VU reading + peak hold for visuals
  const timeData = new Uint8Array(liveMicAnalyser.fftSize);
  liveMicAnalyser.getByteTimeDomainData(timeData);
  let sq = 0;
  let peak = 0;
  for (let i = 0; i < timeData.length; i++) {
    const s = (timeData[i] - 128) / 128;  // -1 … +1
    sq += s * s;
    if (Math.abs(s) > peak) peak = Math.abs(s);
  }
  const rms  = Math.sqrt(sq / timeData.length);
  const pct  = Math.min(100, rms * 300);  // scale: full voice ≈ 100%
  const pkPct = Math.min(100, peak * 100);

  const bar = document.getElementById('mic-level-bar');
  if (bar) {
    bar.style.width = pct + '%';
    // Colour-code: green (safe) → amber (hot) → red (clipping)
    if (pkPct > 95) {
      bar.style.background = 'linear-gradient(90deg,#ff2050,#ff0030)'; // clipping
    } else if (pkPct > 75) {
      bar.style.background = 'linear-gradient(90deg,#4caf82,#d4a843,#e05070)'; // hot
    } else {
      bar.style.background = 'linear-gradient(90deg,#4caf82,#7ecf90)'; // safe
    }
  }

  // Clip indicator flash
  const clipEl = document.getElementById('mic-clip-indicator');
  if (clipEl) {
    if (pkPct > 95) {
      clipEl.style.opacity = '1';
      clearTimeout(clipEl._hideTO);
      clipEl._hideTO = setTimeout(() => { clipEl.style.opacity = '0'; }, 300);
    }
  }

  // Peak percentage label
  const peakLabel = document.getElementById('mic-peak-label');
  if (peakLabel) peakLabel.textContent = Math.round(pkPct) + '%';
}

function updateLiveTimer() {
  if (!liveStartTime) return;
  const elapsed = Math.floor((Date.now() - liveStartTime) / 1000);
  const h = String(Math.floor(elapsed / 3600)).padStart(2,'0');
  const m = String(Math.floor((elapsed % 3600) / 60)).padStart(2,'0');
  const s = String(elapsed % 60).padStart(2,'0');
  document.getElementById('live-timer').textContent = `${h}:${m}:${s}`;

  // Chunks-per-second (how many MediaRecorder slices were emitted last second)
  const rate = _liveChunksSent;
  _liveChunksSent = 0;   // reset for next second

  const rateEl = document.getElementById('live-chunk-rate');
  if (rateEl) {
    const color = rate >= 8 ? '#4caf82' : rate >= 4 ? '#d4a843' : '#e05070';
    rateEl.style.color = color;
    rateEl.textContent = rate + '/s';
  }

  // Bytes sent — updated live via live:pong; fall back to local estimate
  const bytesEl = document.getElementById('live-bytes-display');
  if (bytesEl && _liveBytesFromServer > 0) {
    bytesEl.textContent = _fmtBytes(_liveBytesFromServer);
  }

  // Update quality badge every second
  _updateLiveQuality(rate, _liveRtt);

  // Send heartbeat ping to server every 5th tick
  if (elapsed % 5 === 0 && liveMediaRecorder) {
    socket.emit('live:ping', Date.now());
  }
}

function setLiveUIState(on) {
  const chip       = document.getElementById('live-status-chip');
  const btnGo      = document.getElementById('btn-go-live');
  const btnGoTab   = document.getElementById('btn-go-live-tab');
  const btnGoYt    = document.getElementById('btn-go-live-youtube');
  const btnStop    = document.getElementById('btn-stop-live');
  const timerWrap  = document.getElementById('live-timer-wrap');
  const navDot     = document.getElementById('live-nav-dot');

  if (on) {
    chip.textContent = '● ON AIR';
    chip.style.background = 'rgba(224,80,112,0.18)';
    chip.style.borderColor = 'rgba(224,80,112,0.55)';
    chip.style.color = '#ff6b8a';
    chip.classList.add('live-status-chip-on');
    btnGo.disabled  = true;
    btnGo.style.opacity = '0.4';
    if (btnGoTab) { btnGoTab.disabled = true; btnGoTab.style.opacity = '0.4'; }
    if (btnGoYt)  { btnGoYt.disabled  = true; btnGoYt.style.opacity  = '0.4'; }
    btnStop.disabled = false;
    btnStop.style.opacity = '1';
    timerWrap.style.display = 'block';
    navDot.style.display = 'block';
  } else {
    chip.textContent = '● OFF AIR';
    chip.style.background = 'rgba(90,90,90,0.15)';
    chip.style.borderColor = 'rgba(90,90,90,0.3)';
    chip.style.color = '#888';
    chip.classList.remove('live-status-chip-on');
    btnGo.disabled  = false;
    btnGo.style.opacity = '1';
    if (btnGoTab) { btnGoTab.disabled = false; btnGoTab.style.opacity = '1'; }
    if (btnGoYt)  { btnGoYt.disabled  = false; btnGoYt.style.opacity  = '1'; }
    btnStop.disabled = true;
    btnStop.style.opacity = '0.4';
    timerWrap.style.display = 'none';
    navDot.style.display = 'none';
    var ytStatusEl = document.getElementById('yt-relay-status');
    if (ytStatusEl) ytStatusEl.style.display = 'none';
    _ytRelayLocalActive = false;
    if (document.getElementById('live-timer')) document.getElementById('live-timer').textContent = '00:00:00';
    // Reset stats
    const rttEl   = document.getElementById('live-rtt-display');
    const bytesEl = document.getElementById('live-bytes-display');
    const wsEl    = document.getElementById('live-ws-listeners');
    const qEl     = document.getElementById('live-quality-badge');
    const warnEl  = document.getElementById('live-conn-warning');
    if (rttEl)   rttEl.textContent   = '—';
    if (bytesEl) bytesEl.textContent = '0B';
    if (wsEl)    wsEl.textContent    = '0';
    if (qEl)     { qEl.textContent = '● GOOD'; qEl.style.background = 'rgba(76,175,130,0.12)'; qEl.style.borderColor = 'rgba(76,175,130,0.35)'; qEl.style.color = '#4caf82'; }
    if (warnEl)  warnEl.style.display = 'none';
  }
}

socket.on('request:new', () => {
  const badge = document.getElementById('community-badge');
  if (badge && state.currentPage !== 'community') badge.style.display = 'inline';
});

socket.on('ban:new', () => {
  // Refresh banned list if community page is open
  if (state.currentPage === 'community') loadBannedUsers();
});

socket.on('live:ended', () => {
  logActivity('⏹ Live broadcast ended');
  // Reset the Go Live UI if the broadcast was stopped externally (e.g. Icecast encoder
  // disconnected or admin heartbeat timeout) rather than by this browser's Stop button.
  if (!liveMediaRecorder || liveMediaRecorder.state === 'inactive') {
    setLiveUIState(false);
  }
});

// Icecast / external encoder started a broadcast not initiated from this browser.
socket.on('live:started', (info) => {
  if (!liveMediaRecorder || liveMediaRecorder.state === 'inactive') {
    logActivity(`📡 Encoder broadcast started: "${info.title || 'Live Broadcast'}"`);
    setLiveUIState(true);
  }
});

socket.on('live:push-sent', ({ count }) => {
  if (count > 0) {
    logActivity(`📱 Push notification sent to ${count} subscriber${count !== 1 ? 's' : ''}`);
    toast(`📱 ${count} subscriber${count !== 1 ? 's' : ''} notified`, 'success');
  }
});

// ── Server-side YouTube relay status / errors ────────────────────────────────
socket.on('youtube:status', (st) => {
  const statusEl  = document.getElementById('yt-relay-status');
  const statusTxt = document.getElementById('yt-relay-status-text');
  if (!st || !st.active) {
    if (statusEl && !_ytRelayLocalActive) statusEl.style.display = 'none';
    return;
  }
  _ytRelayLocalActive = true;
  if (statusEl)  statusEl.style.display = 'block';
  if (statusTxt) {
    if (st.waiting) {
      statusTxt.innerHTML = '⏳ Waiting for the channel to go live — the broadcast will start automatically.';
    } else if (st.retry > 0) {
      statusTxt.innerHTML = `📡 Reconnecting to YouTube… (attempt ${st.retry})`;
    } else {
      const up = st.uptime ? ` · ${Math.floor(st.uptime/60)}m ${st.uptime%60}s` : '';
      statusTxt.innerHTML = `▶ Live from YouTube: <strong>${esc(st.title || 'LETW Live')}</strong>${up}`;
    }
  }
});
socket.on('youtube:error', (msg) => {
  logActivity('⚠ YouTube relay: ' + msg);
  const statusTxt = document.getElementById('yt-relay-status-text');
  if (statusTxt && _ytRelayLocalActive) statusTxt.innerHTML = '⚠ ' + esc(String(msg));
});

// ── Live quality / health socket events ──────────────────────────────────────

// Server replies to live:ping with round-trip measurement
socket.on('live:pong', ({ clientTs, bytesSent }) => {
  _liveRtt = Date.now() - clientTs;
  _liveBytesFromServer = bytesSent || _liveBytesFromServer;

  const rttEl = document.getElementById('live-rtt-display');
  if (rttEl) {
    rttEl.textContent = _liveRtt + 'ms';
    rttEl.style.color = _liveRtt < 100 ? '#4caf82' : _liveRtt < 300 ? '#d4a843' : '#e05070';
  }
});

// Server auto-stopped the broadcast (heartbeat timeout)
socket.on('live:admin-timeout', () => {
  logActivity('⚠ Live broadcast auto-stopped: admin connection timed out.');
  // Clean up local state as if admin had clicked Stop
  if (liveMediaRecorder && liveMediaRecorder.state !== 'inactive') {
    liveMediaRecorder.stop();
    liveMediaRecorder = null;
  }
  if (liveMicStream) { liveMicStream.getTracks().forEach(t => t.stop()); liveMicStream = null; }
  if (liveMicCtx) { liveMicCtx.close(); liveMicCtx = null; }
  liveGainNode = liveBassNode = livePresenceNode = liveTrebleNode = liveNoiseGateNode = liveDestStream = null;
  _ngUsingWorklet = false;
  if (liveMicRAF) { cancelAnimationFrame(liveMicRAF); liveMicRAF = null; }
  if (liveTimerInterval) { clearInterval(liveTimerInterval); liveTimerInterval = null; }
  if (_livePingTimer)    { clearInterval(_livePingTimer);    _livePingTimer = null; }
  _liveRtt = null; _liveBytesFromServer = 0;
  setLiveUIState(false);
  if (monitorActive) stopMonitor();
  alert('⚠ Live broadcast was auto-stopped because the server lost contact with your browser for more than 20 seconds.');
});

// connect / disconnect handlers are consolidated earlier in the file (Station Health section)

// ── Activity Log ──────────────────────────────────────────────────────────────
function logActivity(msg) {
  const log = document.getElementById('activity-log');
  if (!log) return;
  const now = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  const row = document.createElement('div');
  row.style.cssText = 'color:var(--text2);padding:3px 0;border-bottom:1px solid rgba(212,168,67,0.06);animation:fadeIn 0.3s ease-out;';
  row.innerHTML = `<span style="color:rgba(212,168,67,0.4);margin-right:8px;">${now}</span>${esc(msg)}`;
  // Remove placeholder
  const placeholder = log.querySelector('div[style*="italic"]');
  if (placeholder) placeholder.remove();
  log.insertBefore(row, log.firstChild);
  // Keep max 40 entries
  while (log.children.length > 40) log.removeChild(log.lastChild);
}

function clearActivityLog() {
  const log = document.getElementById('activity-log');
  if (log) log.innerHTML = '<div style="color:var(--text3);font-style:italic;">Cleared.</div>';
}

// ── Flash Alert ───────────────────────────────────────────────────────────────
async function sendFlashAlert() {
  const text  = (document.getElementById('flash-alert-text') || {}).value || '';
  const color = (document.getElementById('flash-alert-color') || {}).value || '#d4a843';
  if (!text.trim()) { alert('Please enter a message.'); return; }
  try {
    const res = await apiFetch('/api/flash-alert', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: text.trim(), color }),
    });
    if (!res.ok) throw new Error(await res.text());
    const status = document.getElementById('flash-alert-status');
    if (status) {
      status.textContent = '⚡ Sent to all listeners!';
      status.style.display = 'block';
      setTimeout(() => { status.style.display = 'none'; }, 3000);
    }
    document.getElementById('flash-alert-text').value = '';
    logActivity(`⚡ Flash alert: "${text.slice(0, 60)}"`);
  } catch(e) {
    alert('Failed to send: ' + e.message);
  }
}

// ── Broadcast Announcement ────────────────────────────────────────────────────
async function broadcastAnnounce(enable) {
  const text = (document.getElementById('announce-text') || {}).value || '';
  try {
    await apiFetch('/api/ticker', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text: enable ? text : '', enabled: enable }),
    });
    const status = document.getElementById('announce-status');
    if (status) {
      status.textContent = enable ? 'Sent to all listeners!' : 'Ticker cleared.';
      status.style.display = 'block';
      setTimeout(() => { status.style.display = 'none'; }, 3000);
    }
    if (enable) logActivity(`📢 Announcement sent: "${text}"`);
    else logActivity('📢 Ticker cleared');
  } catch(e) {
    alert('Failed: ' + e.message);
  }
}

// ── apiFetch helper (wraps native fetch for community functions) ──────────────
const apiFetch = (path, opts = {}) => fetch(path, opts);
const escHtml = esc;

// ── Community page loader ─────────────────────────────────────────────────────
async function loadCommunity() {
  await Promise.all([loadTickerAdmin(), loadChatMod(), loadRequestsAdmin(), loadPushCount(), loadBannedUsers()]);
}

// ── Banned Users ──────────────────────────────────────────────────────────────
async function loadBannedUsers() {
  const container = document.getElementById('banned-users-list');
  if (!container) return;
  try {
    const res   = await apiFetch('/api/bans');
    const bans  = await res.json();
    if (!bans.length) {
      container.innerHTML = '<div style="padding:16px;text-align:center;font-size:12px;color:var(--text3);">No banned users. ✓</div>';
      return;
    }
    container.innerHTML = '';
    bans.forEach(ban => {
      const row = document.createElement('div');
      row.style.cssText = 'display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid rgba(224,48,96,0.08);';
      const d    = ban.banned_at ? new Date(ban.banned_at).toLocaleString([], { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '';
      const isUsername = ban.ip && ban.ip.startsWith('username:');
      const ipLabel    = isUsername ? '(by username)' : ban.ip;
      row.innerHTML =
        '<div style="flex:1;min-width:0;">' +
          '<div style="font-size:12px;font-weight:700;color:#e05070;">' + escHtml(ban.username || '—') + '</div>' +
          '<div style="font-size:10px;color:var(--text3);margin-top:2px;">' + escHtml(ipLabel) + ' · ' + escHtml(ban.reason || '') + '</div>' +
          '<div style="font-size:9px;color:rgba(192,168,216,0.35);margin-top:1px;">' + d + ' · by ' + escHtml(ban.banned_by || 'auto') + '</div>' +
        '</div>' +
        '<button onclick="unbanUser(' + ban.id + ', this)" style="background:rgba(76,175,130,0.1);border:1px solid rgba(76,175,130,0.3);color:#4caf82;border-radius:6px;padding:3px 10px;font-size:10px;cursor:pointer;font-family:inherit;flex-shrink:0;" onmouseenter="this.style.background=\'rgba(76,175,130,0.2)\'" onmouseleave="this.style.background=\'rgba(76,175,130,0.1)\'">Unban</button>';
      container.appendChild(row);
    });
  } catch(e) {
    if (container) container.innerHTML = '<div style="padding:16px;text-align:center;font-size:12px;color:var(--text3);">Failed to load bans.</div>';
  }
}

async function unbanUser(id, btn) {
  try {
    await apiFetch('/api/bans/' + id, { method: 'DELETE' });
    const row = btn && btn.closest('[style*="border-bottom"]');
    if (row) row.remove();
    const container = document.getElementById('banned-users-list');
    if (container && !container.children.length) {
      container.innerHTML = '<div style="padding:16px;text-align:center;font-size:12px;color:var(--text3);">No banned users. ✓</div>';
    }
  } catch(e) { alert('Failed to unban: ' + e.message); }
}

async function banFromChat(username) {
  if (!username) return;
  if (!confirm('Ban user "' + username + '"? They will not be able to send messages or requests.')) return;
  try {
    await apiFetch('/api/bans/by-username', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, reason: 'Banned by admin from chat' }),
    });
    toast('User "' + username + '" banned', 'success');
    await loadBannedUsers();
  } catch(e) { alert('Failed to ban user: ' + e.message); }
}

async function manualBan() {
  const username = (document.getElementById('manual-ban-username') || {}).value?.trim();
  const reason   = (document.getElementById('manual-ban-reason')   || {}).value?.trim() || 'Manual ban by admin';
  if (!username) { alert('Enter a username to ban.'); return; }
  await banFromChat(username);
  const inp = document.getElementById('manual-ban-username');
  const rInp = document.getElementById('manual-ban-reason');
  if (inp) inp.value = '';
  if (rInp) rInp.value = '';
}

// ── Ticker ────────────────────────────────────────────────────────────────────
async function loadTickerAdmin() {
  try {
    const res  = await apiFetch('/api/ticker');
    const data = await res.json();
    const inp  = document.getElementById('ticker-text-input');
    const chk  = document.getElementById('ticker-enabled-chk');
    const prev = document.getElementById('ticker-preview');
    if (inp)  inp.value   = data.text || '';
    if (chk)  chk.checked = !!data.enabled;
    if (prev) prev.textContent = data.text || '—';
  } catch(e) {}
}

document.getElementById('ticker-text-input') && document.getElementById('ticker-text-input').addEventListener('input', function() {
  const prev = document.getElementById('ticker-preview');
  if (prev) prev.textContent = this.value || '—';
});

async function saveTicker() {
  const text    = (document.getElementById('ticker-text-input') || {}).value || '';
  const enabled = !!(document.getElementById('ticker-enabled-chk') || {}).checked;
  try {
    await apiFetch('/api/ticker', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text, enabled }),
    });
    const msg = document.getElementById('ticker-save-msg');
    if (msg) { msg.style.display = 'inline'; setTimeout(() => { msg.style.display = 'none'; }, 2500); }
  } catch(e) { alert('Failed to save ticker: ' + e.message); }
}

// ── Chat moderation ───────────────────────────────────────────────────────────
async function loadChatMod() {
  const container = document.getElementById('chat-mod-list');
  if (!container) return;
  try {
    const res  = await apiFetch('/api/chat');
    const msgs = await res.json();
    if (!msgs.length) {
      container.innerHTML = '<div style="padding:20px;text-align:center;font-size:13px;color:var(--text3);">No chat messages yet.</div>';
      return;
    }
    const recent = msgs.slice(-50).reverse();
    container.innerHTML = '';
    recent.forEach(msg => {
      const row = document.createElement('div');
      row.dataset.chatId = msg.id;
      row.style.cssText = 'display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-bottom:1px solid rgba(212,168,67,0.07);transition:background 0.15s;';
      row.onmouseenter = () => { row.style.background = 'rgba(212,168,67,0.04)'; };
      row.onmouseleave = () => { row.style.background = ''; };
      const color = msg.color || '#d4a843';
      const d     = msg.created_at ? new Date(msg.created_at) : new Date();
      const time  = d.toLocaleString([], { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' });
      row.innerHTML =
        '<div style="flex:0 0 8px;width:8px;height:8px;border-radius:50%;background:' + color + ';margin-top:5px;"></div>' +
        '<div style="flex:1;min-width:0;">' +
          '<div style="display:flex;gap:8px;align-items:center;margin-bottom:2px;">' +
            '<span style="font-size:11px;font-weight:700;color:' + color + ';">' + escHtml(msg.username) + '</span>' +
            '<span style="font-size:9px;color:rgba(192,168,216,0.4);">' + time + '</span>' +
          '</div>' +
          '<div style="font-size:12px;color:var(--text3);word-break:break-word;">' + escHtml(msg.message) + '</div>' +
        '</div>' +
        '<div style="display:flex;flex-direction:column;gap:4px;flex-shrink:0;">' +
          '<button onclick="deleteChat(' + msg.id + ')" style="background:rgba(224,48,96,0.1);border:1px solid rgba(224,48,96,0.3);color:#e03060;border-radius:6px;padding:3px 8px;font-size:10px;cursor:pointer;font-family:inherit;" onmouseenter="this.style.background=\'rgba(224,48,96,0.2)\'" onmouseleave="this.style.background=\'rgba(224,48,96,0.1)\'">Delete</button>' +
          '<button onclick="banFromChat(\'' + escHtml(msg.username).replace(/'/g, "\\'") + '\')" style="background:rgba(150,30,50,0.12);border:1px solid rgba(180,40,60,0.35);color:#c05070;border-radius:6px;padding:3px 8px;font-size:10px;cursor:pointer;font-family:inherit;" onmouseenter="this.style.background=\'rgba(150,30,50,0.22)\'" onmouseleave="this.style.background=\'rgba(150,30,50,0.12)\'">🚫 Ban</button>' +
        '</div>';
      container.appendChild(row);
    });
  } catch(e) {
    container.innerHTML = '<div style="padding:20px;text-align:center;font-size:13px;color:var(--text3);">Failed to load chat.</div>';
  }
}

async function clearChat() {
  if (!confirm('Clear all chat messages? This cannot be undone.')) return;
  try {
    await apiFetch('/api/chat/all', { method: 'DELETE' });
    await loadChatMod();
  } catch(e) { alert('Failed to clear chat: ' + e.message); }
}

async function deleteChat(id) {
  try {
    await apiFetch('/api/chat/' + id, { method: 'DELETE' });
    const row = document.querySelector('[data-chat-id="' + id + '"]');
    if (row) row.remove();
  } catch(e) { alert('Failed to delete message: ' + e.message); }
