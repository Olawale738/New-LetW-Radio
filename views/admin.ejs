async function uploadFiles(files) {
  if (!files.length) return;
  const prog = document.getElementById('upload-progress');
  const bar = document.getElementById('upload-bar');
  const status = document.getElementById('upload-status');
  prog.style.display = 'block';

  const fd = new FormData();
  files.forEach(f => fd.append('files', f));
  fd.append('tray', document.getElementById('upload-tray').value);

  status.textContent = `Uploading ${files.length} file(s)...`;
  bar.style.width = '30%';

  try {
    const res = await fetch('/api/tracks/upload', { method: 'POST', body: fd });
    bar.style.width = '100%';
    const data = await res.json();
    if (data.success) {
      status.textContent = `✅ ${data.tracks.length} track(s) uploaded`;
      toast(`${data.tracks.length} track(s) uploaded successfully`, 'success');
      setTimeout(() => { closeModal('upload-modal'); prog.style.display = 'none'; bar.style.width = '0%'; }, 1500);
      loadTracks();
    } else {
      status.textContent = '❌ Upload failed';
      toast('Upload failed', 'error');
    }
  } catch (e) {
    status.textContent = '❌ ' + e.message;
    toast('Upload error: ' + e.message, 'error');
  }
}

