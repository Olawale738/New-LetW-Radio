  const set = (id, key, fallback) => {
    const v = localStorage.getItem(key);
    const el = document.getElementById(id);
    if (el && v !== null) el.value = v;
    return v !== null ? v : fallback;
  };
  // Broadcast info
  const title  = localStorage.getItem('letw_live_title');
  const artist = localStorage.getItem('letw_live_artist');
  if (title)  document.getElementById('live-title').value  = title;
  if (artist) document.getElementById('live-artist').value = artist;
  // Recording checkbox
  const rec = localStorage.getItem('letw_live_record');
  if (rec !== null) document.getElementById('live-record-check').checked = rec === '1';
  // Gain
  const gain = set('live-gain-slider', 'letw_live_gain', '4');
  document.getElementById('live-gain-display').textContent = Math.round(parseFloat(gain) * 100) + '%';
  // EQ
  const bass = set('live-bass-slider', 'letw_live_bass', '4');
  document.getElementById('live-bass-display').textContent     = (parseFloat(bass) >= 0 ? '+' : '') + parseFloat(bass) + 'dB';
  const pres = set('live-presence-slider', 'letw_live_presence', '5');
  document.getElementById('live-presence-display').textContent = (parseFloat(pres) >= 0 ? '+' : '') + parseFloat(pres) + 'dB';
  const treb = set('live-treble-slider', 'letw_live_treble', '3');
  document.getElementById('live-treble-display').textContent   = (parseFloat(treb) >= 0 ? '+' : '') + parseFloat(treb) + 'dB';
  // Noise filter
  const noiseOn = localStorage.getItem('letw_live_noise_on');
  if (noiseOn !== null) {
    document.getElementById('live-noise-toggle').checked = noiseOn !== '0';
    const label = document.getElementById('live-noise-label');
    if (label) { label.textContent = noiseOn !== '0' ? 'ON' : 'OFF'; label.style.color = noiseOn !== '0' ? '#4caf82' : 'var(--text3)'; }
  }
  const noiseThresh = set('live-noise-threshold', 'letw_live_noise_thresh', '30');
  document.getElementById('live-noise-level').textContent = noiseThresh + '%';
  // Bitrate selector
  const savedBitrate = localStorage.getItem('letw_bitrate');
  if (savedBitrate) {
    const brSel = document.getElementById('live-bitrate-select');
    if (brSel) {
      brSel.value = savedBitrate;
      const opt = brSel.options[brSel.selectedIndex];
      const lbl = document.getElementById('live-bitrate-label');
      if (lbl && opt) lbl.textContent = opt.dataset.label || (Math.round(parseInt(savedBitrate,10)/1000) + ' kbps');
    }
  }
}

