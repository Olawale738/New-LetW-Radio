            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
              <div style="font-size:11px;font-weight:700;color:var(--text);letter-spacing:0.5px;">🔊 Pre-Broadcast Sound Check</div>
              <button id="btn-soundcheck" onclick="runSoundCheck()"
