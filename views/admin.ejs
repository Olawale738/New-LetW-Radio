        '<td style="padding:10px 14px;font-size:12px;color:var(--text3);">' + escHtml(req.username) + '</td>' +
        '<td style="padding:10px 14px;font-size:12px;max-width:220px;"><div style="word-break:break-word;">' + escHtml(req.request_text) + '</div>' + dedLine + '</td>' +
        '<td style="padding:10px 14px;"><select onchange="updateRequest(' + req.id + ', this.value)" style="background:rgba(255,255,255,0.04);border:1px solid rgba(212,168,67,0.2);border-radius:6px;padding:4px 8px;color:' + statusColor + ';font-size:11px;font-family:inherit;cursor:pointer;outline:none;">' +
          '<option value="pending"'   + (req.status==='pending'   ? ' selected' : '') + ' style="background:#0e0a0f;color:#c0a8d8;">Pending</option>' +
          '<option value="approved"'  + (req.status==='approved'  ? ' selected' : '') + ' style="background:#0e0a0f;color:#4caf82;">Approved</option>' +
          '<option value="played"'    + (req.status==='played'    ? ' selected' : '') + ' style="background:#0e0a0f;color:#d4a843;">Played</option>' +
          '<option value="rejected"'  + (req.status==='rejected'  ? ' selected' : '') + ' style="background:#0e0a0f;color:#e05070;">Rejected</option>' +
        '</select></td>' +
        '<td style="padding:10px 14px;white-space:nowrap;"><button onclick="quickApprove(' + req.id + ')" style="background:rgba(76,175,130,0.12);border:1px solid rgba(76,175,130,0.3);color:#4caf82;border-radius:6px;padding:4px 10px;font-size:10px;cursor:pointer;font-family:inherit;margin-right:4px;">✓ Approve</button><button onclick="deleteRequest(' + req.id + ')" style="background:rgba(224,48,96,0.1);border:1px solid rgba(224,48,96,0.3);color:#e03060;border-radius:6px;padding:4px 10px;font-size:10px;cursor:pointer;font-family:inherit;" onmouseenter="this.style.background=\'rgba(224,48,96,0.2)\'" onmouseleave="this.style.background=\'rgba(224,48,96,0.1)\'">Delete</button></td>';
      tbody.appendChild(tr);
    });
  } catch(e) {
    tbody.innerHTML = '<tr><td colspan="5" style="padding:20px;text-align:center;color:var(--text3);font-size:13px;">Failed to load requests.</td></tr></tr>';
  }
}

async function updateRequest(id, status) {
  try {
    await apiFetch('/api/requests/' + id, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status }) });
  } catch(e) { alert('Failed to update request: ' + e.message); }
}

async function deleteRequest(id) {
  try {
    await apiFetch('/api/requests/' + id, { method: 'DELETE' });
    const row = document.querySelector('[data-req-id="' + id + '"]');
    if (row) row.remove();
  } catch(e) { alert('Failed to delete request: ' + e.message); }
}

// ── Push subscriber count ─────────────────────────────────────────────────────
async function loadPushCount() {
  try {
    const res  = await apiFetch('/api/push/subscribers/count');
    const data = await res.json();
    const el   = document.getElementById('push-sub-count');
    if (el) el.textContent = data.count || 0;
  } catch(e) {}
}

async function sendTestPush() {
  const msg = document.getElementById('push-test-msg');
  if (msg) { msg.style.display = 'inline'; setTimeout(() => { msg.style.display = 'none'; }, 2500); }
}

// ── Analytics listeners chart ─────────────────────────────────────────────────
let listenersChartInstance = null;

async function loadListenersChart() {
  const canvas = document.getElementById('listeners-chart');
  if (!canvas || typeof Chart === 'undefined') return;
  try {
    const res    = await apiFetch('/api/analytics/listeners');
    const rows   = await res.json();
    const cutoff = Date.now() - 24 * 60 * 60 * 1000;
    const filtered = rows.filter(r => new Date(r.recorded_at).getTime() >= cutoff);
    const labels   = filtered.map(r => new Date(r.recorded_at).toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' }));
    const counts   = filtered.map(r => Number(r.count));
    if (listenersChartInstance) { listenersChartInstance.destroy(); listenersChartInstance = null; }
    listenersChartInstance = new Chart(canvas, {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label: 'Listeners', data: counts, fill: true, tension: 0.4,
          borderColor: '#d4a843', borderWidth: 2, pointRadius: 0, pointHoverRadius: 4,
          pointHoverBackgroundColor: '#f0c85a',
          backgroundColor: (ctx) => {
            const g = ctx.chart.ctx.createLinearGradient(0, 0, 0, ctx.chart.height);
            g.addColorStop(0, 'rgba(212,168,67,0.25)'); g.addColorStop(1, 'rgba(212,168,67,0.0)');
            return g;
          },
        }],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(14,10,16,0.95)', borderColor: 'rgba(212,168,67,0.3)', borderWidth: 1,
            titleColor: '#f0c85a', bodyColor: '#c0a8d8',
            callbacks: { label: ctx => ' Listeners: ' + ctx.parsed.y },
          },
        },
        scales: {
          x: { grid: { color: 'rgba(212,168,67,0.06)' }, ticks: { color: 'rgba(192,168,216,0.45)', font: { size: 10 }, maxTicksLimit: 12 } },
          y: { beginAtZero: true, grid: { color: 'rgba(212,168,67,0.06)' }, ticks: { color: 'rgba(192,168,216,0.45)', font: { size: 10 }, precision: 0 } },
        },
      },
    });
  } catch(e) {}
}

// =================== TOP PLAYED TRACKS ===================
async function loadTopPlayed() {
  const el = document.getElementById('top-played-list');
  if (!el) return;
  try {
    const rows = await api('GET', '/tracks/top-played');
    if (!rows.length) { el.innerHTML = '<div style="padding:20px;text-align:center;font-size:13px;color:var(--text3);">No play history yet.</div>'; return; }
    el.innerHTML = rows.slice(0,10).map((t, i) =>
      `<div style="display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid rgba(212,168,67,0.07);">
        <div style="font-family:var(--mono);font-size:11px;color:rgba(212,168,67,0.4);width:20px;text-align:right;">${i+1}</div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:13px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(t.title)}</div>
          <div style="font-size:11px;color:var(--gold);">${esc(t.artist)}</div>
        </div>
        <div style="text-align:right;flex-shrink:0;">
          <div style="font-size:16px;font-weight:700;color:var(--gold);font-family:var(--mono);">${t.play_count}</div>
          <div style="font-size:9px;color:var(--text3);letter-spacing:1px;">PLAYS</div>
        </div>
      </div>`
    ).join('');
  } catch(e) { el.innerHTML = '<div style="padding:20px;text-align:center;font-size:13px;color:var(--text3);">Failed to load.</div>'; }
}

// =================== BULK TRACK OPERATIONS ===================
let selectedTrackIds = new Set();

function toggleTrackSelect(id, checked) {
  if (checked) selectedTrackIds.add(id); else selectedTrackIds.delete(id);
  updateBulkBar();
}

function toggleSelectAll(checked) {
  document.querySelectorAll('.track-checkbox').forEach(cb => {
    cb.checked = checked;
    toggleTrackSelect(cb.dataset.id, checked);
  });
}

function updateBulkBar() {
  const bar = document.getElementById('bulk-bar');
  const cnt = document.getElementById('bulk-count');
  if (!bar) return;
  bar.style.display = selectedTrackIds.size > 0 ? 'flex' : 'none';
  if (cnt) cnt.textContent = selectedTrackIds.size + ' selected';
}

function clearBulkSelection() {
  selectedTrackIds.clear();
  document.querySelectorAll('.track-checkbox').forEach(cb => cb.checked = false);
  const sa = document.getElementById('select-all-tracks');
  if (sa) sa.checked = false;
  updateBulkBar();
}

async function bulkDelete() {
  if (!selectedTrackIds.size) return;
  if (!confirm(`Delete ${selectedTrackIds.size} track(s)? This cannot be undone.`)) return;
  const ids = [...selectedTrackIds];
  await Promise.all(ids.map(id => api('DELETE', '/tracks/' + id).catch(() => {})));
  clearBulkSelection();
  loadTracks();
}

async function bulkMoveTray() {
  const tray = document.getElementById('bulk-tray-select').value;
  if (!tray || !selectedTrackIds.size) return;
  const ids = [...selectedTrackIds];
  await Promise.all(ids.map(id => api('PUT', '/tracks/' + id, { tray }).catch(() => {})));
  clearBulkSelection();
  loadTracks();
}

// =================== PLAYBACK SETTINGS ===================
async function savePlaybackSettings() {
  const crossfade = document.getElementById('set-crossfade').value;
  const autodj    = document.getElementById('set-autodj').checked ? '1' : '0';
  await api('PUT', '/settings', { crossfade_time: crossfade, auto_dj: autodj });
  const msg = document.getElementById('playback-settings-saved');
  msg.style.display = 'inline'; setTimeout(() => { msg.style.display = 'none'; }, 2500);
}

// =================== QUICK APPROVE REQUEST ===================
async function quickApprove(id) {
  await updateRequest(id, 'approved');
  await loadRequestsAdmin();
}

// =================== QUEUE DRAG-AND-DROP ===================
function initQueueDragDrop(tbody) {
  let dragSrc = null;
  tbody.querySelectorAll('tr[draggable]').forEach(row => {
    row.addEventListener('dragstart', e => { dragSrc = row; row.style.opacity = '0.4'; e.dataTransfer.effectAllowed = 'move'; });
    row.addEventListener('dragend',   e => { row.style.opacity = '1'; });
    row.addEventListener('dragover',  e => { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; row.style.background = 'rgba(212,168,67,0.06)'; });
    row.addEventListener('dragleave', e => { row.style.background = ''; });
    row.addEventListener('drop',      e => {
      e.stopPropagation(); row.style.background = '';
      if (dragSrc !== row) {
        const rows = [...tbody.querySelectorAll('tr')];
        const fromIdx = rows.indexOf(dragSrc);
        const toIdx   = rows.indexOf(row);
        if (fromIdx < toIdx) tbody.insertBefore(dragSrc, row.nextSibling);
        else tbody.insertBefore(dragSrc, row);
        saveDailyQueueOrder(tbody);
      }
    });
  });
}

async function saveDailyQueueOrder(tbody) {
  const ids = [...tbody.querySelectorAll('tr')].map(r => r.dataset.queueId).filter(Boolean);
  try { await api('POST', '/daily-queue/reorder', { ids }); } catch(e) {}
}

// ══════════════════════════════════════════════════════════════
// Streams / Channels management
// ══════════════════════════════════════════════════════════════

let _adminStreams = [];

async function loadAdminStreams() {
  const list = document.getElementById('streams-list');
  list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text3);">Loading…</div>';
  try {
    _adminStreams = await api('GET', '/streams/all');
    renderAdminStreamsList();
  } catch(e) {
    list.innerHTML = `<div style="text-align:center;padding:30px;color:#e05050;">${e.message}</div>`;
  }
}

function renderAdminStreamsList() {
  const list = document.getElementById('streams-list');
  if (!_adminStreams.length) {
    list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text3);font-size:13px;">No channels yet. Click "Add Channel" to create one.</div>';
    return;
  }
  list.innerHTML = `
    <table style="width:100%;border-collapse:collapse;">
      <thead>
        <tr style="font-size:10px;letter-spacing:1px;color:var(--text3);text-transform:uppercase;border-bottom:1px solid var(--border);">
          <th style="padding:8px 12px;text-align:left;">Name / Language</th>
          <th style="padding:8px 12px;text-align:left;">Stream URL</th>
          <th style="padding:8px 12px;text-align:left;">Description</th>
          <th style="padding:8px 12px;text-align:center;">Order</th>
          <th style="padding:8px 12px;text-align:center;">Active</th>
          <th style="padding:8px 12px;text-align:right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        ${_adminStreams.map(s => `
          <tr style="border-bottom:1px solid rgba(255,255,255,0.05);font-size:12px;">
            <td style="padding:10px 12px;">
              <div style="color:var(--white);font-weight:700;">${s.name}</div>
              <div style="font-size:10px;margin-top:2px;">
                ${s.language && s.language !== 'English' ? `<span style="padding:1px 6px;border-radius:6px;background:rgba(212,168,67,0.15);color:var(--accent);margin-right:4px;">${s.language}</span>` : ''}
                ${s.category && s.category !== 'General' ? `<span style="padding:1px 6px;border-radius:6px;background:rgba(100,180,255,0.12);color:#8ac4ff;margin-right:4px;">${s.category}</span>` : ''}
                ${s.whatsapp ? `<span style="padding:1px 6px;border-radius:6px;background:rgba(37,211,102,0.12);color:#25d366;">📱 WA</span>` : ''}
              </div>
            </td>
            <td style="padding:10px 12px;color:var(--accent);font-family:monospace;font-size:11px;">${s.url}</td>
            <td style="padding:10px 12px;color:var(--text3);">${s.description || '—'}</td>
            <td style="padding:10px 12px;text-align:center;color:var(--text3);">${s.sort_order}</td>
            <td style="padding:10px 12px;text-align:center;">
              <span style="font-size:11px;padding:2px 10px;border-radius:10px;background:${s.active ? 'rgba(80,200,80,0.15)' : 'rgba(200,80,80,0.12)'};color:${s.active ? '#80e080' : '#e08080'};">${s.active ? 'Active' : 'Hidden'}</span>
            </td>
            <td style="padding:10px 12px;text-align:right;white-space:nowrap;">
              <button class="btn" style="font-size:11px;padding:4px 12px;margin-right:4px;background:var(--panel);" onclick="editStream('${s.id}')">Edit</button>
              <button class="btn" style="font-size:11px;padding:4px 12px;background:rgba(200,60,60,0.2);color:#e08080;border-color:rgba(200,60,60,0.3);" onclick="deleteStream('${s.id}')">Delete</button>
            </td>
          </tr>
        `).join('')}
      </tbody>
    </table>`;
}

function openAddStreamModal() {
  document.getElementById('stream-modal-title').textContent = 'Add Channel';
  document.getElementById('stream-edit-id').value = '';
  document.getElementById('stream-name').value = '';
  document.getElementById('stream-ch-url').value = '';
  document.getElementById('stream-description').value = '';
  document.getElementById('stream-language').value = 'English';
  document.getElementById('stream-category').value = 'General';
  document.getElementById('stream-image-url').value = '';
  document.getElementById('stream-whatsapp').value = '';
  document.getElementById('stream-sort').value = _adminStreams.length;
  document.getElementById('stream-modal').style.display = 'flex';
}

function editStream(id) {
  const s = _adminStreams.find(x => x.id === id);
  if (!s) return;
  document.getElementById('stream-modal-title').textContent = 'Edit Channel';
  document.getElementById('stream-edit-id').value = s.id;
  document.getElementById('stream-name').value = s.name;
  document.getElementById('stream-ch-url').value = s.url;
  document.getElementById('stream-description').value = s.description || '';
  document.getElementById('stream-language').value = s.language || 'English';
  document.getElementById('stream-category').value = s.category || 'General';
  document.getElementById('stream-image-url').value = s.image_url || '';
  document.getElementById('stream-whatsapp').value = s.whatsapp || '';
  document.getElementById('stream-sort').value = s.sort_order || 0;
  document.getElementById('stream-modal').style.display = 'flex';
}

function closeStreamModal() {
  document.getElementById('stream-modal').style.display = 'none';
}

async function saveStream() {
  const id       = document.getElementById('stream-edit-id').value;
  const name     = document.getElementById('stream-name').value.trim();
  const url      = document.getElementById('stream-ch-url').value.trim();
  const desc     = document.getElementById('stream-description').value.trim();
  const language = document.getElementById('stream-language').value.trim() || 'English';
  const category = document.getElementById('stream-category').value.trim() || 'General';
  const image_url= document.getElementById('stream-image-url').value.trim();
  const whatsapp = document.getElementById('stream-whatsapp').value.trim();
  const sort     = parseInt(document.getElementById('stream-sort').value, 10) || 0;
  if (!name || !url) { alert('Name and URL are required'); return; }
  try {
    const payload = { name, url, description: desc, sort_order: sort, language, category, image_url, whatsapp };
    if (id) {
      await api('PUT', `/streams/${id}`, { ...payload, active: 1 });
    } else {
      await api('POST', '/streams', payload);
    }
    closeStreamModal();
    loadAdminStreams();
  } catch(e) { alert('Error: ' + e.message); }
}

async function deleteStream(id) {
  if (!confirm('Delete this channel?')) return;
  try { await api('DELETE', `/streams/${id}`); loadAdminStreams(); }
  catch(e) { alert('Error: ' + e.message); }
}
</script>
