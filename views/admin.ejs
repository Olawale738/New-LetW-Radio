// ── Pre-broadcast sound check ─────────────────────────────────────────────────
let _scRaf       = null;
let _scStream    = null;
let _scCtx       = null;
let _scAnalyser  = null;

async function runSoundCheck() {
  const btn    = document.getElementById('btn-soundcheck');
  const bar    = document.getElementById('soundcheck-bar');
  const status = document.getElementById('soundcheck-status');
  const micId  = document.getElementById('live-mic-select').value;

  if (!micId) { if (status) status.textContent = '⚠ Select a microphone first.'; return; }
  if (btn) { btn.disabled = true; btn.textContent = '⏳ Testing…'; }

  // Cleanup any previous check
  if (_scRaf)    { cancelAnimationFrame(_scRaf); _scRaf = null; }
  if (_scStream) { _scStream.getTracks().forEach(t => t.stop()); _scStream = null; }
  if (_scCtx)    { _scCtx.close(); _scCtx = null; }

  try {
    _scStream = await navigator.mediaDevices.getUserMedia({
      audio: { deviceId: { exact: micId }, echoCancellation: true, noiseSuppression: true }
    });
    _scCtx      = new (window.AudioContext || window.webkitAudioContext)();
    _scAnalyser = _scCtx.createAnalyser();
    _scAnalyser.fftSize = 256;
    const src   = _scCtx.createMediaStreamSource(_scStream);
    src.connect(_scAnalyser);

    const timeData = new Uint8Array(_scAnalyser.fftSize);
    const startTs  = Date.now();
    const duration = 5000;
    let   maxPeak  = 0;

    function tick() {
      const elapsed = Date.now() - startTs;
      if (elapsed >= duration) {
        // Done
        cancelAnimationFrame(_scRaf); _scRaf = null;
        _scStream.getTracks().forEach(t => t.stop()); _scStream = null;
        _scCtx.close(); _scCtx = null;
        if (bar)  { bar.style.width = '0%'; bar.style.background = 'linear-gradient(90deg,#4a7fd4,#6ea0e8)'; }
        if (btn)  { btn.disabled = false; btn.textContent = '▶ Test Mic (5s)'; }
        const grade = maxPeak > 60 ? '✅ Good — audio detected clearly!' : maxPeak > 20 ? '⚠ Low signal — try raising Mic Boost.' : '❌ No signal — check microphone selection.';
        const col   = maxPeak > 60 ? '#4caf82' : maxPeak > 20 ? '#d4a843' : '#e05070';
        if (status) { status.textContent = grade; status.style.color = col; }
        return;
      }

      _scAnalyser.getByteTimeDomainData(timeData);
      let sq = 0, pk = 0;
      for (let i = 0; i < timeData.length; i++) {
        const s = (timeData[i] - 128) / 128;
        sq += s * s;
        if (Math.abs(s) > pk) pk = Math.abs(s);
      }
      const rms  = Math.sqrt(sq / timeData.length);
      const pct  = Math.min(100, rms * 300);
      const pkPct = Math.min(100, pk * 100);
      if (pkPct > maxPeak) maxPeak = pkPct;

      if (bar) {
        bar.style.width = pct + '%';
        bar.style.background = pkPct > 90 ? 'linear-gradient(90deg,#ff2050,#ff0030)' : pkPct > 65 ? 'linear-gradient(90deg,#4a7fd4,#d4a843)' : 'linear-gradient(90deg,#4a7fd4,#6ea0e8)';
      }
      const remaining = Math.ceil((duration - elapsed) / 1000);
      if (status) { status.textContent = `Testing… ${remaining}s remaining  (peak: ${Math.round(pkPct)}%)`; status.style.color = 'var(--text3)'; }
      _scRaf = requestAnimationFrame(tick);
    }
    _scRaf = requestAnimationFrame(tick);
  } catch(e) {
    if (btn)    { btn.disabled = false; btn.textContent = '▶ Test Mic (5s)'; }
    if (status) { status.textContent = '❌ Could not access mic: ' + e.message; status.style.color = '#e05070'; }
  }
}

// Restore EQ/gain/noise/title settings from localStorage
