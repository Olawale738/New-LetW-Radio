              <div style="font-size:10px;color:var(--text3);margin-top:3px;">tuned in via WebSocket</div>
            </div>
            <div style="flex:1;min-width:100px;">
              <div style="font-size:10px;color:var(--text3);letter-spacing:2px;text-transform:uppercase;margin-bottom:4px;">Total Listeners</div>
              <div style="font-family:'Cinzel',serif;font-size:32px;color:var(--text2);line-height:1;" id="live-total-listener-count">0</div>
              <div style="font-size:10px;color:var(--text3);margin-top:3px;">including HTTP stream</div>
            </div>
          </div>
        </div>

      </div>
    </div>

