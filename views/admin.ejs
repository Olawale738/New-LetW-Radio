// =================== PLANNING CALENDAR ===================
const HOURS = Array.from({length:24},(_,i) => i);
const PX_PER_HOUR = 40;
const DAYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

function buildCalendarStructure() {
  const timesEl = document.getElementById('cal-times');
  timesEl.innerHTML = '';
  const today = new Date().getDay();

  HOURS.forEach(h => {
    const div = document.createElement('div');
    div.className = 'cal-time-slot';
    div.textContent = `${String(h).padStart(2,'0')}:00`;
    timesEl.appendChild(div);
  });

  // Add 24 hour lines to each column
  for (let d = 0; d < 7; d++) {
    const col = document.getElementById(`col-${d}`);
    col.innerHTML = '';
    col.style.position = 'relative';
    col.style.minHeight = (HOURS.length * PX_PER_HOUR) + 'px';
    HOURS.forEach(() => {
      const line = document.createElement('div');
      line.className = 'cal-hour-line';
      col.appendChild(line);
    });
    // Make column clickable
    col.addEventListener('click', (e) => {
      if (!e.target.classList.contains('cal-slot')) {
        const rect = col.getBoundingClientRect();
        const bodyEl = document.getElementById('cal-body');
        const scrollTop = bodyEl.scrollTop;
        const y = e.clientY - rect.top + scrollTop;
        const hour = Math.floor(y / PX_PER_HOUR);
        const minutes = Math.floor((y % PX_PER_HOUR) / PX_PER_HOUR * 60 / 15) * 15;
        const hh = String(hour).padStart(2,'0');
        const mm = String(minutes).padStart(2,'0');
        document.getElementById('plan-day').value = d;
        document.getElementById('plan-start').value = `${hh}:${mm}`;
        const endH = hour < 23 ? hour + 1 : 23;
        document.getElementById('plan-end').value = `${String(endH).padStart(2,'0')}:${mm}`;
        openPlanningModal();
      }
    });

    // Today highlight
    if (d === today) {
      document.getElementById(`cal-${DAYS[d].toLowerCase()}`).classList.add('today');
    }
  }

  updateCurrentTimeLine();
  setInterval(updateCurrentTimeLine, 60000);
}

function updateCurrentTimeLine() {
  document.querySelectorAll('.current-time-line').forEach(el => el.remove());
  const now = new Date();
  const dayIndex = now.getDay(); // 0=Sun
  const col = document.getElementById(`col-${dayIndex}`);
  if (!col) return;
  const totalMins = now.getHours() * 60 + now.getMinutes();
  const top = (totalMins / 60) * PX_PER_HOUR;
  const line = document.createElement('div');
  line.className = 'current-time-line';
  line.style.top = top + 'px';
  col.appendChild(line);
}

async function loadPlanning() {
  buildCalendarStructure();
  const slots = await api('GET', '/planning');
  state.planning = slots;
  renderCalendarSlots(slots);
}

function timeToMinutes(t) {
  const [h, m] = t.split(':').map(Number);
  return h * 60 + m;
}

function renderCalendarSlots(slots) {
  // Clear existing slots
  for (let d = 0; d < 7; d++) {
    const col = document.getElementById(`col-${d}`);
    col.querySelectorAll('.cal-slot').forEach(s => s.remove());
  }

  slots.forEach(slot => {
    const col = document.getElementById(`col-${slot.day_of_week}`);
    if (!col) return;
    const startMins = timeToMinutes(slot.start_time);
    const endMins = timeToMinutes(slot.end_time);
    const top = (startMins / 60) * PX_PER_HOUR;
    const height = Math.max(20, ((endMins - startMins) / 60) * PX_PER_HOUR);

    const slotEl = document.createElement('div');
    slotEl.className = 'cal-slot';
    slotEl.style.top = top + 'px';
    slotEl.style.height = height + 'px';
    slotEl.style.background = hexToRgba(slot.color || '#00e5ff', 0.2);
    slotEl.style.border = `1px solid ${slot.color || '#00e5ff'}`;
    slotEl.style.color = slot.color || '#00e5ff';
    slotEl.innerHTML = `
      <div class="cal-slot-title">${esc(slot.content_name)}</div>
      <div class="cal-slot-time">${slot.start_time}–${slot.end_time}</div>`;
    slotEl.title = `${slot.content_name} | ${slot.start_time}–${slot.end_time}`;

    slotEl.addEventListener('click', (e) => {
      e.stopPropagation();
      if (confirm(`Delete slot "${slot.content_name}"?`)) {
        api('DELETE', `/planning/${slot.id}`).then(() => {
          toast('Slot deleted', 'success');
          loadPlanning();
        });
      }
    });

    col.appendChild(slotEl);
  });
}

async function openPlanningModal() {
  await loadPlanContent();
  openModal('planning-modal');
}

async function loadPlanContent() {
  const type = document.getElementById('plan-type').value;
  const select = document.getElementById('plan-content');
  const items = type === 'playlist' ? state.playlists || await api('GET', '/playlists') : state.programs || await api('GET', '/programs');
  select.innerHTML = items.map(i => `<option value="${i.id}" data-name="${esc(i.name)}">${esc(i.name)}</option>`).join('');
}

async function savePlanSlot() {
  const day = parseInt(document.getElementById('plan-day').value);
  const start = document.getElementById('plan-start').value;
  const end = document.getElementById('plan-end').value;
  const type = document.getElementById('plan-type').value;
  const contentSel = document.getElementById('plan-content');
  const contentId = contentSel.value;
  const contentName = contentSel.options[contentSel.selectedIndex]?.text || '';

  if (!start || !end || !contentId) return toast('Fill in all fields', 'error');
  if (start >= end) return toast('End time must be after start time', 'error');

  const items = type === 'playlist' ? (state.playlists || []) : (state.programs || []);
  const item = items.find(i => i.id === contentId);
  const color = item?.color || '#00e5ff';

  try {
    await api('POST', '/planning', {
      day_of_week: day, start_time: start, end_time: end,
      content_type: type, content_id: contentId, content_name: contentName,
      color, play_order: document.getElementById('plan-order').value,
      play_at_fixed_time: document.getElementById('plan-fixed-time').checked ? 1 : 0,
    });
    toast('Slot added to planning', 'success');
    closeModal('planning-modal');
    loadPlanning();
  } catch (e) { toast(e.message, 'error'); }
}

